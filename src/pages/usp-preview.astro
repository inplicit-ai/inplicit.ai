---
import Layout from '../layouts/Layout.astro';
import UspGrid2 from '../components/UspGrid2.astro';

const facts = [
  { icon: 'coins',  viz: 'savings',     title: 'Spart Zeit und Geld',               body: 'Bisher haben oft Beratungsfirmen Mitarbeiterbefragungen durchgeführt – teuer und zeitaufwändig. Inplicit liefert diese Erkenntnisse in Stunden statt Monaten, zu einem Bruchteil klassischer Kosten.' },
  { icon: 'users',  viz: 'departments', title: 'Skalierbar auf die gesamte Belegschaft', body: 'KI ermöglicht es, hunderte Mitarbeitende gleichzeitig zu interviewen – und sofort auszuwerten. So kann die gesamte Belegschaft, oder gezielt die richtigen Menschen, in Stunden befragt werden.' },
  { icon: 'mic',    viz: 'interviews',  title: 'Rollenspezifische KI-Interviews',    body: 'Jede Frage passt sich an Rolle und Kontext an. Auch können Antworten innerhalb einer Kampagne direkt cross-validiert werden.' },
  { icon: 'cpu',    viz: 'context',     title: 'Die fehlende menschliche Ebene für eure KI-Tools', body: 'Das meiste Wissen bleibt unsichtbar – in den Köpfen eurer Mitarbeitenden. Inplicit macht dieses Erfahrungswissen durch KI-Interviews sichtbar und verbindet es direkt mit euren KI-Tools. So arbeiten sie nicht nur mit Dokumenten, sondern mit echtem Praxiswissen – für präzisere, weniger generische Antworten.' },
];
---

<Layout title="USP animation preview" lang="de">
  <main class="prev">
    <div class="container">
      <span class="section-eyebrow">Warum inplicit</span>
      <h2 class="prev__h">
        <span>Alles, was Sie brauchen,</span>
        <span class="prev__h-ghost">um Ihre Organisation wirklich zu verstehen.</span>
      </h2>
      <UspGrid2 facts={facts} />
    </div>
  </main>
</Layout>

<style>
  .prev { padding: 120px 0 160px; }
  .prev__h { font-size: clamp(var(--text-xl), 4vw, var(--text-2xl)); font-weight: 400; letter-spacing: -0.04em; line-height: 1.1; color: var(--color-text-primary); margin-bottom: var(--space-10); max-width: 720px; display: flex; flex-direction: column; gap: 0.08em; }
  .prev__h-ghost { color: var(--color-text-primary); opacity: 0.3; }
</style>

---
import Layout from '../layouts/Layout.astro';
import UspGrid2 from '../components/UspGrid2.astro';

const facts = [
  { icon: 'coins',  viz: 'savings',     title: 'Spart Zeit und Geld',               body: 'Erkenntnisse in Stunden statt Monaten, zu einem Bruchteil klassischer Beratungskosten.' },
  { icon: 'users',  viz: 'departments', title: 'Skalierbar auf die gesamte Belegschaft', body: 'KI ermöglicht es, hunderte Mitarbeitende gleichzeitig zu interviewen – und sofort auszuwerten. So kann die gesamte Belegschaft in Stunden befragt werden, oder gezielt die richtigen Menschen.' },
  { icon: 'mic',    viz: 'interviews',  title: 'Rollenspezifische KI-Interviews',    body: 'Ein Kampagnenziel gibt die Richtung vor, jede Frage passt sich Rolle und Kontext an. Innerhalb einer Kampagne werden Antworten aufgenommen und direkt cross-validiert.' },
  { icon: 'cpu',    viz: 'context',     title: 'Die fehlende menschliche Ebene für eure KI-Tools', body: 'Das meiste Wissen bleibt unsichtbar – in den Köpfen der Mitarbeitenden. Inplicit macht diese implizite Ebene für eure KI-Agenten zugänglich (via MCP). Mit dem richtigen Kontext liefern sie [XX] % bessere Ergebnisse.' },
];
---

<Layout title="USP animation preview" lang="de">
  <main class="prev">
    <div class="container">
      <span class="section-eyebrow">Warum inplicit</span>
      <h2 class="prev__h">
        <span>Alles, was Sie brauchen,</span>
        <span class="prev__h-ghost">um Ihre Organisation wirklich zu verstehen.</span>
      </h2>
      <UspGrid2 facts={facts} />
    </div>
  </main>
</Layout>

<style>
  .prev { padding: 120px 0 160px; }
  .prev__h { font-size: clamp(var(--text-xl), 4vw, var(--text-2xl)); font-weight: 400; letter-spacing: -0.04em; line-height: 1.1; color: var(--color-text-primary); margin-bottom: var(--space-10); max-width: 720px; display: flex; flex-direction: column; gap: 0.08em; }
  .prev__h-ghost { color: var(--color-text-primary); opacity: 0.3; }
</style>

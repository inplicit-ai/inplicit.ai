---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import TrustCenter from '../components/TrustCenter.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';
---

<Layout
  title="Trust Center - inplicit.ai"
  description="Everything you need to know about how inplicit handles your data. GDPR compliant, EU-hosted, works-council ready."
  lang={lang}
>
  <Nav lang={lang} />
  <main>
    <TrustCenter lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.section-fade').forEach((el) => observer.observe(el));
</script>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Imprint / Impressum - inplicit.ai" description="Legal imprint for inplicit.ai (§5 TMG)">
  <Nav />
  <main class="legal container">
    <h1>Imprint / Impressum</h1>

    <section>
      <h2>DE - Impressum (§5 TMG)</h2>
      <p><strong>Angaben gemäß §5 TMG:</strong></p>
      <p>
        inplicit.ai<br />
        [Straße und Hausnummer]<br />
        [PLZ] [Stadt]<br />
        Deutschland
      </p>
      <p>
        <strong>Vertreten durch:</strong><br />
        [Vorname Nachname]
      </p>
      <p>
        <strong>Kontakt:</strong><br />
        E-Mail: hello@inplicit.ai
      </p>
      <p>
        <strong>Umsatzsteuer-Identifikationsnummer:</strong><br />
        [USt-IdNr., sofern vorhanden]
      </p>
      <p>
        <strong>Verantwortlich für den Inhalt nach §55 Abs. 2 RStV:</strong><br />
        [Vorname Nachname]<br />
        [Adresse wie oben]
      </p>
    </section>

    <section>
      <h2>EN - Imprint</h2>
      <p>
        inplicit.ai<br />
        [Street, House Number]<br />
        [Postcode] [City]<br />
        Germany
      </p>
      <p>
        <strong>Represented by:</strong><br />
        [First name Last name]
      </p>
      <p>
        <strong>Contact:</strong><br />
        Email: hello@inplicit.ai
      </p>
      <p>
        <strong>VAT identification number:</strong><br />
        [VAT ID, if applicable]
      </p>
      <p>
        <strong>Responsible for content (§55 Abs. 2 RStV):</strong><br />
        [First name Last name]<br />
        [Address as above]
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .legal {
    padding: var(--space-16) var(--space-4);
    max-width: 720px;
  }

  .legal h1 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
  }

  .legal section {
    margin-bottom: var(--space-12);
  }

  .legal h2 {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-accent);
  }

  .legal p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .legal strong {
    color: var(--color-text-primary);
  }
</style>

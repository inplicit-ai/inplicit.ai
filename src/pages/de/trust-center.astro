---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import TrustCenter from '../../components/TrustCenter.astro';
import Footer from '../../components/Footer.astro';

const lang = 'de';
---

<Layout
  title="Trust Center - inplicit.ai"
  description="Transparenz über Datenschutz und KI-Einsatz bei inplicit. DSGVO-konform, EU-gehostet, Betriebsrat-ready."
  lang={lang}
>
  <Nav lang={lang} />
  <main>
    <TrustCenter lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.section-fade').forEach((el) => observer.observe(el));
</script>

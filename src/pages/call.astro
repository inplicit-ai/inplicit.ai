---
import '../styles/design.css';

const CAL_LINK = 'inplicit/30min';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Book a call · Inplicit</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <div id="cal-inline" data-cal-link={CAL_LINK}></div>
    </main>

    <script is:inline>
      (function (C, A, INIT) {
        const p = (a, ar) => { a.q.push(ar); };
        const d = C.document;
        C.Cal = C.Cal || function () {
          const cal = C.Cal;
          const ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement('script')).src = A;
            cal.loaded = true;
          }
          if (ar[0] === INIT) {
            const api = function () { p(api, arguments); };
            const ns = ar[1];
            api.q = api.q || [];
            typeof ns === 'string' ? (cal.ns[ns] = api) && p(api, ar) : p(cal, ar);
            return;
          }
          p(cal, ar);
        };
      })(window, 'https://app.cal.eu/embed/embed.js', 'init');

      Cal('init', { origin: 'https://cal.eu' });
      Cal('inline', {
        elementOrSelector: '#cal-inline',
        calLink: 'inplicit/30min',
        layout: 'month_view',
        config: { theme: 'light', locale: 'de' },
      });
      Cal('ui', {
        styles: { branding: { brandColor: '#f5a623' } },
        hideEventTypeDetails: false,
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--color-bg);
  }

  main {
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  #cal-inline {
    flex: 1;
    min-height: 0;
  }

  #cal-inline cal-inline {
    height: 100% !important;
    display: block;
  }

  #cal-inline iframe.cal-embed {
    height: 100% !important;
  }
</style>

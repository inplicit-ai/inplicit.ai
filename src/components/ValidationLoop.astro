---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const stages = lang === 'de' ? [
  { id: 'listen',      num: '01', label: 'Zuhören',      desc: 'KI-Gespräche mit der gesamten Belegschaft, kreuzvalidiert für Ehrlichkeit' },
  { id: 'synthesise',  num: '02', label: 'Verdichten',   desc: 'Muster und Cluster über Gespräche und Teams hinweg erkennen' },
  { id: 'generate',   num: '03', label: 'Generieren',    desc: 'Konkrete Erkenntnisse aus verdichteten Signalen ableiten' },
  { id: 'validate',   num: '04', label: 'Validieren',    desc: 'Erkenntnisse gegen reale Einschränkungen und strategische Ziele prüfen' },
  { id: 'converge',   num: '05', label: 'Konvergieren',  desc: 'Priorisierte, handlungsfertige Ergebnisse für die Entscheidungsebene liefern' },
] : [
  { id: 'listen',      num: '01', label: 'Listen',     desc: 'AI conversations with your entire workforce, cross-validated for honesty' },
  { id: 'synthesise',  num: '02', label: 'Synthesise', desc: 'Identify patterns and clusters across conversations and teams' },
  { id: 'generate',   num: '03', label: 'Generate',    desc: 'Derive concrete insights from synthesised signals' },
  { id: 'validate',   num: '04', label: 'Validate',    desc: 'Test findings against real constraints and strategic goals' },
  { id: 'converge',   num: '05', label: 'Converge',    desc: 'Deliver prioritised, action-ready results to decision level' },
];
---

<section class="loop" id="validation-loop">
  <div class="container">
    <div class="loop__header">
      <p class="loop__eyebrow section-fade">
        {lang === 'de' ? 'Proprietärer Prozess' : 'Proprietary process'}
      </p>
      <h2 class="loop__heading section-fade">
        <span class="loop__heading-line1">{lang === 'de' ? 'Der Validierungskreislauf' : 'The Validation Loop'}</span>
        <span class="loop__heading-line2">{lang === 'de' ? 'Fünf Stufen. Kein Rauschen.' : 'Five stages. Zero noise.'}</span>
      </h2>
      <p class="loop__sub section-fade">
        {lang === 'de'
          ? 'Ein proprietärer 5-Stufen-Prozess, der das Wissen Ihrer Belegschaft in handlungsfertige Erkenntnisse verwandelt.'
          : 'A proprietary 5-stage process that turns what your workforce knows into action-ready insights.'}
      </p>
    </div>

    <!-- Desktop: horizontal stepper -->
    <div class="loop__stepper" aria-hidden="true">
      {stages.map((stage, i) => (
        <div class="loop__stepper-item">
          <div class="loop__stepper-circle">{stage.num}</div>
          {i < stages.length - 1 && <div class="loop__stepper-line"></div>}
        </div>
      ))}
    </div>

    <!-- Cards -->
    <div class="loop__flow">
      {stages.map((stage, i) => (
        <div class="loop__stage section-fade" style={`--delay: ${i * 80}ms`}>
          <span class="loop__stage-num" aria-hidden="true">{stage.num}</span>
          <span class="loop__stage-label">{stage.label}</span>
          <p class="loop__stage-desc">{stage.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .loop {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .loop { padding: var(--space-24) 0; }
  }

  .loop__header {
    margin-bottom: var(--space-16);
    max-width: 640px;
  }

  @media (max-width: 767px) {
    .loop__header { margin-bottom: var(--space-10); }
  }

  .loop__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .loop__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 400;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    line-height: 1.05;
  }

  .loop__heading-line1 { color: var(--color-text-primary); }
  .loop__heading-line2 { color: var(--color-text-primary); opacity: 0.3; }

  .loop__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Stepper (desktop only) */
  .loop__stepper { display: none; }

  @media (min-width: 768px) {
    .loop__stepper {
      display: flex;
      align-items: center;
      margin-bottom: var(--space-6);
    }
  }

  .loop__stepper-item {
    display: flex;
    align-items: center;
    flex: 1;
  }

  .loop__stepper-item:last-child { flex: 0; }

  .loop__stepper-circle {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-ui);
    background-color: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: var(--text-xs);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .loop__stepper-line {
    flex: 1;
    height: 1px;
    background-color: var(--color-border);
    margin: 0 var(--space-1);
  }

  /* Cards */
  .loop__flow {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  @media (min-width: 480px) and (max-width: 767px) {
    .loop__flow { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 768px) {
    .loop__flow { grid-template-columns: repeat(5, 1fr); }
  }

  .loop__stage {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-4) var(--space-4) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: border-color 0.2s var(--ease-smooth), background-color 0.2s var(--ease-smooth);
    position: relative;
    overflow: hidden;
  }

  .loop__stage:hover {
    border-color: var(--color-text-tertiary);
    background-color: var(--color-surface-elevated);
  }

  .loop__stage-num {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-tertiary);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }

  .loop__stage-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .loop__stage-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>

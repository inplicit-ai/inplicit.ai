---
export interface Props { type: string; }
const { type } = Astro.props;

const departments = [
  { name: 'Betrieb', n: 18 },
  { name: 'Vertrieb', n: 15 },
  { name: 'IT', n: 10 },
  { name: 'Personal', n: 9 },
];
const questions = [
  'Wo verlieren wir die meiste Zeit?',
  'Welche Abläufe bremsen den Betrieb aus?',
  'Kommt das neue Rollout wirklich an?',
  'Was sollten wir zuerst automatisieren?',
  'Wo hakt es im Onboarding?',
];
const aiTools = ['Claude', 'Gemini', 'Copilot', 'GPT'];
---

{type === 'savings' && (
  <div class="viz red" aria-hidden="true">
    <svg viewBox="0 0 320 132" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path class="red__area" d="M40 28 C 120 34, 150 92, 280 100 L280 116 L40 116 Z" fill="var(--color-accent)" />
      <path class="red__line" d="M40 28 C 120 34, 150 92, 280 100" stroke="var(--color-accent)" stroke-width="2" />
      <circle cx="40" cy="28" r="4" fill="var(--color-text-tertiary)" />
      <circle class="red__ping" cx="280" cy="100" r="6" fill="none" stroke="var(--color-accent)" />
      <circle cx="280" cy="100" r="6" fill="var(--color-accent)" />
      <text x="48" y="22" text-anchor="start" font-size="11" fill="var(--color-text-tertiary)" font-family="Inter, sans-serif">Monate · €500k+</text>
      <text x="272" y="90" text-anchor="end" font-size="12" font-weight="700" fill="var(--color-accent)" font-family="Inter, sans-serif">Tage · ab €30k</text>
    </svg>
  </div>
)}

{type === 'departments' && (
  <div class="viz dept" data-questions={JSON.stringify(questions)} aria-hidden="true">
    <div class="dept__chat">
      <span class="dept__chat-mark"></span>
      <span class="dept__chat-q">{questions[0]}</span>
    </div>
    <span class="dept__status">Gesamte Belegschaft · Antworten in Stunden</span>
    <div class="org">
      <span class="org__top">C-Level</span>
      <svg class="org__lines" viewBox="0 0 1000 56" preserveAspectRatio="none">
        {departments.map((_, i) => (
          <path class="org__path" data-i={i} d={`M ${125 + i * 250} 56 L ${125 + i * 250} 28 L 500 28 L 500 0`} />
        ))}
      </svg>
      <div class="org__row">
        {departments.map((d) => (
          <div class="org__dept" data-dept={d.name}>
            <span class="org__name">{d.name}</span>
            <div class="org__dots">
              {Array.from({ length: d.n }).map(() => <span></span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
)}

{type === 'context' && (
  <div class="viz ctx" aria-hidden="true">
    <div class="ctx__stack">
      <span class="ctx__label">Organisationskontext</span>
      <div class="ctx__layer ctx__layer--human">
        <span>Menschlicher Kontext</span>
        <em>+ inplicit</em>
      </div>
      <div class="ctx__layer ctx__layer--base">Daten &amp; Systeme</div>
    </div>
    <div class="ctx__pipe" aria-hidden="true"></div>
    <div class="ctx__ai">
      {aiTools.map((t) => <span class="ctx__chip">{t}</span>)}
    </div>
  </div>
)}

<style>
  .viz { width: 100%; color: var(--color-accent); }

  /* ── savings: a single descending curve = less time & cost ── */
  .red { display: flex; justify-content: center; }
  .red svg { width: 100%; max-width: 320px; height: auto; }
  .red__area { opacity: 0; }
  .red__line { fill: none; stroke-dasharray: 360; stroke-dashoffset: 360; }
  :global(.is-visible) .red__line { animation: draw 1.6s var(--ease-smooth) forwards; }
  :global(.is-visible) .red__area { animation: areaIn 1s ease 0.7s forwards; }
  @keyframes draw { to { stroke-dashoffset: 0; } }
  @keyframes areaIn { to { opacity: 0.07; } }
  .red__ping { transform-box: fill-box; transform-origin: center; animation: ping 3.2s ease-out infinite; }
  @keyframes ping { 0% { transform: scale(1); opacity: 0.4; } 70%, 100% { transform: scale(1.9); opacity: 0; } }

  /* ── departments: SVG org chart, path lights up to C-Level ── */
  .dept { display: flex; flex-direction: column; gap: 6px; }
  .dept__chat { display: flex; align-items: center; gap: 9px; padding: 9px 11px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface); }
  .dept__chat-mark { width: 16px; height: 16px; border-radius: 5px; background: var(--color-accent); flex-shrink: 0; }
  .dept__chat-q { font-size: 12px; color: var(--color-text-primary); transition: opacity 0.25s ease; }
  .dept__status { font-size: 11px; color: var(--color-text-tertiary); margin-bottom: 6px; transition: opacity 0.25s ease; }
  .org { display: flex; flex-direction: column; }
  .org__top { text-align: center; font-size: 11px; font-weight: 600; color: var(--color-text-secondary); transition: color 0.3s ease; }
  .org__lines { width: 100%; height: 38px; }
  .org__path { fill: none; stroke: var(--color-border); stroke-width: 1.5px; vector-effect: non-scaling-stroke; transition: stroke 0.3s ease; }
  .org__row { display: flex; }
  .org__dept { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 7px; }
  .org__name { font-size: 11px; color: var(--color-text-secondary); transition: color 0.3s ease; }
  .org__dots { display: flex; flex-wrap: wrap; justify-content: center; gap: 3px; max-width: 64px; }
  .org__dots span { width: 8px; height: 8px; border-radius: 2px; background: var(--color-border); transition: background-color 0.4s ease; }
  .dept.is-all .org__top, .dept.is-all .org__name { color: var(--color-accent); }
  .dept.is-all .org__path { stroke: var(--color-accent); }
  .dept.is-all .org__dots span { background: var(--color-accent); }
  .dept.is-single .org__top { color: var(--color-accent); }
  .org__path.is-active { stroke: var(--color-accent); stroke-width: 2px; }
  .org__dept.is-active .org__name { color: var(--color-accent); font-weight: 600; }
  .org__dept.is-active .org__dots span { background: var(--color-accent); }

  /* ── context: inplicit adds the human layer to the org context ── */
  .ctx { display: flex; align-items: center; gap: 10px; }
  .ctx__stack { flex: 1; display: flex; flex-direction: column; gap: 6px; }
  .ctx__label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-tertiary); }
  .ctx__layer { border-radius: 8px; padding: 11px 12px; font-size: 12px; }
  .ctx__layer--human {
    display: flex; align-items: center; justify-content: space-between;
    border: 1px solid var(--color-accent); background: var(--color-accent-light);
    color: var(--color-accent); font-weight: 600;
    animation: layerIn 0.7s var(--ease-smooth) both, humanPulse 3s ease-in-out 0.8s infinite;
  }
  .ctx__layer--human em { font-style: normal; font-size: 10px; opacity: 0.8; }
  .ctx__layer--base { border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); }
  @keyframes layerIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }
  @keyframes humanPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(245,166,35,0); } 50% { box-shadow: 0 0 0 4px var(--color-accent-light); } }
  .ctx__pipe { width: 26px; height: 2px; flex-shrink: 0; background-image: repeating-linear-gradient(90deg, var(--color-accent) 0 4px, transparent 4px 9px); background-size: 13px 2px; animation: flow 0.9s linear infinite; }
  @keyframes flow { to { background-position: 13px 0; } }
  .ctx__ai { display: flex; flex-direction: column; gap: 5px; flex-shrink: 0; }
  .ctx__chip { font-size: 11px; padding: 4px 9px; border-radius: 6px; border: 1px solid var(--color-border); color: var(--color-text-primary); text-align: center; }

  @media (prefers-reduced-motion: reduce) {
    .viz * { animation: none !important; }
    .red__line { stroke-dashoffset: 0; }
    .red__area { opacity: 0.07; }
  }
</style>

<script>
  function runDept(card: Element) {
    const q = card.querySelector('.dept__chat-q') as HTMLElement | null;
    const status = card.querySelector('.dept__status') as HTMLElement | null;
    const depts = [...card.querySelectorAll('.org__dept')] as HTMLElement[];
    const paths = [...card.querySelectorAll('.org__path')] as SVGElement[];
    if (!q || !depts.length) return;
    let questions: string[] = [];
    try { questions = JSON.parse(card.getAttribute('data-questions') || '[]'); } catch {}
    let step = 0;
    const tick = () => {
      q.style.opacity = '0';
      if (status) status.style.opacity = '0';
      setTimeout(() => {
        if (step === 0) {
          card.classList.add('is-all');
          card.classList.remove('is-single');
          depts.forEach((d) => d.classList.remove('is-active'));
          paths.forEach((p) => p.classList.remove('is-active'));
          if (status) status.textContent = 'Gesamte Belegschaft · Antworten in Stunden';
        } else {
          card.classList.remove('is-all');
          card.classList.add('is-single');
          depts.forEach((d, i) => d.classList.toggle('is-active', i === step - 1));
          paths.forEach((p, i) => p.classList.toggle('is-active', i === step - 1));
          if (status) status.textContent = 'Gezielt an die richtigen Menschen: ' + (depts[step - 1].getAttribute('data-dept') || '');
        }
        q.textContent = questions[step] || '';
        q.style.opacity = '1';
        if (status) status.style.opacity = '1';
        step = (step + 1) % (depts.length + 1);
      }, 220);
    };
    let started = false;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !started) {
          started = true; step = 0; tick(); setInterval(tick, 2600); io.disconnect();
        }
      });
    }, { threshold: 0.4 });
    io.observe(card);
  }
  document.querySelectorAll('.dept').forEach(runDept);
</script>

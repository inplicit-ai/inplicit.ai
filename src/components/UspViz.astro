---
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props { type: string; lang?: 'en' | 'de'; }
const { type, lang = 'de' } = Astro.props;
const isDE = lang === 'de';

const departments = isDE
  ? [{ name: 'Betrieb', n: 18 }, { name: 'Vertrieb', n: 15 }, { name: 'IT', n: 10 }, { name: 'Personal', n: 9 }]
  : [{ name: 'Operations', n: 18 }, { name: 'Sales', n: 15 }, { name: 'IT', n: 10 }, { name: 'People', n: 9 }];
const deptQuestions = isDE
  ? ['Wo verlieren wir die meiste Zeit?','Welche Abläufe bremsen den Betrieb aus?','Was sollten wir zuerst automatisieren?','Wo hakt es im Onboarding?','Kommt das neue Rollout wirklich an?']
  : ['Where do we lose the most time?','Which processes slow operations down?','What should we automate first?','Where does onboarding get stuck?','Is the new rollout really landing?'];
const campaignGoal = isDE ? 'Ineffizienzen im Tagesgeschäft' : 'Inefficiencies in daily work';
const roles = isDE ? [
  { role: 'Schichtleiter',        ctx: 'Logistik · Hallenumbau',        photo: 'photo-1560250097-0b93528c311a', q: 'Als Schichtleiter koordinierst du gerade den Hallenumbau – wo verlierst du im Tagesablauf am meisten Zeit?' },
  { role: 'Vertriebsmitarbeiter', ctx: 'Sales · Region Ost',            photo: 'photo-1507003211169-0a1dd7228f2d', q: 'Im Vertrieb für Region Ost: an welcher Stelle im Abschluss stockt es bei dir am häufigsten?' },
  { role: 'IT-Admin',             ctx: 'IT · Ticket-Migration',         photo: 'photo-1500648767791-00dcc994a43e', q: 'Ihr migriert gerade das Ticket-System – welche wiederkehrende Aufgabe frisst dabei die meiste Zeit?' },
  { role: 'HR Business Partner',  ctx: 'People · Onboarding-Rollout',   photo: 'photo-1472099645785-5658abf4ff4e', q: 'Beim neuen Onboarding-Rollout, den du betreust: wo hakt es im Ablauf für dich am meisten?' },
  { role: 'Teamleiterin',         ctx: 'Strategy & Ops · Rollout Nord', photo: 'photo-1494790108377-be9c29b29330', q: 'Als Teamleiterin steckst du gerade im Rollout Nord – an welcher Übergabe geht bei euch am meisten Zeit verloren?' },
  { role: 'Qualitätsmanagerin',   ctx: 'QM · Audit-Vorbereitung',       photo: 'photo-1438761681033-6461ffad8d80', q: 'In der Audit-Vorbereitung: wo entstehen bei euch die meisten vermeidbaren Fehler?' },
] : [
  { role: 'Shift lead',        ctx: 'Logistics · Warehouse revamp', photo: 'photo-1560250097-0b93528c311a', q: 'As shift lead you\'re coordinating the warehouse revamp – where do you lose the most time day to day?' },
  { role: 'Sales rep',         ctx: 'Sales · East region',          photo: 'photo-1507003211169-0a1dd7228f2d', q: 'In sales for the East region: where in the closing process does it stall for you most often?' },
  { role: 'IT admin',          ctx: 'IT · Ticket migration',        photo: 'photo-1500648767791-00dcc994a43e', q: 'You\'re migrating the ticketing system – which recurring task eats up the most time?' },
  { role: 'HR business partner', ctx: 'People · Onboarding rollout', photo: 'photo-1472099645785-5658abf4ff4e', q: 'On the new onboarding rollout you own: where does the process snag most for you?' },
  { role: 'Team lead',         ctx: 'Strategy & Ops · North rollout', photo: 'photo-1494790108377-be9c29b29330', q: 'As team lead you\'re deep in the North rollout – at which handoff does the most time get lost?' },
  { role: 'Quality manager',   ctx: 'QA · Audit prep',              photo: 'photo-1438761681033-6461ffad8d80', q: 'In audit prep: where do the most avoidable errors happen on your side?' },
];

const t = isDE ? {
  savingsTime: 'Zeit bis zur Erkenntnis', consulting: 'Beratung', months: '4-6 Monate', hours: 'Stunden',
  cost: 'Kosten', costHigh: '500k+', costLow: 'ab 30k',
  statusAll: 'Gesamte Belegschaft, Antworten in Stunden', statusTargeted: 'Gezielt: ',
  leadership: 'Geschäftsführung', middle: 'Mittelmanagement', campaign: 'Kampagne',
  orgCtx1: 'Organisations-', orgCtx2: 'kontext', explicit: 'EXPLIZITER KONTEXT',
  docs: 'Dokumente', systems: 'Systeme', toolsMeetings: 'Tools & Meetings',
  implicit: 'IMPLIZITER KONTEXT', ex1: 'Praxiswissen', ex2: 'Echte Abläufe', ex3: 'Erfahrungswissen',
  humanLayer1: 'Menschliche', humanLayer2: 'Kontext-Ebene', viaInterviews: 'durch KI-Interviews',
} : {
  savingsTime: 'Time to insight', consulting: 'Consulting', months: '4-6 months', hours: 'Hours',
  cost: 'Cost', costHigh: '500k+', costLow: 'from 30k',
  statusAll: 'Entire workforce, answers in hours', statusTargeted: 'Targeted: ',
  leadership: 'Leadership', middle: 'Middle management', campaign: 'Campaign',
  orgCtx1: 'Organisational', orgCtx2: 'context', explicit: 'EXPLICIT CONTEXT',
  docs: 'Documents', systems: 'Systems', toolsMeetings: 'Tools & meetings',
  implicit: 'IMPLICIT CONTEXT', ex1: 'Practical know-how', ex2: 'Real workflows', ex3: 'Experience',
  humanLayer1: 'Human context', humanLayer2: 'layer', viaInterviews: 'via AI interviews',
};

// Scaled SQUARE path for InplicitLoader at S=44/1080
const SQ = "M37.71 33.80 L10.24 37.71 L6.31 10.24 L33.80 6.31 Z";
---

{type === 'savings' && (
  <div class="viz hbars" aria-hidden="true">
    <div class="hbars__metric">
      <span class="hbars__label">{t.savingsTime}</span>
      <div class="hbars__row"><span class="hbars__name">{t.consulting}</span><div class="hbars__track"><i class="hbars__fill hbars__fill--gray" style="--w:100%"></i></div><span class="hbars__val">{t.months}</span></div>
      <div class="hbars__row"><span class="hbars__name acc">Inplicit</span><div class="hbars__track"><i class="hbars__fill hbars__fill--acc" data-w="8%" style="--w:8%"></i></div><span class="hbars__val acc">{t.hours}</span></div>
    </div>
    <div class="hbars__metric">
      <span class="hbars__label">{t.cost}</span>
      <div class="hbars__row"><span class="hbars__name">{t.consulting}</span><div class="hbars__track"><i class="hbars__fill hbars__fill--gray" style="--w:100%"></i></div><span class="hbars__val">{t.costHigh}</span></div>
      <div class="hbars__row"><span class="hbars__name acc">Inplicit</span><div class="hbars__track"><i class="hbars__fill hbars__fill--acc" data-w="14%" style="--w:14%"></i></div><span class="hbars__val acc">{t.costLow}</span></div>
    </div>
  </div>
)}

{type === 'departments' && (
  <div class="viz dept" data-questions={JSON.stringify(deptQuestions)} data-status-all={t.statusAll} data-status-targeted={t.statusTargeted} aria-hidden="true">
    <div class="dept__chat"><span class="dept__chat-mark"></span><span class="dept__chat-q">{deptQuestions[0]}</span></div>
    <span class="dept__status">{t.statusAll}</span>
    <div class="org">
      <span class="org__top">{t.leadership}</span>
      <div class="org__tier-dots org__gf">{Array.from({ length: 3 }).map(() => <span></span>)}</div>
      <svg class="org__lines org__lines--a" viewBox="0 0 1000 30" preserveAspectRatio="none">
        {departments.map((_, i) => <path class="org__path-top" d={`M 500 0 L 500 15 L ${125 + i * 250} 15 L ${125 + i * 250} 30`} />)}
      </svg>
      <span class="org__tier-label">{t.middle}</span>
      <div class="org__row org__row--mm">
        {departments.map(() => (
          <div class="org__mm-node"><div class="org__tier-dots">{Array.from({ length: 3 }).map(() => <span></span>)}</div></div>
        ))}
      </div>
      <svg class="org__lines org__lines--b" viewBox="0 0 1000 20" preserveAspectRatio="none">
        {departments.map((_, i) => <path class="org__path" data-i={i} d={`M ${125 + i * 250} 0 L ${125 + i * 250} 20`} />)}
      </svg>
      <div class="org__row">
        {departments.map((d) => (
          <div class="org__dept" data-dept={d.name}>
            <span class="org__name">{d.name}</span>
            <div class="org__dots">{Array.from({ length: d.n }).map(() => <span></span>)}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
)}

{type === 'context' && (
  <div class="viz ctx" aria-hidden="true">
    <svg class="ctx__svg" viewBox="-10 0 355 186" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <!-- Claude: Anthropic flower mark (cls-2 path from Claude_AI_logo.svg) -->
        <symbol id="viz-claude" viewBox="0 0 143 149">
          <g transform="translate(-75.96,-223.53)">
            <path d="m 105.01,322.07 29.14,-16.35 0.49,-1.42 -0.49,-0.79 h -1.42 l -4.87,-0.3 -16.65,-0.45 -14.44,-0.6 -13.99,-0.75 -3.52,-0.75 -3.3,-4.35 0.34,-2.17 2.96,-1.99 4.24,0.37 9.37,0.64 14.06,0.97 10.2,0.6 15.11,1.57 h 2.4 l 0.34,-0.97 -0.82,-0.6 -0.64,-0.6 -14.55,-9.86 -15.75,-10.42 -8.25,-6 -4.46,-3.04 -2.25,-2.85 -0.97,-6.22 4.05,-4.46 5.44,0.37 1.39,0.37 5.51,4.24 11.77,9.11 15.37,11.32 2.25,1.87 0.9,-0.64 0.11,-0.45 -1.01,-1.69 -8.36,-15.11 -8.92,-15.37 -3.97,-6.37 -1.05,-3.82 c -0.37,-1.57 -0.64,-2.89 -0.64,-4.5 l 4.61,-6.26 2.55,-0.82 6.15,0.82 2.59,2.25 3.82,8.74 6.19,13.76 9.6,18.71 2.81,5.55 1.5,5.14 0.56,1.57 h 0.97 v -0.9 l 0.79,-10.54 1.46,-12.94 1.42,-16.65 0.49,-4.69 2.32,-5.62 4.61,-3.04 3.6,1.72 2.96,4.24 -0.41,2.74 -1.76,11.44 -3.45,17.92 -2.25,12 h 1.31 l 1.5,-1.5 6.07,-8.06 10.2,-12.75 4.5,-5.06 5.25,-5.59 3.37,-2.66 h 6.37 l 4.69,6.97 -2.1,7.2 -6.56,8.32 -5.44,7.05 -7.8,10.5 -4.87,8.4 0.45,0.67 1.16,-0.11 17.62,-3.75 9.52,-1.72 11.36,-1.95 5.14,2.4 0.56,2.44 -2.02,4.99 -12.15,3 -14.25,2.85 -21.22,5.02 -0.26,0.19 0.3,0.37 9.56,0.9 4.09,0.22 h 10.01 l 18.64,1.39 4.87,3.22 2.92,3.94 -0.49,3 -7.5,3.82 -10.12,-2.4 -23.62,-5.62 -8.1,-2.02 h -1.12 v 0.67 l 6.75,6.6 12.37,11.17 15.49,14.4 0.79,3.56 -1.99,2.81 -2.1,-0.3 -13.61,-10.24 -5.25,-4.61 -11.89,-10.01 h -0.79 v 1.05 l 2.74,4.01 14.47,21.75 0.75,6.67 -1.05,2.17 -3.75,1.31 -4.12,-0.75 -8.47,-11.89 -8.74,-13.39 -7.05,-12 -0.86,0.49 -4.16,44.81 -1.95,2.29 -4.5,1.72 -3.75,-2.85 -1.99,-4.61 1.99,-9.11 2.4,-11.89 1.95,-9.45 1.76,-11.74 1.05,-3.9 -0.07,-0.26 -0.86,0.11 -8.85,12.15 -13.46,18.19 -10.65,11.4 -2.55,1.01 -4.42,-2.29 0.41,-4.09 2.47,-3.64 14.74,-18.75 8.89,-11.62 5.74,-6.71 -0.04,-0.97 h -0.34 l -39.15,25.42 -6.97,0.9 -3,-2.81 0.37,-4.61 1.42,-1.5 11.77,-8.1 z" fill="var(--color-text-primary)"/>
          </g>
        </symbol>
        <!-- Gemini: 4-point sparkle star (from Google_Gemini_logo.svg mask) -->
        <symbol id="viz-gemini" viewBox="210 0 52 52">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M234.123 41.2204C235.489 44.3354 236.172 47.6638 236.172 51.2055C236.172 47.6638 236.833 44.3354 238.156 41.2204C239.521 38.1054 241.356 35.3958 243.66 33.0916C245.965 30.7873 248.674 28.9738 251.789 27.651C254.904 26.2855 258.233 25.6028 261.774 25.6028C258.233 25.6028 254.904 24.9414 251.789 23.6185C248.674 22.2531 245.965 20.4182 243.66 18.114C241.356 15.8097 239.521 13.1001 238.156 9.98507C236.833 6.87007 236.172 3.54171 236.172 0C236.172 3.54171 235.489 6.87007 234.123 9.98507C232.801 13.1001 230.987 15.8097 228.683 18.114C226.379 20.4182 223.669 22.2531 220.554 23.6185C217.439 24.9414 214.111 25.6028 210.569 25.6028C214.111 25.6028 217.439 26.2855 220.554 27.651C223.669 28.9738 226.379 30.7873 228.683 33.0916C230.987 35.3958 232.801 38.1054 234.123 41.2204Z" fill="var(--color-text-primary)"/>
        </symbol>
        <!-- ChatGPT: OpenAI bloom icon (from Chatgpt-logo SVG, second path) -->
        <symbol id="viz-chatgpt" viewBox="52 394 192 244">
          <path d="M239.5442,480.8042c4.79-14.3701,3.1457-30.0985-4.5041-43.1817c-11.5104-20.018-34.6741-30.313-57.2658-25.523c-10.0805-11.2959-24.5221-17.7302-39.6786-17.6587c-23.0922,0-43.6107,14.8705-50.76,36.8188c-14.8705,3.0742-27.6678,12.3683-35.1745,25.5229c-11.5819,20.018-8.9366,45.1835,6.5773,62.3418c-4.79,14.3701-3.1457,30.0986,4.5041,43.1102c11.5104,20.0895,34.6741,30.3845,57.3373,25.5945c10.009,11.2959,24.4506,17.8018,39.6071,17.7302c23.0922,0,43.6107-14.8705,50.76-36.8188c14.8705-3.0742,27.6678-12.3682,35.103-25.5229c11.6533-20.018,9.0081-45.1835-6.5058-62.3418L239.5442,480.8042z M223.1009,444.5573c4.5755,8.0072,6.2914,17.3728,4.7185,26.4524c-0.286-0.2145-0.8579-0.5004-1.2154-0.7149l-42.0378-24.3076c-2.1448-1.2154-4.79-1.2154-6.9348,0l-49.2586,28.4542v-20.8759l40.6795-23.5211C187.9979,419.1058,212.1625,425.6116,223.1009,444.5573z M128.3728,487.9534l20.7329-12.0108l20.7329,12.0108v23.9501l-20.7329,12.0108l-20.7329-12.0108V487.9534z M138.0243,408.2389c9.2941,0,18.2307,3.2172,25.38,9.1511c-0.286,0.143-0.8579,0.5004-1.2869,0.7149l-42.0378,24.2361c-2.1448,1.2154-3.4317,3.5031-3.4317,6.0054v56.9084l-18.0877-10.438v-47.0423c0-21.8768,17.6588-39.5356,39.5356-39.6071L138.0243,408.2389z M64.1721,463.7173L64.1721,463.7173c4.647-8.0072,11.8678-14.1556,20.59-17.3728v49.9735c0,2.5023,1.2869,4.7185,3.4317,6.0054l49.1871,28.3827l-18.1592,10.5095l-40.608-23.4496C59.7396,506.8276,53.2337,482.663,64.1721,463.7173z M75.2535,555.4427L75.2535,555.4427c-4.647-7.9357-6.2914-17.3728-4.7185-26.4524c0.286,0.2145,0.8579,0.5005,1.2154,0.715l42.0378,24.3076c2.1448,1.2154,4.79,1.2154,6.9348,0l49.1871-28.4542v20.8759l-40.6795,23.4497c-18.9456,10.8669-43.1102,4.4326-54.0486-14.4416H75.2535z M160.2586,591.7612c-9.2226,0-18.2307-3.2172-25.3085-9.1511c0.286-0.143,0.9294-0.5004,1.2869-0.7149l42.0378-24.2361c2.1448-1.2154,3.5031-3.5032,3.4317-6.0054v-56.8369l18.0877,10.438v46.9709c0,21.8768-17.7302,39.6071-39.5356,39.6071V591.7612z M234.1823,536.2827c-4.647,8.0072-11.9393,14.1556-20.59,17.3013v-49.9735c0-2.5022-1.2869-4.79-3.4317-6.0054l0,0l-49.2586-28.4542l18.0877-10.438l40.6795,23.4497c18.9456,10.9384,25.38,35.103,14.4416,54.0486L234.1823,536.2827z" fill="var(--color-text-primary)"/>
        </symbol>
        <!-- Copilot: wing icon shapes (4 unique paths from microsoft-copilot-logo.svg) -->
        <symbol id="viz-copilot" viewBox="-3 -1 44 41">
          <path d="M30.252 3.129A4.357 4.357 0 0 0 26.071 0h-1.272a4.358 4.358 0 0 0-4.286 3.571l-2.179 11.871.541-1.85a4.358 4.358 0 0 1 4.182-3.135h7.392l3.1 1.208 2.988-1.208h-.872a4.357 4.357 0 0 1-4.181-3.129l-1.233-4.199z" fill="var(--color-text-primary)"/>
          <path d="M11.605 34.5a4.357 4.357 0 0 0 4.186 3.147h2.701a4.357 4.357 0 0 0 4.356-4.245l.294-11.447-.615 2.102a4.358 4.358 0 0 1-4.182 3.133h-7.453l-2.657-1.442-2.877 1.442h.858a4.358 4.358 0 0 1 4.186 3.147z" fill="var(--color-text-primary)"/>
          <path d="M25.882 0H10.786C6.473 0 3.885 5.7 2.16 11.401.116 18.154-2.559 27.186 5.179 27.186h6.518a4.357 4.357 0 0 0 4.193-3.161 1954.236 1954.236 0 0 1 4.679-16.147c.793-2.676 1.453-4.974 2.467-6.405.568-.802 1.515-1.474 2.845-1.474z" fill="var(--color-text-primary)"/>
          <path d="M15.528 37.647h15.096c4.313 0 6.901-5.701 8.626-11.403 2.044-6.755 4.719-15.788-3.019-15.788h-6.518a4.357 4.357 0 0 0-4.193 3.161 1927.986 1927.986 0 0 1-4.68 16.15c-.793 2.676-1.453 4.975-2.467 6.406-.568.802-1.515 1.474-2.845 1.474z" fill="var(--color-text-primary)"/>
        </symbol>
      </defs>

      <!-- LEFT: inplicit box (orange border) — appears last, after org context + tools -->
      <g class="ctx__g-inplicit">
        <rect x="3" y="18" width="90" height="150" rx="8" fill="var(--color-bg)" stroke="var(--color-accent-muted)" stroke-width="1.1"/>
        <!-- InplicitLoader animation — whole mark scaled to 0.78 around its centre (22,22) -->
        <g transform="translate(48,48) scale(0.78) translate(-22,-22)">
          <path d={SQ} fill="var(--color-text-primary)"/>
          <circle class="ctx__loader-w" cx="20.41" cy="20.38" r="5.23" fill="var(--color-bg)"/>
          <circle class="ctx__loader-o" cx="23.59" cy="23.90" r="5.23" fill="var(--color-accent)"/>
        </g>
        <!-- inplicit label below logo -->
        <line x1="13" y1="78" x2="83" y2="78" stroke="var(--color-accent-muted)" stroke-width="1"/>
        <text x="48" y="93" text-anchor="middle" font-size="11" font-weight="700" fill="var(--color-accent)" font-family="var(--font-family)">inplicit</text>
        <text x="48" y="108" text-anchor="middle" font-size="9" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.humanLayer1}</text>
        <text x="48" y="121" text-anchor="middle" font-size="9" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.humanLayer2}</text>
        <text x="48" y="136" text-anchor="middle" font-size="8" fill="var(--color-text-tertiary)" font-family="var(--font-family)">{t.viaInterviews}</text>
      </g>

      <!-- CENTER: Organisationskontext box -->
      <g class="ctx__g-org">
        <rect x="112" y="12" width="118" height="170" rx="8" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.2"/>
        <text x="171" y="32" text-anchor="middle" font-size="10" font-weight="600" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.orgCtx1}</text>
        <text x="171" y="46" text-anchor="middle" font-size="10" font-weight="600" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.orgCtx2}</text>
        <line x1="120" y1="53" x2="222" y2="53" stroke="var(--color-border)" stroke-width="1"/>
        <!-- Expliziter Kontext section -->
        <text x="171" y="66" text-anchor="middle" font-size="7.5" font-weight="600" fill="var(--color-text-tertiary)" font-family="var(--font-family)" letter-spacing="0.08em">{t.explicit}</text>
        <text x="171" y="80" text-anchor="middle" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-family)">{t.docs}</text>
        <text x="171" y="93" text-anchor="middle" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-family)">{t.systems}</text>
        <text x="171" y="106" text-anchor="middle" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-family)">{t.toolsMeetings}</text>
        <line x1="120" y1="113" x2="222" y2="113" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="3 3"/>
        <!-- Impliziter Kontext section (orange, contributed by inplicit) -->
        <rect x="120" y="117" width="102" height="60" rx="5" fill="var(--color-accent-light)" stroke="var(--color-accent-muted)" stroke-width="0.7"/>
        <text x="171" y="130" text-anchor="middle" font-size="7.5" font-weight="700" fill="var(--color-accent)" font-family="var(--font-family)" letter-spacing="0.08em">{t.implicit}</text>
        <text x="171" y="144" text-anchor="middle" font-size="8.5" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.ex1}</text>
        <text x="171" y="157" text-anchor="middle" font-size="8.5" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.ex2}</text>
        <text x="171" y="170" text-anchor="middle" font-size="8.5" fill="var(--color-text-secondary)" font-family="var(--font-family)">{t.ex3}</text>
      </g>

      <!-- RIGHT: MCP hands the context off to the AI tools -->
      <g class="ctx__g-mcp">
        <!-- MCP circle at center-right of Organisationskontext, fan-out origin -->
        <circle cx="236" cy="93" r="12" fill="var(--color-text-primary)"/>
        <text x="236" y="93" text-anchor="middle" dominant-baseline="middle" font-size="7" font-weight="700" fill="var(--color-bg)" font-family="var(--font-family)">MCP</text>

        <!-- Fan-out dashed lines: FROM MCP circle edge → AI tools (fast flow) -->
        <g class="ctx__out-spokes" stroke="var(--color-border)" stroke-width="0.8" stroke-dasharray="3 5">
          <line x1="248" y1="93" x2="265" y2="38"/>
          <line x1="248" y1="93" x2="265" y2="78"/>
          <line x1="248" y1="93" x2="265" y2="118"/>
          <line x1="248" y1="93" x2="265" y2="158"/>
        </g>

        <!-- AI tools: real brand logos (all black) + labels -->
        <use href="#viz-claude"  x="265" y="31" width="14" height="14"/>
        <text x="283" y="42" font-size="11" fill="var(--color-text-primary)" font-family="var(--font-family)">Claude</text>

        <use href="#viz-gemini"  x="265" y="71" width="14" height="14"/>
        <text x="283" y="82" font-size="11" fill="var(--color-text-primary)" font-family="var(--font-family)">Gemini</text>

        <use href="#viz-chatgpt" x="265" y="111" width="14" height="14"/>
        <text x="283" y="122" font-size="11" fill="var(--color-text-primary)" font-family="var(--font-family)">ChatGPT</text>

        <use href="#viz-copilot" x="265" y="151" width="14" height="14"/>
        <text x="283" y="162" font-size="11" fill="var(--color-text-primary)" font-family="var(--font-family)">Copilot</text>
      </g>

      <!-- Connector (drawn LAST so it sits on top): inplicit centre-right → orange
           "impliziter Kontext" box, via a magnifying-glass node. Inplicit surfaces
           the hidden, in-people's-heads knowledge and feeds it into the org context. -->
      <g class="ctx__connector">
        <line x1="93" y1="93" x2="111.5" y2="147" stroke="var(--color-border)" stroke-width="0.9"/>
        <circle cx="120" cy="147" r="8.5" fill="var(--color-text-primary)"/>
        <circle cx="118.9" cy="145.9" r="2.6" fill="none" stroke="var(--color-bg)" stroke-width="1.3"/>
        <line x1="120.5" y1="147.5" x2="122.3" y2="149.3" stroke="var(--color-bg)" stroke-width="1.3" stroke-linecap="round"/>
      </g>
    </svg>
  </div>
)}

{type === 'interviews' && (
  <div class="viz iviz" data-roles={JSON.stringify(roles)} aria-hidden="true">
    <div class="iviz__campaign"><span class="iviz__campaign-dot"></span>{t.campaign} · {campaignGoal}</div>
    <div class="iviz__body">
      <div class="iviz__list">
        {roles.map((r, i) => (
          <button type="button" class={`iviz__ava${i === 0 ? ' is-active' : ''}`} data-idx={i} aria-label={r.role}
            style={`background-image:url(https://images.unsplash.com/${r.photo}?w=120&h=120&fit=facearea&facepad=3.5&auto=format&q=80)`}></button>
        ))}
      </div>
      <div class="iviz__chat">
        <div class="iviz__bubble-row">
          <span class="iviz__mark" set:html={logoIconRaw}></span>
          <div class="iviz__bubble iviz__q">{roles[0].q}</div>
        </div>
        <div class="iviz__who">
          <div class="iviz__who-meta">
            <span class="iviz__who-role">{roles[0].role}</span>
            <span class="iviz__who-ctx">{roles[0].ctx}</span>
          </div>
          <span class="iviz__who-ava"
            style={`background-image:url(https://images.unsplash.com/${roles[0].photo}?w=120&h=120&fit=facearea&facepad=3.5&auto=format&q=80)`}></span>
        </div>
      </div>
    </div>
  </div>
)}

<style>
  .viz { width: 100%; }

  /* savings */
  .hbars { display: flex; flex-direction: column; gap: 18px; }
  .hbars__label { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-text-tertiary); margin-bottom: 9px; }
  .hbars__row { display: flex; align-items: center; gap: 10px; font-size: 11px; margin-bottom: 7px; }
  .hbars__name { width: 56px; flex-shrink: 0; color: var(--color-text-tertiary); }
  .hbars__name.acc { color: var(--color-accent); font-weight: 600; }
  .hbars__track { flex: 1; height: 9px; border-radius: 5px; background: var(--color-accent-light); overflow: hidden; }
  .hbars__fill { display: block; height: 100%; border-radius: 5px; }
  .hbars__fill--gray { width: var(--w); background: var(--color-text-tertiary); opacity: 0.35; }
  .hbars__fill--acc { width: 100%; background: var(--color-accent); }
  .hbars__val { width: 58px; flex-shrink: 0; text-align: right; color: var(--color-text-tertiary); font-size: 11px; }
  .hbars__val.acc { color: var(--color-accent); font-weight: 700; }

  /* departments */
  .dept { display: flex; flex-direction: column; gap: 6px; }
  .dept__chat { display: flex; align-items: center; gap: 9px; padding: 9px 11px; border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface); }
  .dept__chat-mark { width: 16px; height: 16px; border-radius: 5px; background: var(--color-accent); flex-shrink: 0; }
  .dept__chat-q { font-size: 12px; color: var(--color-text-primary); transition: opacity 0.25s ease; }
  .dept__status { font-size: 11px; color: var(--color-text-tertiary); margin-bottom: 4px; transition: opacity 0.25s ease; }
  .org { display: flex; flex-direction: column; }
  .org__top { text-align: center; font-size: 11px; font-weight: 600; color: var(--color-text-secondary); transition: color 0.3s ease; }
  .org__tier-label { text-align: center; font-size: 10px; color: var(--color-text-tertiary); transition: color 0.3s ease; }
  .org__tier-dots { display: flex; justify-content: center; gap: 3px; margin: 4px 0; }
  .org__tier-dots span { width: 8px; height: 8px; border-radius: 2px; background: var(--color-border); transition: background-color 0.4s ease; }
  .org__row--mm { margin: 2px 0; }
  .org__mm-node { flex: 1; display: flex; justify-content: center; }
  .org__lines { width: 100%; }
  .org__lines--a { height: 20px; }
  .org__lines--b { height: 13px; }
  .org__path, .org__path-top { fill: none; stroke: var(--color-border); stroke-width: 1.5px; vector-effect: non-scaling-stroke; transition: stroke 0.3s ease; }
  .org__row { display: flex; }
  .org__dept { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 7px; }
  .org__name { font-size: 11px; color: var(--color-text-secondary); transition: color 0.3s ease; }
  .org__dots { display: flex; flex-wrap: wrap; justify-content: center; gap: 3px; max-width: 64px; }
  .org__dots span { width: 8px; height: 8px; border-radius: 2px; background: var(--color-border); transition: background-color 0.4s ease; }
  .dept.is-all .org__path, .dept.is-all .org__path-top { stroke: var(--color-accent); }
  .dept.is-all .org__dots span, .dept.is-all .org__tier-dots span { background: var(--color-accent); }
  .org__path.is-active, .org__path-top.is-active { stroke: var(--color-accent); stroke-width: 2px; }
  .org__dept.is-active .org__name { color: var(--color-accent); font-weight: 600; }
  .org__dept.is-active .org__dots span { background: var(--color-accent); }
  .org__mm-node.is-active .org__tier-dots span { background: var(--color-accent); }

  /* context */
  .ctx { display: flex; justify-content: center; align-items: center; }
  .ctx__svg { width: 100%; height: auto; }

  /* fan-out dashes flow fast toward the tools (carries the "info travels" motion) */
  .ctx__out-spokes line { animation: ctxFlow 0.28s linear infinite; }
  @keyframes ctxFlow { to { stroke-dashoffset: -8; } }

  /* staged entrance (JS adds .ctx--anim, then .is-in on scroll):
     inplicit opens first → org context → connector → MCP hands off to tools */
  .ctx--anim .ctx__g-inplicit,
  .ctx--anim .ctx__g-org,
  .ctx--anim .ctx__g-mcp,
  .ctx--anim .ctx__connector { opacity: 0; }
  .ctx--anim .ctx__g-inplicit { transform-box: fill-box; transform-origin: center; transform: scale(0.86); }
  .ctx--anim.is-in .ctx__g-org       { animation: ctxIn 0.5s ease-out forwards; }
  .ctx--anim.is-in .ctx__g-mcp       { animation: ctxIn 0.5s ease-out 0.5s forwards; }
  .ctx--anim.is-in .ctx__g-inplicit  { animation: ctxOpen 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1.1s forwards; }
  .ctx--anim.is-in .ctx__connector   { animation: ctxIn 0.45s ease-out 1.6s forwards; }
  @keyframes ctxOpen { to { opacity: 1; transform: scale(1); } }
  @keyframes ctxIn { to { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    .ctx__out-spokes line { animation: none; }
  }

  /* interviews — chat design: inplicit asks, interviewee shown bottom-right */
  .iviz { display: flex; flex-direction: column; gap: var(--space-3); }
  .iviz__campaign { display: flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 600; color: var(--color-text-secondary); }
  .iviz__campaign-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; }

  .iviz__body { display: flex; gap: var(--space-3); align-items: stretch; }

  /* left: campaign participants */
  .iviz__list { display: flex; flex-direction: column; gap: 6px; flex-shrink: 0; }
  .iviz__ava {
    width: 30px; height: 30px; border-radius: 50%; padding: 0;
    background-size: cover; background-position: center;
    border: 2px solid transparent; opacity: 0.5; cursor: pointer;
    transition: opacity 0.25s, border-color 0.25s, transform 0.25s;
  }
  .iviz__ava:hover { opacity: 0.85; }
  .iviz__ava.is-active { opacity: 1; border-color: var(--color-accent); transform: scale(1.06); }

  /* right: chat window */
  .iviz__chat {
    flex: 1; min-width: 0;
    display: flex; flex-direction: column; justify-content: space-between; gap: var(--space-3);
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-card); padding: var(--space-3);
  }
  .iviz__bubble-row { display: flex; gap: 8px; align-items: flex-start; }
  .iviz__mark {
    width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0; margin-top: 1px;
    background: var(--color-accent-light); border: 1px solid var(--color-accent-muted);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .iviz__mark :global(svg) { width: 13px; height: 13px; display: block; }
  .iviz__mark :global(path) { fill: var(--color-text-primary); }
  .iviz__mark :global(rect) { fill: var(--color-accent); }
  .iviz__bubble {
    background: var(--color-text-primary); color: var(--color-bg);
    border-radius: 4px 12px 12px 12px; padding: 8px 11px;
    font-size: 11.5px; line-height: 1.5; transition: opacity 0.2s ease;
  }
  .iviz__who { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
  .iviz__who-meta { display: flex; flex-direction: column; align-items: flex-end; line-height: 1.25; transition: opacity 0.2s ease; }
  .iviz__who-role { font-size: 11px; font-weight: 600; color: var(--color-text-primary); }
  .iviz__who-ctx { font-size: 10px; color: var(--color-text-tertiary); }
  .iviz__who-ava {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    background-size: cover; background-position: center;
    border: 2px solid var(--color-accent); transition: opacity 0.2s ease;
  }
</style>

<script>
  // Savings: auto-animate on scroll-in + restart on hover
  document.querySelectorAll('.hbars').forEach((hbars) => {
    const card = hbars.closest('.g2__card'); if (!card) return;
    const fills = [...hbars.querySelectorAll<HTMLElement>('.hbars__fill--acc')];
    const reveal = () => {
      fills.forEach((f) => {
        const w = f.dataset.w || '20%';
        f.style.transition = 'none'; f.style.width = '100%';
        void f.offsetWidth;
        f.style.transition = 'width 1.1s var(--ease-smooth)'; f.style.width = w;
      });
    };
    new IntersectionObserver((es, io) => { es.forEach((e) => { if (e.isIntersecting) { setTimeout(reveal, 200); io.disconnect(); } }); }, { threshold: 0.3 }).observe(card);
    card.addEventListener('mouseenter', reveal);
  });

  // Departments: hover cycle
  document.querySelectorAll('.dept').forEach((dept) => {
    const card = dept.closest('.g2__card'); if (!card) return;
    const q = dept.querySelector<HTMLElement>('.dept__chat-q');
    const status = dept.querySelector<HTMLElement>('.dept__status');
    const depts = [...dept.querySelectorAll<HTMLElement>('.org__dept')];
    const paths = [...dept.querySelectorAll<SVGElement>('.org__path')];
    const mmNodes = [...dept.querySelectorAll<HTMLElement>('.org__mm-node')];
    const topPaths = [...dept.querySelectorAll<SVGElement>('.org__path-top')];
    let questions: string[] = [];
    try { questions = JSON.parse(dept.getAttribute('data-questions') || '[]'); } catch {}
    const statusAll = dept.getAttribute('data-status-all') || '';
    const statusTargeted = dept.getAttribute('data-status-targeted') || '';
    let step = 0; let timer: ReturnType<typeof setInterval> | null = null;
    const clearActive = () => { depts.forEach(d=>d.classList.remove('is-active')); paths.forEach(p=>p.classList.remove('is-active')); mmNodes.forEach(n=>n.classList.remove('is-active')); topPaths.forEach(p=>p.classList.remove('is-active')); };
    const reset = () => { dept.classList.remove('is-all'); clearActive(); if(q) q.textContent=questions[0]||''; if(status) status.textContent=statusAll; step=0; };
    const tick = () => {
      if(q) q.style.opacity='0'; if(status) status.style.opacity='0';
      setTimeout(()=>{
        if(step===0){ dept.classList.add('is-all'); clearActive(); if(status) status.textContent=statusAll; }
        else { dept.classList.remove('is-all'); const a=step-1; depts.forEach((d,i)=>d.classList.toggle('is-active',i===a)); paths.forEach((p,i)=>p.classList.toggle('is-active',i===a)); mmNodes.forEach((n,i)=>n.classList.toggle('is-active',i===a)); topPaths.forEach((p,i)=>p.classList.toggle('is-active',i===a)); if(status) status.textContent=statusTargeted+(depts[a]?.getAttribute('data-dept')||''); }
        if(q){q.textContent=questions[step%questions.length]||'';q.style.opacity='1';} if(status) status.style.opacity='1';
        step=(step+1)%(depts.length+1);
      },200);
    };
    card.addEventListener('mouseenter',()=>{ tick(); timer=setInterval(tick,2600); });
    card.addEventListener('mouseleave',()=>{ if(timer){clearInterval(timer);timer=null;} reset(); });
  });

  // InplicitLoader animation (vanilla JS port of React component)
  {
    const R=128.405, Mx=539.95, My=543.84, Ox=38.85, Oy=42.71, DEPTH=0.13, DUR=1400, S=44/1080;
    document.querySelectorAll('.ctx').forEach((ctx) => {
      const w = ctx.querySelector<SVGCircleElement>('.ctx__loader-w');
      const o = ctx.querySelector<SVGCircleElement>('.ctx__loader-o');
      if (!w || !o) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      let t0: number | null = null;
      const tick = (now: number) => {
        if (t0 === null) t0 = now;
        const a = (((now - t0) % DUR) / DUR) * 2 * Math.PI;
        const cos = Math.cos(a), sin = Math.sin(a);
        const set = (el: SVGCircleElement, cx: number, cy: number, r: number) => {
          el.setAttribute('cx', (cx*S).toFixed(2));
          el.setAttribute('cy', (cy*S).toFixed(2));
          el.setAttribute('r',  (r*S).toFixed(2));
        };
        set(w, Mx - Ox*cos, My - Oy*cos, R*(1 + DEPTH*sin));
        set(o, Mx + Ox*cos, My + Oy*cos, R*(1 - DEPTH*sin));
        const front = sin >= 0 ? w : o;
        if (front.parentNode?.lastChild !== front) front.parentNode?.appendChild(front);
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });
  }

  // Context viz: staged entrance on scroll-in (inplicit box opens first)
  document.querySelectorAll('.ctx').forEach((ctx) => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    ctx.classList.add('ctx--anim');
    const card = ctx.closest('.g2__card') || ctx;
    new IntersectionObserver((es, io) => {
      es.forEach((e) => { if (e.isIntersecting) { ctx.classList.add('is-in'); io.disconnect(); } });
    }, { threshold: 0.3 }).observe(card);
  });

  // Interviews: avatar click + hover auto-cycle (chat design)
  document.querySelectorAll('.iviz').forEach((iviz) => {
    const card = iviz.closest('.g2__card'); if (!card) return;
    let roles: {role:string;ctx:string;q:string;photo:string}[] = [];
    try { roles = JSON.parse(iviz.getAttribute('data-roles')||'[]'); } catch {}
    const qEl    = iviz.querySelector<HTMLElement>('.iviz__q');
    const roleEl = iviz.querySelector<HTMLElement>('.iviz__who-role');
    const ctxEl  = iviz.querySelector<HTMLElement>('.iviz__who-ctx');
    const metaEl = iviz.querySelector<HTMLElement>('.iviz__who-meta');
    const avaEl  = iviz.querySelector<HTMLElement>('.iviz__who-ava');
    const avatars = [...iviz.querySelectorAll<HTMLElement>('.iviz__ava')];
    const photoUrl = (p: string) => `url(https://images.unsplash.com/${p}?w=120&h=120&fit=facearea&facepad=3.5&auto=format&q=80)`;
    let idx = 0; let timer: ReturnType<typeof setInterval> | null = null;
    const show = (i: number) => {
      const r = roles[i]; if(!r) return; idx = i;
      if(qEl) qEl.style.opacity='0'; if(metaEl) metaEl.style.opacity='0'; if(avaEl) avaEl.style.opacity='0';
      avatars.forEach((a,j)=>a.classList.toggle('is-active',j===i));
      setTimeout(()=>{
        if(qEl){qEl.textContent=r.q;qEl.style.opacity='1';}
        if(roleEl) roleEl.textContent=r.role;
        if(ctxEl) ctxEl.textContent=r.ctx;
        if(metaEl) metaEl.style.opacity='1';
        if(avaEl){avaEl.style.backgroundImage=photoUrl(r.photo);avaEl.style.opacity='1';}
      },200);
    };
    avatars.forEach((a,i)=>a.addEventListener('click',()=>{ show(i); }));
    card.addEventListener('mouseenter',()=>{ show(0); timer=setInterval(()=>{ show((idx+1)%roles.length); },2600); });
    card.addEventListener('mouseleave',()=>{ if(timer){clearInterval(timer);timer=null;} show(0); });
  });
</script>

---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const deliverables = lang === 'de' ? [
  'Unsere KI führt Interviews mit Ihrem gesamten Team',
  'Sie erhalten die Ergebnisse mit identifizierten Signalen',
  'Lückenanalyse: Was Ihrer aktuellen Wissensstrategie fehlt',
  'Empfehlungen für die nächsten Schritte, basierend auf Ihrer spezifischen Situation',
] : [
  '30-minute AI interview session with your team',
  'Pilot results overview: your first identified signals',
  'Gap analysis: what your current knowledge strategy is missing',
  'Next-step recommendation based on your specific situation',
];
---

<section class="demo" id="request-pilot">
  <div class="container">
    <div class="demo__card section-fade">
      <div class="demo__content">
        <div class="demo__content-header">
          <p class="section-eyebrow">
            {lang === 'de' ? 'Jetzt starten' : 'Get started'}
          </p>
          <h2 class="demo__heading">
            <span class="demo__heading-line1">{lang === 'de' ? 'Starten Sie jetzt.' : 'Start with a pilot.'}</span>
            <span class="demo__heading-line2">{lang === 'de' ? 'Erste Erkenntnisse in einem Tag.' : 'Results in one day.'}</span>
          </h2>
          <p class="demo__sub">
            {lang === 'de'
              ? 'Kein aufwendiges Onboarding. Keine Setup-Gebühr. Sehen Sie selbst, was in Ihrer Organisation verborgen liegt.'
              : 'No lengthy onboarding. No setup fee. Just a focused pilot that shows what is hidden inside your organisation.'}
          </p>
        </div>

        <ul class="demo__deliverables" role="list">
          {deliverables.map((d, i) => (
            <li class="demo__deliverable" style={`--delay: ${(i + 1) * 60}ms`}>
              <span class="demo__check" aria-hidden="true">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {d}
            </li>
          ))}
        </ul>

        <a href="mailto:inplicit@outlook.com" class="demo__cta">
          <span class="demo__cta-label">
            {lang === 'de' ? 'Zur Warteliste' : 'Join Waitlist'}
          </span>
          <i class="demo__cta-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </i>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .demo {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .demo { padding: var(--space-24) 0; }
  }

  .demo__card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-12);
    overflow: hidden;
    max-width: 680px;
  }

  @media (max-width: 767px) {
    .demo__card { padding: var(--space-8) var(--space-6); }
  }

  .demo__content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .demo__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .demo__heading {
    font-size: clamp(var(--text-lg), 3vw, var(--text-xl));
    font-weight: 400;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    line-height: 1.05;
  }

  .demo__heading-line1 { color: var(--color-text-primary); }
  .demo__heading-line2 { color: var(--color-text-primary); opacity: 0.3; }

  .demo__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .demo__deliverables {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .demo__deliverable {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .demo__check {
    width: 18px;
    height: 18px;
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Primary CTA */
  .demo__cta {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 48px;
    padding: 0 var(--space-8);
    background-color: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: -0.01em;
    border-radius: var(--radius-ui);
    transition: opacity 0.2s var(--ease-smooth);
  }

  .demo__cta:hover { opacity: 0.85; }
  .demo__cta:active { transform: scale(0.97); }

  .demo__cta-label {
    margin-right: var(--space-10);
    transition: opacity 0.4s var(--ease-smooth);
    white-space: nowrap;
  }

  .demo__cta:hover .demo__cta-label { opacity: 0; }

  .demo__cta-icon {
    position: absolute;
    right: 4px;
    top: 4px;
    bottom: 4px;
    border-radius: var(--radius-ui);
    z-index: 1;
    display: grid;
    width: 25%;
    place-items: center;
    background-color: var(--color-cta-icon-bg);
    transition: width 0.4s var(--ease-spring);
  }

  .demo__cta:hover .demo__cta-icon { width: calc(100% - 8px); }

  @media (max-width: 767px) {
    .demo__cta { width: 100%; justify-content: center; }
  }
</style>

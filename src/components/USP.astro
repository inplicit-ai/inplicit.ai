---
import UspGrid2 from './UspGrid2.astro';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const facts = isDE ? [
  { icon: 'coins',  viz: 'savings',     title: 'Spart Zeit und Geld',                              body: 'Bisher haben oft Beratungsfirmen Mitarbeiterbefragungen durchgeführt – teuer und zeitaufwändig. Inplicit liefert diese Erkenntnisse in Stunden statt Monaten, zu einem Bruchteil klassischer Kosten.' },
  { icon: 'users',  viz: 'departments', title: 'Skalierbar auf die gesamte Belegschaft',           body: 'KI ermöglicht es, hunderte Mitarbeitende gleichzeitig zu interviewen – und sofort auszuwerten. So kann die gesamte Belegschaft, oder gezielt die richtigen Menschen, in Stunden befragt werden.' },
  { icon: 'mic',    viz: 'interviews',  title: 'Rollenspezifische KI-Interviews',                  body: 'Jede Frage passt sich an Rolle und Kontext an. Auch können Antworten innerhalb einer Kampagne direkt cross-validiert werden.' },
  { icon: 'cpu',    viz: 'context',     title: 'Die fehlende menschliche Ebene für eure KI-Tools', body: 'Das meiste Wissen bleibt unsichtbar – in den Köpfen eurer Mitarbeitenden. Inplicit macht dieses Erfahrungswissen durch KI-Interviews sichtbar und verbindet es direkt mit euren KI-Tools. So arbeiten sie nicht nur mit Dokumenten, sondern mit echtem Praxiswissen – für präzisere, weniger generische Antworten.' },
] : [
  { icon: 'coins',  viz: 'savings',     title: 'Saves time and money',                       body: 'Employee research has long meant expensive, slow consulting projects. Inplicit delivers the same insight in hours instead of months, at a fraction of the cost.' },
  { icon: 'users',  viz: 'departments', title: 'Scales to your entire workforce',            body: 'AI interviews hundreds of employees at once – and evaluates instantly. Survey your whole workforce, or exactly the right people, in hours.' },
  { icon: 'mic',    viz: 'interviews',  title: 'Role-specific AI interviews',                body: 'Every question adapts to role and context. Answers can also be cross-validated directly within a campaign.' },
  { icon: 'cpu',    viz: 'context',     title: 'The missing human layer for your AI tools',  body: 'Most knowledge stays invisible – in your employees\' heads. Inplicit surfaces this experiential knowledge through AI interviews and connects it directly to your AI tools. So they work not just with documents, but with real practical know-how – for more precise, less generic answers.' },
];
---

<section class="usp" id="usp">
  <div class="container">

    <div class="usp__header section-fade">
      <span class="section-eyebrow">
        {isDE ? 'Warum inplicit' : 'Why inplicit'}
      </span>
      <h2 class="usp__heading">
        <span class="usp__line1">
          {isDE ? 'Alles, was Sie brauchen,' : 'Everything you need'}
        </span>
        <span class="usp__line2">
          {isDE ? 'um Ihre Organisation wirklich zu verstehen.' : 'to understand any organisation.'}
        </span>
      </h2>
    </div>

    <UspGrid2 facts={facts} lang={lang} />

  </div>
</section>

<style>
  .usp {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .usp { padding: var(--space-24) 0; }
  }

  .usp__header {
    margin-bottom: var(--space-16);
  }

  @media (max-width: 767px) {
    .usp__header { margin-bottom: var(--space-12); }
  }

  .usp__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    max-width: 600px;
  }

  .usp__line1 { color: var(--color-text-primary); }
  .usp__line2 { color: var(--color-text-primary); opacity: 0.3; }
</style>

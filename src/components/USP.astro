---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

interface Fact {
  icon: string;
  title: string;
  body: string;
}

const facts: Fact[] = isDE ? [
  {
    icon: 'users',
    title: 'Die gesamte Belegschaft, erreichbar in Stunden',
    body: 'KI-gestützte Gespräche skalieren auf alle Mitarbeitenden, ohne Terminplanung, ohne Interviewaufwand, ohne Verzerrung durch Hierarchien.',
  },
  {
    icon: 'layers',
    title: 'Tausende Stimmen, automatisch strukturiert',
    body: 'Muster und Signalcluster entstehen über Teams und Abteilungen hinweg. Keine manuelle Auswertung, keine tagelange Wartezeit.',
  },
  {
    icon: 'compass',
    title: 'Nicht nur Probleme. Konkrete Handlungsfelder.',
    body: 'Aus den Signalen entstehen klare Handlungsfelder - keine bloße Problemliste. inplicit zeigt, wo als nächstes angesetzt werden kann.',
  },
  {
    icon: 'zap',
    title: 'Erste Erkenntnisse in 3–4 Tagen',
    body: 'Kein monatelanger Analyseprozess. Die ersten Ergebnisse liegen in 3–4 Tagen vor - mit klaren Handlungsempfehlungen.',
  },
  {
    icon: 'plug',
    title: 'Integration in Ihre bestehenden Tools',
    body: 'Ergebnisse fließen direkt in Ihre vorhandenen Tools und KI-Workflows. inplicit verbindet sich dort, wo Ihre Arbeit stattfindet.',
  },
  {
    icon: 'shield',
    title: 'Die Stimme zwischen Mensch und KI',
    body: 'Wenn KI-Agenten bei Unterscheidungen fundiert unterstützen sollen, benötigen Sie menschlichen Kontext. inplicit liefert diesen Kontext - strukturiert, geprüft und direkt von Ihren Mitarbeitenden.',
  },
] : [
  {
    icon: 'users',
    title: 'Your entire workforce, reached in hours',
    body: 'AI-led conversations scale to every employee. No scheduling, no interviewer fatigue, no hierarchy distorting what gets said.',
  },
  {
    icon: 'layers',
    title: 'Thousands of voices, automatically clustered',
    body: 'Patterns and signal clusters form across teams and departments. No manual analysis, no days of waiting for results.',
  },
  {
    icon: 'compass',
    title: 'Not just problems. Directions.',
    body: 'Concrete areas for action emerge from the signals, not just a list of complaints. The AI shows what can be done next.',
  },
  {
    icon: 'zap',
    title: 'First insights in 4 hours',
    body: 'No months-long analysis process. Your first results are ready in 4 hours, action-ready and without detours.',
  },
  {
    icon: 'plug',
    title: 'MCP connections for your workflows',
    body: 'Results flow directly into your existing tools and AI workflows. inplicit connects where your work actually happens.',
  },
  {
    icon: 'shield',
    title: 'The voice between humans and AI',
    body: 'When AI agents prepare decisions, they need human context. inplicit is the bridge: structured listening that informs AI systems with what people actually think.',
  },
];
---

<section class="usp" id="usp">
  <div class="container">

    <div class="usp__header section-fade">
      <span class="section-eyebrow">
        {isDE ? 'Warum inplicit' : 'Why inplicit'}
      </span>
      <h2 class="usp__heading">
        <span class="usp__line1">
          {isDE ? 'Alles, was Sie brauchen,' : 'Everything you need'}
        </span>
        <span class="usp__line2">
          {isDE ? 'um Ihre Organisation wirklich zu verstehen.' : 'to understand any organisation.'}
        </span>
      </h2>
    </div>

    <div class="usp__grid">
      {facts.map((fact, i) => (
        <div class="usp__fact section-fade" style={`--delay: ${i * 60}ms`}>
          <div class="usp__fact-icon" aria-hidden="true">
            {fact.icon === 'users' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            )}
            {fact.icon === 'layers' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
              </svg>
            )}
            {fact.icon === 'compass' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
              </svg>
            )}
            {fact.icon === 'zap' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            )}
            {fact.icon === 'plug' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6L6 18"/><path d="m13 6 5 5"/><path d="m6 13 5 5"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>
              </svg>
            )}
            {fact.icon === 'shield' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            )}
          </div>
          <div class="usp__fact-body">
            <h3 class="usp__fact-title">{fact.title}</h3>
            <p class="usp__fact-text">{fact.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .usp {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .usp { padding: var(--space-24) 0; }
  }

  .usp__header {
    margin-bottom: var(--space-16);
  }

  @media (max-width: 767px) {
    .usp__header { margin-bottom: var(--space-12); }
  }

  .usp__badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
  }

  .usp__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    max-width: 600px;
  }

  .usp__line1 { color: var(--color-text-primary); }
  .usp__line2 { color: var(--color-text-primary); opacity: 0.3; }

  .usp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  @media (min-width: 640px) {
    .usp__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .usp__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .usp__fact {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-6);
    transition: border-color 0.2s var(--ease-smooth);
  }
  
  .usp__fact-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-ui);
    color: var(--color-text-secondary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .usp__fact-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .usp__fact-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  .usp__fact-text {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>

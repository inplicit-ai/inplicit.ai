---
import logoRaw from '../assets/logo.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
  langToggleHref?: string;
}
const { lang = 'en', langToggleHref } = Astro.props;
const cta = lang === 'de' ? 'Demo buchen' : 'Book demo';
const toggleHref = langToggleHref ?? (lang === 'de' ? '/' : '/de/');
const toggleLabel = lang === 'de' ? 'EN' : 'DE';
---

<nav class="nav" id="nav">
  <div class="nav__inner container">
    <a href={lang === 'de' ? '/de/' : '/'} class="nav__logo" aria-label="inplicit.ai home">
      <span class="nav__logo-mark" set:html={logoRaw} />
    </a>
    <div class="nav__actions">
      <a href={toggleHref} class="nav__lang" aria-label={`Switch to ${toggleLabel}`}>
        {toggleLabel}
      </a>
      <a href="https://app.inplicit.ai/login" class="nav__login" target="_blank" rel="noopener noreferrer">
        Login
      </a>
      <a href="#book-demo" class="nav__cta">
        <span class="nav__cta-label">{cta}</span>
        <i class="nav__cta-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </i>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    transition: border-color 0.2s var(--ease-smooth);
  }

  .nav.scrolled {
    background-color: color-mix(in srgb, var(--color-bg) 92%, transparent);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    transition: opacity 0.15s var(--ease-smooth);
  }

  .nav__logo:hover { opacity: 0.7; }

  .nav__logo-mark {
    display: flex;
    align-items: center;
  }

  .nav__logo-mark :global(svg) {
    height: 26px;
    width: auto;
  }

  /* Override black fills to follow theme */
  .nav__logo-mark :global(svg path),
  .nav__logo-mark :global(svg text) {
    fill: var(--color-text-primary);
  }

  /* Keep the orange accent rect */
  .nav__logo-mark :global(svg rect) {
    fill: var(--color-accent);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }


  .nav__lang {
    display: inline-flex;
    align-items: center;
    height: 36px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.06em;
    padding: 0 var(--space-3);
    border-radius: var(--radius-ui);
    transition: color 0.15s var(--ease-smooth);
  }

  .nav__lang:hover { color: var(--color-text-primary); }

  .nav__login {
    display: inline-flex;
    align-items: center;
    height: 36px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    padding: 0 var(--space-4);
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }

  .nav__login:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  .nav__cta {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 var(--space-4);
    background-color: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: -0.01em;
    border-radius: var(--radius-ui);
    transition: opacity 0.2s var(--ease-smooth);
  }

  .nav__cta:hover { opacity: 0.85; }
  .nav__cta:active { transform: scale(0.97); }

  .nav__cta-label {
    margin-right: var(--space-8);
    transition: opacity 0.4s var(--ease-smooth);
    white-space: nowrap;
  }

  .nav__cta:hover .nav__cta-label { opacity: 0; }

  .nav__cta-icon {
    position: absolute;
    right: 3px;
    top: 3px;
    bottom: 3px;
    border-radius: var(--radius-ui);
    z-index: 1;
    display: grid;
    width: 25%;
    place-items: center;
    background-color: var(--color-cta-icon-bg);
    transition: width 0.4s var(--ease-spring);
  }

  .nav__cta:hover .nav__cta-icon { width: calc(100% - 6px); }

  @media (max-width: 639px) {
    .nav__lang {
      font-size: var(--text-xs);
      padding: var(--space-1) var(--space-2);
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
  }
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelector('.nav__cta')?.addEventListener('click', function () {
      window.posthog?.capture('nav_demo_cta_clicked');
    });
    document.querySelector('.nav__login')?.addEventListener('click', function () {
      window.posthog?.capture('nav_login_clicked');
    });
    document.querySelector('.nav__lang')?.addEventListener('click', function () {
      var currentLang = document.documentElement.lang || 'en';
      window.posthog?.capture('language_switched', { from_lang: currentLang, to_lang: currentLang === 'de' ? 'en' : 'de' });
    });
  });
</script>

---
import Logo from './Logo.astro';

export interface Props {
  lang?: 'en' | 'de';
  langToggleHref?: string;
}
const { lang = 'en', langToggleHref } = Astro.props;
const cta = lang === 'de' ? 'Demo buchen' : 'Book demo';
const toggleHref = langToggleHref ?? (lang === 'de' ? '/' : '/de/');
const toggleLabel = lang === 'de' ? 'EN' : 'DE';
---

<nav class="nav" id="nav">
  <div class="nav__pill">
    <a href={lang === 'de' ? '/de/' : '/'} class="nav__logo" aria-label="inplicit.ai home">
      <Logo />
    </a>
    <div class="nav__actions">
      <a href={toggleHref} class="nav__lang" aria-label={`Switch to ${toggleLabel}`}>
        {toggleLabel}
      </a>
      <a href="https://app.inplicit.ai/login" class="nav__login" target="_blank" rel="noopener noreferrer">
        Login
      </a>
      <a href="#book-demo" class="nav__cta">
        <span class="nav__cta-label">{cta}</span>
        <i class="nav__cta-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </i>
      </a>
    </div>

    <button class="nav__burger" id="nav-burger" type="button" aria-label={lang === 'de' ? 'Menü öffnen' : 'Open menu'} aria-expanded="false" aria-controls="nav-menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 8h16M4 16h16"/>
      </svg>
    </button>
  </div>

  <div class="nav__menu" id="nav-menu" aria-hidden="true">
    <button class="nav__menu-close" id="nav-menu-close" type="button" aria-label={lang === 'de' ? 'Menü schließen' : 'Close menu'}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18"/>
      </svg>
    </button>
    <div class="nav__menu-inner">
      <a href={toggleHref} class="nav__menu-link">{lang === 'de' ? 'English' : 'Deutsch'}</a>
      <a href="https://app.inplicit.ai/login" class="nav__menu-link" target="_blank" rel="noopener noreferrer">Login</a>
      <a href="#book-demo" class="nav__menu-cta">{cta}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: var(--space-6);
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 0 var(--space-4);
    pointer-events: none;
  }

  .nav__pill {
    /* transparent at the very top — don't intercept clicks on the hero */
    pointer-events: none;
    width: 100%;
    max-width: var(--max-width);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-5);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-full, 999px);
    box-shadow: none;
    transition: background 0.3s var(--ease-smooth), border-color 0.3s var(--ease-smooth), box-shadow 0.3s var(--ease-smooth);
  }

  /* On scroll the white pill materialises */
  .nav.scrolled .nav__pill {
    pointer-events: auto;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border-color: rgba(255, 255, 255, 0.7);
    box-shadow: 0 8px 28px -10px rgba(11, 12, 16, 0.24), 0 1px 0 rgba(255, 255, 255, 0.6) inset;
  }

  .nav__logo {
    pointer-events: auto; /* logo stays clickable even when the pill is transparent */
    display: flex;
    align-items: center;
    /* inverted (white) logo over the hero video */
    --logo-ink: #fff;
    --logo-hole: var(--color-canvas-dark, #0B0C10);
    transition: opacity 0.15s var(--ease-smooth);
  }
  .nav.scrolled .nav__logo {
    --logo-ink: var(--color-text-primary);
    --logo-hole: #fff;
  }
  .nav__logo:hover { opacity: 0.75; }

  /* Actions hidden at the top, revealed with the pill on scroll */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 0.3s var(--ease-smooth), transform 0.3s var(--ease-smooth);
  }
  .nav.scrolled .nav__actions {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .nav__lang {
    display: inline-flex;
    align-items: center;
    height: 36px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.06em;
    padding: 0 var(--space-3);
    border-radius: var(--radius-full, 999px);
    transition: color 0.15s var(--ease-smooth);
  }
  .nav__lang:hover { color: var(--color-text-primary); }

  .nav__login {
    display: inline-flex;
    align-items: center;
    height: 36px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    padding: 0 var(--space-4);
    border-radius: var(--radius-full, 999px);
    border: 1px solid var(--color-border);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }
  .nav__login:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  .nav__cta {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 var(--space-4);
    background-color: var(--color-cta-bg);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: -0.01em;
    border-radius: var(--radius-full, 999px);
    transition: opacity 0.2s var(--ease-smooth);
  }
  .nav__cta:hover { opacity: 0.85; }
  .nav__cta:active { transform: scale(0.97); }

  .nav__cta-label {
    margin-right: var(--space-8);
    transition: opacity 0.4s var(--ease-smooth);
    white-space: nowrap;
  }
  .nav__cta:hover .nav__cta-label { opacity: 0; }

  .nav__cta-icon {
    position: absolute;
    right: 3px;
    top: 3px;
    bottom: 3px;
    border-radius: var(--radius-full, 999px);
    z-index: 1;
    display: grid;
    width: 30px;
    place-items: center;
    color: #fff;
    background-color: var(--color-accent-dark);
    transition: width 0.4s var(--ease-spring);
  }
  .nav__cta:hover .nav__cta-icon { width: calc(100% - 6px); }

  /* ── Burger (mobile) — orange circle that opens the full-page menu ── */
  .nav__burger {
    display: none;
    width: 40px; height: 40px; flex-shrink: 0;
    align-items: center; justify-content: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    pointer-events: auto;
    transition: transform 0.15s var(--ease-smooth);
  }
  .nav__burger:active { transform: scale(0.94); }

  /* ── Full-page menu overlay (white) ── */
  .nav__menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: #fff;
    display: flex;
    flex-direction: column;
    padding: var(--space-5) var(--space-6) var(--space-8);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s var(--ease-smooth), visibility 0.3s var(--ease-smooth);
  }
  .nav__menu.is-open { opacity: 1; visibility: visible; pointer-events: auto; }
  .nav__menu-close {
    align-self: flex-end;
    width: 44px; height: 44px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 50%;
    color: var(--color-text-primary);
    background: var(--color-surface-elevated);
    border: none;
  }
  .nav__menu-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    padding-bottom: 12vh;
  }
  .nav__menu-link {
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }
  .nav__menu-cta {
    display: inline-flex; align-items: center; justify-content: center;
    height: 54px; padding: 0 var(--space-12);
    background: var(--color-accent); color: #fff;
    font-size: var(--text-lg); font-weight: 700;
    border-radius: var(--radius-full, 999px);
    margin-top: var(--space-2);
  }

  @media (max-width: 767px) {
    .nav__actions { display: none; }
    .nav__burger { display: inline-flex; }
    .nav__pill { padding-left: var(--space-4); }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 64);
    }, { passive: true });
  }

  // Mobile full-page menu
  const burger = document.getElementById('nav-burger');
  const menu = document.getElementById('nav-menu');
  const closeBtn = document.getElementById('nav-menu-close');
  if (burger && menu) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    };
    burger.addEventListener('click', () => setOpen(true));
    closeBtn?.addEventListener('click', () => setOpen(false));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
  }
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelector('.nav__cta')?.addEventListener('click', function () {
      window.posthog?.capture('nav_demo_cta_clicked');
    });
    document.querySelector('.nav__login')?.addEventListener('click', function () {
      window.posthog?.capture('nav_login_clicked');
    });
    document.querySelector('.nav__lang')?.addEventListener('click', function () {
      var currentLang = document.documentElement.lang || 'en';
      window.posthog?.capture('language_switched', { from_lang: currentLang, to_lang: currentLang === 'de' ? 'en' : 'de' });
    });
  });
</script>

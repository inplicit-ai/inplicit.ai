---
import DottedSurface from './ui/DottedSurface.astro';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const pills = lang === 'de'
  ? ['Prozesswissen', 'Operatives Know-how', 'Innovationspotential']
  : ['Process knowledge', 'Operational know-how', 'Innovation potential'];
---

<section class="hero" id="hero">
  <DottedSurface />

  <div class="hero__inner container">
    <div class="hero__content">

      <div class="hero__pills">
        {pills.map(p => <span class="hero__pill">{p}</span>)}
      </div>

      <h1 class="hero__headline">
        {lang === 'de' ? (
          <>
            <span class="hero__line">Euer <strong>wertvollstes Wissen</strong></span>
            <span class="hero__line">steckt in Köpfen.</span>
            <span class="hero__line hero__line--ghost">Wir machen es sichtbar und nutzbar.</span>
          </>
        ) : (
          <>
            <span class="hero__line">The answers are</span>
            <span class="hero__line"><strong>already within</strong></span>
            <span class="hero__line hero__line--ghost">your organization.</span>
          </>
        )}
      </h1>

      <p class="hero__sub">
        {lang === 'de'
          ? 'Inplicit macht das implizite Wissen eurer Mitarbeitenden sichtbar und verwandelt es in strategische Organisationsintelligenz.'
          : 'inplicit.ai gives every person in your organisation a voice. Understand what your workforce truly knows, thinks, and needs.'}
      </p>

      <div class="hero__actions">
        <a href="#request-pilot" class="hero__cta-primary">
          <span class="hero__cta-primary-label">
            {lang === 'de' ? 'Zur Warteliste' : 'Join Waitlist'}
          </span>
          <i class="hero__cta-primary-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </i>
        </a>
        <a href="#how-it-works" class="hero__cta-secondary">
          {lang === 'de' ? "So funktioniert's" : 'How it works'}
        </a>
      </div>

      <div class="hero__meta">
        <span class="hero__meta-item">{lang === 'de' ? 'DSGVO-konform' : 'GDPR compliant'}</span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item">{lang === 'de' ? 'Betriebsrat-ready' : 'Works-council ready'}</span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item">{lang === 'de' ? 'Daten in Frankfurt (EU)' : 'Data in EU'}</span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item">{lang === 'de' ? 'EU AI Act konform' : 'EU AI Act compliant'}</span>
      </div>
    </div>

    <div class="hero__visual" aria-hidden="true">
      <div class="hero__glow"></div>
      <canvas id="brain-canvas" class="hero__brain-canvas"></canvas>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-start;
    padding-top: calc(var(--space-6) + 64px);
    padding-bottom: var(--space-section);
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: calc(var(--space-4) + 56px);
      padding-bottom: var(--space-16);
      min-height: 0;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-16);
    align-items: center;
    width: 100%;
    animation: hero-in 0.7s var(--ease-out) forwards;
  }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__visual { display: none; }
  }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__content { max-width: 620px; }

  /* Pills */
  .hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.05s;
    opacity: 0;
  }

  .hero__pill {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    border-radius: var(--radius-card);
    border: 1px solid rgba(0,0,0,0.1);
    background: rgba(0,0,0,0.03);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  /* Headline */
  .hero__headline {
    font-size: clamp(1.75rem, 3.6vw, 3.0rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.1s;
    opacity: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero__line { display: block; color: var(--color-text-primary); }

  .hero__line strong {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .hero__line--ghost {
    color: var(--color-text-primary);
    opacity: 0.18;
  }

  .hero__sub {
    font-size: clamp(var(--text-base), 1.7vw, var(--text-lg));
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.18s;
    opacity: 0;
  }

  /* Actions */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.26s;
    opacity: 0;
  }

  .hero__cta-primary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 var(--space-8);
    background-color: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    border-radius: var(--radius-ui);
    transition: opacity 0.2s var(--ease-smooth);
  }

  .hero__cta-primary:hover { opacity: 0.85; }
  .hero__cta-primary:active { transform: scale(0.97); }

  .hero__cta-primary-label {
    margin-right: var(--space-10);
    transition: opacity 0.4s var(--ease-smooth);
    white-space: nowrap;
  }

  .hero__cta-primary:hover .hero__cta-primary-label { opacity: 0; }

  .hero__cta-primary-icon {
    position: absolute;
    right: 4px;
    top: 4px;
    bottom: 4px;
    border-radius: var(--radius-ui);
    z-index: 1;
    display: grid;
    width: 25%;
    place-items: center;
    background-color: var(--color-cta-icon-bg);
    transition: width 0.4s var(--ease-spring);
  }

  .hero__cta-primary:hover .hero__cta-primary-icon { width: calc(100% - 8px); }

  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 var(--space-6);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }

  .hero__cta-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  /* Meta */
  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    animation: hero-in 0.7s var(--ease-out) forwards 0.34s;
    opacity: 0;
  }

  .hero__meta-item {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-weight: 400;
  }

  .hero__meta-sep { color: var(--color-text-tertiary); opacity: 0.4; font-size: var(--text-sm); }

  /* Visual */
  .hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 420px;
  }

  .hero__glow {
    position: absolute;
    inset: -40px;
    border-radius: 50%;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(245, 166, 35, 0.14), transparent 68%);
    pointer-events: none;
  }

  .hero__brain-canvas {
    width: 400px;
    height: 400px;
    position: relative;
    z-index: 1;
    cursor: grab;
  }

  .hero__brain-canvas:active { cursor: grabbing; }

  @media (max-width: 767px) {
    .hero__sub { font-size: var(--text-base); }
    .hero__meta-sep { display: none; }
    .hero__meta { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
  }

  @media (max-width: 479px) {
    .hero__actions { flex-direction: column; align-items: stretch; }
    .hero__cta-primary, .hero__cta-secondary { width: 100%; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__inner, .hero__pills, .hero__headline,
    .hero__sub, .hero__actions, .hero__meta { animation: none; opacity: 1; }
  }
</style>

<script>
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

function initBrain() {
  const canvas = document.getElementById('brain-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;

  const W = 400, H = 400;
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);

  const scene = new THREE.Scene();
  // Wider FOV + pulled back so brain never clips
  const camera = new THREE.PerspectiveCamera(50, 1, 0.01, 100);
  camera.position.set(0, 0, 4.5);

  const controls = new OrbitControls(camera, canvas);
  controls.enableZoom = false;
  controls.enablePan = false;
  controls.autoRotate = true;
  controls.autoRotateSpeed = 0.5;
  controls.dampingFactor = 0.1;
  controls.enableDamping = true;

  const brainGroup = new THREE.Group();
  scene.add(brainGroup);

  // Edge line material — light grey, clearly visible on white bg
  const edgeMat = new THREE.LineBasicMaterial({ color: 0x888896, transparent: true, opacity: 0.7 });

  const loader = new GLTFLoader();
  loader.load('/brain/scene.gltf', (gltf) => {
    const root = gltf.scene;

    // Centre the raw model first
    const box0 = new THREE.Box3().setFromObject(root);
    const c0 = box0.getCenter(new THREE.Vector3());
    const s0 = box0.getSize(new THREE.Vector3());
    root.position.sub(c0);
    const scaleFactor = 2.2 / Math.max(s0.x, s0.y, s0.z);
    root.scale.setScalar(scaleFactor);

    // Convert every mesh to edges (angle threshold 20° keeps major sulci visible)
    root.traverse((child) => {
      if ((child as THREE.Mesh).isMesh) {
        const mesh = child as THREE.Mesh;
        const worldMat = new THREE.Matrix4();
        mesh.updateWorldMatrix(true, false);
        worldMat.copy(mesh.matrixWorld);

        // Apply world transform to geometry so edges render in correct position
        const geoCopy = mesh.geometry.clone().applyMatrix4(worldMat);
        const edges = new THREE.EdgesGeometry(geoCopy, 22);
        brainGroup.add(new THREE.LineSegments(edges, edgeMat));
      }
    });
  });

  // Amber circuit nodes
  const nodeMat = new THREE.MeshBasicMaterial({ color: 0xf5a623 });
  const nGeo = new THREE.SphereGeometry(0.045, 8, 8);
  const nodeCoords: [number, number, number][] = [
    [ 0,     0.82,  0.52],
    [ 0.70,  0.26,  0.50],
    [-0.70,  0.26,  0.50],
    [ 0.68, -0.30,  0.40],
    [-0.68, -0.30,  0.40],
    [ 0.28,  0.60,  0.70],
    [-0.28,  0.60,  0.70],
    [ 0,    -0.60,  0.55],
  ];
  const nodeGroup = new THREE.Group();
  const nodes = nodeCoords.map(([x, y, z]) => {
    const m = new THREE.Mesh(nGeo, nodeMat);
    m.position.set(x, y, z);
    nodeGroup.add(m);
    return m;
  });
  const lineMat = new THREE.LineBasicMaterial({ color: 0xf5a623, transparent: true, opacity: 0.3 });
  const edgePairs: [number, number][] = [[0,1],[0,2],[1,3],[2,4],[1,5],[2,6],[3,7],[4,7],[5,6],[0,5],[0,6]];
  edgePairs.forEach(([a, b]) => {
    nodeGroup.add(new THREE.Line(
      new THREE.BufferGeometry().setFromPoints([nodes[a].position.clone(), nodes[b].position.clone()]),
      lineMat
    ));
  });
  scene.add(nodeGroup);

  let raf: number;
  function animate() {
    raf = requestAnimationFrame(animate);
    controls.update();
    // Sync node overlay with brain rotation
    nodeGroup.rotation.copy(brainGroup.rotation);
    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('beforeunload', () => cancelAnimationFrame(raf));
}

document.addEventListener('DOMContentLoaded', initBrain);
</script>

---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';
---

<section class="hero" id="hero">
  <div class="hero__bg" aria-hidden="true">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/hero-poster.jpg"
    >
      <source src="/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__inner container">
    <div class="hero__content">

      <h1 class="hero__headline">
        {isDE ? (
          <>
            <span class="hero__line">Ihr</span>
            <span class="hero__line"><em>Organisations-Kontext</em></span>
            <span class="hero__line hero__line--ghost">sichtbar gemacht.</span>
          </>
        ) : (
          <>
            <span class="hero__line">Your organisation's</span>
            <span class="hero__line"><em>context,</em> made</span>
            <span class="hero__line hero__line--ghost">visible.</span>
          </>
        )}
      </h1>

      <p class="hero__sub">
        {isDE
          ? 'Knapp 80% des Wissens Ihrer Organisation steckt in den Köpfen Ihrer Mitarbeitenden. Wir helfen Ihnen dabei, es sichtbar und nutzbar zu machen.'
          : 'Almost 80% of your organisation\'s knowledge lives in the minds of your employees. We help you make it visible and actionable.'}
      </p>

      <div class="hero__actions">
        <a href="#book-demo" class="hero__cta-primary">
          <span class="hero__cta-primary-label">{isDE ? 'Demo buchen' : 'Book demo'}</span>
          <i class="hero__cta-primary-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </i>
        </a>
        <a href="#how-it-works" class="hero__cta-secondary">{isDE ? "So funktioniert's" : 'How it works'}</a>
      </div>

      <div class="hero__meta">
        <span class="hero__meta-item"><svg class="hero__meta-check" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6l3 3 5-5" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>{isDE ? 'DSGVO-konform' : 'GDPR compliant'}</span>
        <span class="hero__meta-item"><svg class="hero__meta-check" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6l3 3 5-5" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>{isDE ? 'Betriebsrat-ready' : 'Works-council ready'}</span>
        <span class="hero__meta-item"><svg class="hero__meta-check" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6l3 3 5-5" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>{isDE ? 'Daten in der EU' : 'Data in EU'}</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
document.querySelector('.hero__cta-primary')?.addEventListener('click', function () {
  window.posthog?.capture('hero_demo_cta_clicked');
});
document.querySelector('.hero__cta-secondary')?.addEventListener('click', function () {
  window.posthog?.capture('hero_how_it_works_clicked');
});
</script>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: 100vh;
    min-height: 100svh;
    padding: 128px 0 96px;
    overflow: hidden;
  }

  /* ── Full-bleed nature video background ── */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: #0b0c10;
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Readability scrim: dark on the left (under the copy) → clearer on the right,
     plus a soft top/bottom vignette. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(11, 12, 16, 0.86) 0%, rgba(11, 12, 16, 0.66) 38%, rgba(11, 12, 16, 0.28) 72%, rgba(11, 12, 16, 0.12) 100%),
      linear-gradient(0deg, rgba(11, 12, 16, 0.55) 0%, rgba(11, 12, 16, 0) 32%),
      linear-gradient(180deg, rgba(11, 12, 16, 0.45) 0%, rgba(11, 12, 16, 0) 22%);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    animation: hero-in 0.7s var(--ease-out) forwards;
  }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__content { max-width: 640px; }

  .hero__headline {
    font-family: var(--font-family);
    font-size: clamp(2.4rem, 5.4vw, 4rem);
    font-weight: 400;
    line-height: 1.07;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.1s;
    opacity: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .hero__line { color: #fff; }
  .hero__line em { font-style: normal; font-weight: 400; }
  .hero__line--ghost { color: rgba(255, 255, 255, 0.42); }

  .hero__sub {
    font-size: clamp(var(--text-base), 1.7vw, var(--text-lg));
    font-weight: 400;
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.18s;
    opacity: 0;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.35);
  }

  .hero__actions {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3);
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.26s; opacity: 0;
  }
  .hero__cta-primary {
    position: relative; overflow: hidden; display: inline-flex; align-items: center;
    height: 46px; padding: 0 var(--space-8);
    background-color: #fff; color: var(--color-text-primary);
    font-size: var(--text-sm); font-weight: 600; letter-spacing: -0.01em;
    border-radius: var(--radius-full, 999px); transition: color 0.3s var(--ease-smooth);
    box-shadow: 0 10px 30px -10px rgba(11, 12, 16, 0.5);
  }
  .hero__cta-primary:active { transform: scale(0.97); }
  .hero__cta-primary-label { margin-right: var(--space-10); transition: opacity 0.35s var(--ease-smooth); white-space: nowrap; }
  .hero__cta-primary:hover .hero__cta-primary-label { opacity: 0; }
  /* Orange fill slides across on hover — the whole button turns orange (no white frame) */
  .hero__cta-primary-icon {
    position: absolute; right: 4px; top: 4px; bottom: 4px;
    border-radius: var(--radius-full, 999px); z-index: 1; display: grid; width: 38px; place-items: center;
    color: #fff; background-color: var(--color-accent);
    transition: width 0.4s var(--ease-spring), top 0.4s var(--ease-spring), right 0.4s var(--ease-spring), bottom 0.4s var(--ease-spring);
  }
  .hero__cta-primary:hover .hero__cta-primary-icon { top: 0; right: 0; bottom: 0; width: 100%; }
  .hero__cta-secondary {
    display: inline-flex; align-items: center; height: 46px; padding: 0 var(--space-6);
    color: #fff; font-size: var(--text-sm); font-weight: 500;
    border-radius: var(--radius-full, 999px); border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(4px);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth), background 0.15s var(--ease-smooth);
  }
  .hero__cta-secondary:hover { border-color: rgba(255, 255, 255, 0.7); background: rgba(255, 255, 255, 0.12); }

  .hero__meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3) var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.34s; opacity: 0;
  }
  .hero__meta-item { display: inline-flex; align-items: center; gap: 6px; font-size: var(--text-sm); color: rgba(255, 255, 255, 0.72); font-weight: 400; }
  .hero__meta-check { width: 12px; height: 12px; flex-shrink: 0; }

  @media (max-width: 767px) {
    .hero { padding: 112px 0 72px; }
    .hero__line { font-size: clamp(2rem, 11vw, 2.8rem); }
    .hero__sub { font-size: var(--text-base); margin-bottom: var(--space-8); }
    .hero__actions { flex-direction: column; align-items: stretch; gap: var(--space-2); }
    .hero__cta-primary, .hero__cta-secondary { width: 100%; justify-content: center; }
    .hero__meta { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__inner, .hero__headline, .hero__sub, .hero__actions, .hero__meta { animation: none; opacity: 1; }
    .hero__video { display: none; }
    .hero__bg { background: #0b0c10 url('/hero-poster.jpg') center / cover no-repeat; }
  }
</style>

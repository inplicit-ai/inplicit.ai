---
import DottedSurface from './ui/DottedSurface.astro';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
---

<section class="hero" id="hero">
  <DottedSurface />

  <div class="hero__inner container">
    <div class="hero__content">
      <div class="hero__badge">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        {lang === 'de' ? 'KI-gestützte Workforce Intelligence' : 'AI-powered workforce intelligence'}
      </div>

      <h1 class="hero__headline">
        <span class="hero__line1">
          {lang === 'de' ? 'Euer wertvollstes' : 'The answers are'}
        </span>
        <span class="hero__line1b">
          {lang === 'de' ? 'Wissen steckt' : 'already within'}
        </span>
        <span class="hero__line2">
          {lang === 'de' ? 'in Köpfen.' : 'your organization.'}
        </span>
      </h1>

      <p class="hero__sub">
        {lang === 'de'
          ? 'Inplicit macht das implizite Wissen eurer Mitarbeitenden sichtbar und verwandelt es in strategische Organisationsintelligenz.'
          : 'inplicit.ai gives every person in your organisation a voice. Understand what your workforce truly knows, thinks, and needs.'}
      </p>

      <div class="hero__actions">
        <a href="#request-pilot" class="hero__cta-primary">
          <span class="hero__cta-primary-label">
            {lang === 'de' ? 'Zur Warteliste' : 'Join Waitlist'}
          </span>
          <i class="hero__cta-primary-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </i>
        </a>
        <a href="#how-it-works" class="hero__cta-secondary">
          {lang === 'de' ? "So funktioniert's" : 'How it works'}
        </a>
      </div>

      <div class="hero__meta">
        <span class="hero__meta-item hero__meta-item--check">
          {lang === 'de' ? 'DSGVO-konform' : 'GDPR compliant'}
        </span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item hero__meta-item--check">
          {lang === 'de' ? 'Betriebsrat-ready' : 'Works-council ready'}
        </span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item hero__meta-item--check">
          {lang === 'de' ? 'Daten in Frankfurt (EU)' : 'Data in EU'}
        </span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item hero__meta-item--check">
          {lang === 'de' ? 'EU AI Act konform' : 'EU AI Act compliant'}
        </span>
      </div>
    </div>

    <div class="hero__visual" aria-hidden="true">
      <div class="hero__glow"></div>
      <canvas id="brain-canvas" class="hero__brain-canvas"></canvas>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-start;
    padding-top: calc(var(--space-6) + 64px);
    padding-bottom: var(--space-section);
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: calc(var(--space-4) + 56px);
      padding-bottom: var(--space-16);
      min-height: 0;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-16);
    align-items: center;
    width: 100%;
    animation: hero-in 0.7s var(--ease-out) forwards;
  }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__visual { display: none; }
  }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__content {
    max-width: 620px;
  }

  /* Visual */
  .hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 340px;
  }

  .hero__glow {
    position: absolute;
    inset: -60px;
    border-radius: 50%;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(245, 166, 35, 0.2), transparent 70%);
    pointer-events: none;
  }

  .hero__brain-canvas {
    width: 300px;
    height: 300px;
    position: relative;
    z-index: 1;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.05s;
    opacity: 0;
  }

  .hero__badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-accent);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.4); }
  }

  /* Headline */
  .hero__headline {
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.1s;
    opacity: 0;
    display: flex;
    flex-direction: column;
    gap: 0.02em;
  }

  .hero__line1,
  .hero__line1b { color: var(--color-text-primary); font-weight: 900; }
  .hero__line2  { color: var(--color-text-primary); font-weight: 900; opacity: 0.25; }

  .hero__sub {
    font-size: clamp(var(--text-base), 1.8vw, var(--text-lg));
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.18s;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.26s;
    opacity: 0;
  }

  /* Primary CTA */
  .hero__cta-primary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    height: 48px;
    padding: 0 var(--space-8);
    background-color: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: -0.01em;
    border-radius: var(--radius-ui);
    transition: opacity 0.2s var(--ease-smooth);
  }

  .hero__cta-primary:hover { opacity: 0.85; }
  .hero__cta-primary:active { transform: scale(0.97); }

  .hero__cta-primary-label {
    margin-right: var(--space-10);
    transition: opacity 0.4s var(--ease-smooth);
    white-space: nowrap;
  }

  .hero__cta-primary:hover .hero__cta-primary-label { opacity: 0; }

  .hero__cta-primary-icon {
    position: absolute;
    right: 4px;
    top: 4px;
    bottom: 4px;
    border-radius: var(--radius-ui);
    z-index: 1;
    display: grid;
    width: 25%;
    place-items: center;
    background-color: var(--color-cta-icon-bg);
    transition: width 0.4s var(--ease-spring);
  }

  .hero__cta-primary:hover .hero__cta-primary-icon { width: calc(100% - 8px); }

  /* Secondary CTA */
  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    font-weight: 500;
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
    height: 48px;
  }

  .hero__cta-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  /* Meta */
  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    animation: hero-in 0.7s var(--ease-out) forwards 0.34s;
    opacity: 0;
  }

  .hero__meta-item {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-weight: 400;
  }

  .hero__meta-item--check::before {
    content: '✓ ';
    color: var(--color-accent);
    font-weight: 600;
  }

  .hero__meta-sep {
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
    opacity: 0.5;
  }

  @media (max-width: 767px) {
    .hero__sub { font-size: var(--text-base); }
    .hero__meta-sep { display: none; }
    .hero__meta { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
  }

  @media (max-width: 479px) {
    .hero__actions { flex-direction: column; align-items: stretch; }
    .hero__cta-primary, .hero__cta-secondary { width: 100%; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__inner, .hero__badge, .hero__headline,
    .hero__sub, .hero__actions, .hero__meta {
      animation: none;
      opacity: 1;
    }
    .hero__badge-dot { animation: none; }
  }
</style>

<script>
import * as THREE from 'three';

function displace(geo: THREE.BufferGeometry, amp: number) {
  const pos = geo.attributes.position as THREE.BufferAttribute;
  for (let i = 0; i < pos.count; i++) {
    const x = pos.getX(i), y = pos.getY(i), z = pos.getZ(i);
    const r = Math.sqrt(x * x + y * y + z * z);
    const noise = amp * (
      0.45 * Math.sin(x * 5.3 + y * 3.7) +
      0.30 * Math.cos(y * 8.1 + z * 5.9) +
      0.20 * Math.sin(z * 11.0 + x * 7.3) +
      0.10 * Math.cos(x * 14.0 + y * 11.0)
    );
    if (r > 0) pos.setXYZ(i, x + (x / r) * noise, y + (y / r) * noise, z + (z / r) * noise);
  }
  geo.computeVertexNormals();
}

function initBrain() {
  const canvas = document.getElementById('brain-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;

  const W = 300, H = 300;
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 50);
  camera.position.set(0, 0.15, 5.4);

  scene.add(new THREE.AmbientLight(0xffffff, 0.55));

  const key = new THREE.DirectionalLight(0xffffff, 1.5);
  key.position.set(3, 5, 4);
  scene.add(key);

  const amber = new THREE.PointLight(0xf5a623, 1.3, 20);
  amber.position.set(-3, 1, 5);
  scene.add(amber);

  const rim = new THREE.DirectionalLight(0xd0d0ff, 0.22);
  rim.position.set(-4, -3, -3);
  scene.add(rim);

  const brain = new THREE.Group();
  scene.add(brain);

  const mat = new THREE.MeshStandardMaterial({ color: 0x8a8a9a, roughness: 0.88, metalness: 0.04 });

  // Left hemisphere
  const lGeo = new THREE.SphereGeometry(1, 64, 48);
  displace(lGeo, 0.13);
  const lMesh = new THREE.Mesh(lGeo, mat);
  lMesh.scale.set(0.92, 0.88, 0.96);
  lMesh.position.set(-0.48, 0, 0);
  brain.add(lMesh);

  // Right hemisphere
  const rGeo = new THREE.SphereGeometry(1, 64, 48);
  displace(rGeo, 0.13);
  const rMesh = new THREE.Mesh(rGeo, mat);
  rMesh.scale.set(0.92, 0.88, 0.96);
  rMesh.position.set(0.48, 0, 0);
  brain.add(rMesh);

  // Brainstem
  const stemMesh = new THREE.Mesh(
    new THREE.CylinderGeometry(0.16, 0.1, 0.75, 12),
    new THREE.MeshStandardMaterial({ color: 0x7a7a88, roughness: 0.9 })
  );
  stemMesh.position.set(0, -1.05, 0);
  brain.add(stemMesh);

  // Amber circuit nodes
  const nodeMat = new THREE.MeshBasicMaterial({ color: 0xf5a623 });
  const nGeo = new THREE.SphereGeometry(0.05, 8, 8);
  const nodeCoords: [number, number, number][] = [
    [ 0,     0.92,  0.62],
    [ 0.85,  0.32,  0.62],
    [-0.85,  0.32,  0.62],
    [ 0.82, -0.38,  0.52],
    [-0.82, -0.38,  0.52],
    [ 0.38,  0.72,  0.88],
    [-0.38,  0.72,  0.88],
    [ 0,    -0.72,  0.68],
  ];

  const nodes = nodeCoords.map(([x, y, z]) => {
    const m = new THREE.Mesh(nGeo, nodeMat);
    m.position.set(x, y, z);
    brain.add(m);
    return m;
  });

  // Connection lines
  const lineMat = new THREE.LineBasicMaterial({ color: 0xf5a623, transparent: true, opacity: 0.38 });
  const edges: [number, number][] = [
    [0,1],[0,2],[1,3],[2,4],[1,5],[2,6],[3,7],[4,7],[5,6],[0,5],[0,6],[3,4]
  ];
  edges.forEach(([a, b]) => {
    const pts = [nodes[a].position.clone(), nodes[b].position.clone()];
    brain.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), lineMat));
  });

  let raf: number;
  function animate() {
    raf = requestAnimationFrame(animate);
    brain.rotation.y += 0.004;
    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('beforeunload', () => cancelAnimationFrame(raf));
}

document.addEventListener('DOMContentLoaded', initBrain);
</script>

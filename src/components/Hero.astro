---
import GradientField from './ui/GradientField.astro';
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const themes = isDE
  ? ['Prozesswissen', 'Operatives Know-how', 'Innovationspotenzial']
  : ['Process knowledge', 'Operational know-how', 'Innovation potential'];

const questions = isDE
  ? [
      'Wo verlieren wir im Betrieb Zeit?',
      'Welches Erfahrungswissen ist nirgends dokumentiert?',
      'Wo sehen Mitarbeitende ungenutzte Chancen?',
      'Was sind die häufigsten Schmerzpunkte?',
    ]
  : [
      'Where do we lose time in operations?',
      'What hands-on knowledge is documented nowhere?',
      'Where do people see untapped opportunities?',
      'What are the most-named pain points?',
    ];

const sendIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>';
---

<section class="hero" id="hero">
  <GradientField />
  <div class="hero__inner container">
    <div class="hero__content">

      <h1 class="hero__headline">
        {isDE ? (
          <>
            <span class="hero__line">Euer <em>wertvollstes Wissen</em></span>
            <span class="hero__line">steckt in Köpfen.</span>
            <span class="hero__line hero__line--ghost">Wir machen es sichtbar.</span>
          </>
        ) : (
          <>
            <span class="hero__line">The answers are</span>
            <span class="hero__line"><em>already within</em></span>
            <span class="hero__line hero__line--ghost">your organization.</span>
          </>
        )}
      </h1>

      <p class="hero__sub">
        {isDE
          ? 'Inplicit macht das implizite Wissen eurer Mitarbeitenden sichtbar und verwandelt es in strategische Organisationsintelligenz.'
          : 'inplicit.ai gives every person in your organisation a voice. Understand what your workforce truly knows, thinks, and needs.'}
      </p>

      <div class="hero__actions">
        <a href="#book-demo" class="hero__cta-primary">
          <span class="hero__cta-primary-label">{isDE ? 'Demo buchen' : 'Book demo'}</span>
          <i class="hero__cta-primary-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </i>
        </a>
        <a href="#how-it-works" class="hero__cta-secondary">{isDE ? "So funktioniert's" : 'How it works'}</a>
      </div>

      <div class="hero__meta">
        <span class="hero__meta-item"><svg class="hero__meta-check" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6l3 3 5-5" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>{isDE ? 'DSGVO-konform' : 'GDPR compliant'}</span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item"><svg class="hero__meta-check" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6l3 3 5-5" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>{isDE ? 'Betriebsrat-ready' : 'Works-council ready'}</span>
        <span class="hero__meta-sep" aria-hidden="true">·</span>
        <span class="hero__meta-item"><svg class="hero__meta-check" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6l3 3 5-5" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>{isDE ? 'Daten in der EU' : 'Data in EU'}</span>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__window" aria-hidden="true">
        <div class="scene">
          <div class="scene__head">
            <span class="scene__avatar" set:html={logoIconRaw} />
            <div>
              <div class="scene__head-title">Inplicit</div>
              <div class="scene__head-sub">{isDE ? 'Frag deine Belegschaft' : 'Ask your workforce'}</div>
            </div>
            <span class="scene__dot scene__dot--live" style="margin-left:auto"></span>
          </div>
          <div class="hero__chat">
            <div class="hero__empty">
              <span class="hero__empty-mark" set:html={logoIconRaw} />
              <p class="hero__empty-hint">{isDE ? 'Frag alles. Jede Antwort zitiert eine anonyme Quelle.' : 'Ask anything. Every answer cites an anonymous source.'}</p>
            </div>
            <div class="composer">
              <div class="composer__chips">
                {themes.map(t => <span class="composer__chip">{t}</span>)}
              </div>
              <div class="composer__input">
                <span class="composer__placeholder"><span id="hero-rotator" data-questions={JSON.stringify(questions)}></span><span class="hero__caret"></span></span>
                <span class="composer__send" set:html={sendIcon} />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script is:inline>
(function () {
  var el = document.getElementById('hero-rotator');
  if (!el) return;
  var qs;
  try { qs = JSON.parse(el.getAttribute('data-questions') || '[]'); } catch (e) { qs = []; }
  if (!qs.length) return;
  el.textContent = qs[0];
  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced || qs.length < 2) return;

  var qi = 0, ci = qs[0].length, deleting = false, paused = false, timer = null;
  function schedule(ms) { timer = setTimeout(tick, ms); }
  function tick() {
    if (paused) return;
    var q = qs[qi];
    if (!deleting) {
      ci++;
      el.textContent = q.slice(0, ci);
      if (ci >= q.length) { deleting = true; schedule(1700); return; }
      schedule(46 + Math.random() * 42);
    } else {
      ci--;
      el.textContent = q.slice(0, ci);
      if (ci <= 0) { deleting = false; qi = (qi + 1) % qs.length; schedule(380); return; }
      schedule(26);
    }
  }
  document.addEventListener('visibilitychange', function () {
    paused = document.hidden;
    if (!paused && !timer) schedule(200);
    if (paused && timer) { clearTimeout(timer); timer = null; }
  });
  schedule(1600); // let it read the first question, then start typing
})();
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    padding-top: calc(var(--space-6) + 64px);
    padding-bottom: var(--space-16);
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr minmax(300px, 380px);
    gap: var(--space-16);
    align-items: center;
    width: 100%;
    animation: hero-in 0.7s var(--ease-out) forwards;
  }

  @keyframes hero-in {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__content { max-width: 600px; }

  /* ── Headline: Inter, one size, only the accent in serif italic ── */
  .hero__headline {
    font-family: var(--font-family);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
    animation: hero-in 0.7s var(--ease-out) forwards 0.1s;
    opacity: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero__line { color: var(--color-text-primary); }
  .hero__line em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.005em;
  }
  .hero__line--ghost { opacity: 0.34; }

  .hero__sub {
    font-size: clamp(var(--text-base), 1.7vw, var(--text-lg));
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 500px;
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.18s;
    opacity: 0;
  }

  /* Actions */
  .hero__actions {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3);
    margin-bottom: var(--space-10);
    animation: hero-in 0.7s var(--ease-out) forwards 0.26s; opacity: 0;
  }
  .hero__cta-primary {
    position: relative; overflow: hidden; display: inline-flex; align-items: center;
    height: 46px; padding: 0 var(--space-8);
    background-color: var(--color-cta-bg); color: var(--color-cta-text);
    font-size: var(--text-sm); font-weight: 600; letter-spacing: -0.01em;
    border-radius: var(--radius-ui); transition: opacity 0.2s var(--ease-smooth);
  }
  .hero__cta-primary:hover { opacity: 0.85; }
  .hero__cta-primary:active { transform: scale(0.97); }
  .hero__cta-primary-label { margin-right: var(--space-10); transition: opacity 0.4s var(--ease-smooth); white-space: nowrap; }
  .hero__cta-primary:hover .hero__cta-primary-label { opacity: 0; }
  .hero__cta-primary-icon {
    position: absolute; right: 4px; top: 4px; bottom: 4px;
    border-radius: var(--radius-ui); z-index: 1; display: grid; width: 25%; place-items: center;
    background-color: var(--color-cta-icon-bg); transition: width 0.4s var(--ease-spring);
  }
  .hero__cta-primary:hover .hero__cta-primary-icon { width: calc(100% - 8px); }
  .hero__cta-secondary {
    display: inline-flex; align-items: center; height: 46px; padding: 0 var(--space-6);
    color: var(--color-text-secondary); font-size: var(--text-sm); font-weight: 500;
    border-radius: var(--radius-ui); border: 1px solid var(--color-border);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }
  .hero__cta-secondary:hover { color: var(--color-text-primary); border-color: var(--color-text-tertiary); }

  /* Meta */
  .hero__meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3);
    animation: hero-in 0.7s var(--ease-out) forwards 0.34s; opacity: 0;
  }
  .hero__meta-item { display: inline-flex; align-items: center; gap: 5px; font-size: var(--text-sm); color: var(--color-text-tertiary); font-weight: 400; }
  .hero__meta-check { width: 12px; height: 12px; flex-shrink: 0; }
  .hero__meta-sep { color: var(--color-text-tertiary); opacity: 0.4; font-size: var(--text-sm); }

  /* ── Visual: portrait (3:4) app window — Inter only, mirrors the dashboard ── */
  .hero__visual { position: relative; display: flex; align-items: center; justify-content: center; }
  .hero__window {
    width: 100%;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-xl);
    animation: hero-in 0.8s var(--ease-out) forwards 0.32s, hero-float 7s ease-in-out 1.1s infinite;
    opacity: 0;
  }
  @keyframes hero-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }

  .scene {
    aspect-ratio: 3 / 4;
    display: flex; flex-direction: column; overflow: hidden;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-card); font-family: var(--font-family);
  }
  .scene__head {
    flex-shrink: 0; display: flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); background: var(--color-surface-elevated);
  }
  .scene__head-title { font-size: 12px; font-weight: 600; color: var(--color-text-primary); }
  .scene__head-sub { font-size: 10px; color: var(--color-text-tertiary); }
  .scene__avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--color-accent-light); border: 1px solid var(--color-accent-muted);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .scene__avatar :global(svg) { width: 17px; height: 17px; display: block; }
  .scene__avatar :global(path) { fill: var(--color-text-primary); }
  .scene__avatar :global(rect) { fill: var(--color-accent); }
  .scene__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-text-tertiary); flex-shrink: 0; }
  .scene__dot--live { background: var(--color-accent); animation: hero-pulse 1.8s ease-in-out infinite; }
  @keyframes hero-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .hero__chat { flex: 1; min-height: 0; display: flex; flex-direction: column; }
  .hero__empty { flex: 1; min-height: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-3); text-align: center; padding: var(--space-5); }
  .hero__empty-mark { width: 34px; height: 34px; opacity: 0.45; display: block; }
  .hero__empty-mark :global(svg) { width: 34px; height: 34px; display: block; }
  .hero__empty-mark :global(path) { fill: var(--color-text-primary); }
  .hero__empty-mark :global(rect) { fill: var(--color-accent); }
  .hero__empty-hint { font-size: 12px; line-height: 1.5; color: var(--color-text-tertiary); max-width: 24ch; }

  .composer { flex-shrink: 0; padding: var(--space-3) var(--space-4) var(--space-4); border-top: 1px solid var(--color-border); background: var(--color-bg); }
  .composer__chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: var(--space-3); }
  .composer__chip { font-size: 10px; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-full); padding: 3px 9px; background: var(--color-surface); white-space: nowrap; }
  .composer__input {
    display: flex; align-items: center; gap: var(--space-2);
    border: 1px solid var(--color-border); border-radius: var(--radius-ui); background: var(--color-surface); padding: 9px 9px 9px 12px;
  }
  .composer__placeholder { flex: 1; min-width: 0; display: inline-flex; align-items: center; font-size: 12.5px; color: var(--color-text-secondary); }
  #hero-rotator { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .hero__caret { display: inline-block; width: 1.5px; height: 1.05em; background: var(--color-accent); margin-left: 2px; flex-shrink: 0; animation: caret-blink 1s step-end infinite; }
  @keyframes caret-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  .composer__send { width: 28px; height: 28px; border-radius: 7px; flex-shrink: 0; background: var(--color-cta-bg); color: var(--color-cta-text); display: flex; align-items: center; justify-content: center; }
  .composer__send :global(svg) { width: 14px; height: 14px; display: block; }

  /* ── Tablet / mobile ── */
  @media (max-width: 900px) {
    .hero { padding-top: calc(var(--space-10) + 56px); padding-bottom: var(--space-16); }
    .hero__inner { display: flex; flex-direction: column; align-items: stretch; gap: var(--space-10); }
    .hero__content { max-width: 100%; }
    .hero__visual { justify-content: center; }
    .hero__window { width: 100%; max-width: 340px; }
  }

  @media (max-width: 767px) {
    .hero__line { font-size: clamp(2rem, 11vw, 2.8rem); }
    .hero__sub { font-size: var(--text-base); margin-bottom: var(--space-8); }
    .hero__actions { flex-direction: column; align-items: stretch; gap: var(--space-2); }
    .hero__cta-primary, .hero__cta-secondary { width: 100%; justify-content: center; }
    .hero__meta-sep { display: none; }
    .hero__meta { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
    .hero__window { max-width: 300px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__inner, .hero__headline, .hero__sub, .hero__actions, .hero__meta, .hero__window { animation: none; opacity: 1; }
    .scene__dot--live, .hero__caret { animation: none; }
  }
</style>

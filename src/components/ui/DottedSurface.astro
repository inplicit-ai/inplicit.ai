---
// Animated Three.js particle wave - hero background
---

<div id="dotted-bg" aria-hidden="true"></div>

<style is:global>
  #dotted-bg {
    pointer-events: none;
    z-index: 0;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  #dotted-bg canvas {
    display: block;
  }
</style>

<script>
  import * as THREE from 'three';

  function init() {
    const container = document.getElementById('dotted-bg');
    if (!container) return;

    const SEPARATION = 150;
    const AMOUNTX = 32;
    const AMOUNTY = 48;
    const W = container.clientWidth || window.innerWidth;
    const H = container.clientHeight || window.innerHeight;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, W / H, 1, 10000);
    camera.position.set(0, 355, 1220);

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(W, H);
    renderer.setClearColor(0x000000, 0);
    container.appendChild(renderer.domElement);

    const count = AMOUNTX * AMOUNTY;
    const posArray = new Float32Array(count * 3);

    for (let ix = 0; ix < AMOUNTX; ix++) {
      for (let iy = 0; iy < AMOUNTY; iy++) {
        const i = ix * AMOUNTY + iy;
        posArray[i * 3]     = ix * SEPARATION - (AMOUNTX * SEPARATION) / 2;
        posArray[i * 3 + 1] = 0;
        posArray[i * 3 + 2] = iy * SEPARATION - (AMOUNTY * SEPARATION) / 2;
      }
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));

    const getTheme = () => document.documentElement.getAttribute('data-theme') ?? 'dark';

    const material = new THREE.PointsMaterial({
      size: 5,
      color: 0xf5a623,
      transparent: true,
      opacity: getTheme() === 'dark' ? 0.9 : 0.70,
      sizeAttenuation: true,
    });

    scene.add(new THREE.Points(geometry, material));

    new MutationObserver(() => {
      material.opacity = getTheme() === 'dark' ? 0.9 : 0.70;
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    let frame = 0;

    function animate() {
      requestAnimationFrame(animate);
      for (let ix = 0; ix < AMOUNTX; ix++) {
        for (let iy = 0; iy < AMOUNTY; iy++) {
          const i = ix * AMOUNTY + iy;
          posArray[i * 3 + 1] =
            Math.sin((ix + frame) * 0.3) * 50 +
            Math.sin((iy + frame) * 0.5) * 50;
        }
      }
      geometry.attributes.position.needsUpdate = true;
      renderer.render(scene, camera);
      frame += 0.08;
    }

    animate();

    window.addEventListener('resize', () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    }, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

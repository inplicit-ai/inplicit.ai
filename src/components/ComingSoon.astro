---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import GradientField from './ui/GradientField.astro';

export interface Props {
  lang?: 'en' | 'de';
  eyebrow: string;
  title: string;
  accent: string;
  body: string;
}
const { lang = 'en', eyebrow, title, accent, body } = Astro.props;
const isDE = lang === 'de';
---

<Layout lang={lang} title={`${title} ${accent} — Inplicit`}>
  <Nav lang={lang} />
  <main class="cs">
    <GradientField />
    <div class="cs__inner container">
      <p class="section-eyebrow">{eyebrow}</p>
      <h1 class="cs__title">{title} <em>{accent}</em></h1>
      <p class="cs__body">{body}</p>
      <p class="cs__soon"><span class="cs__dot"></span>{isDE ? 'Diese Seite kommt bald.' : 'This page is coming soon.'}</p>
      <a class="cs__back" href={isDE ? '/de/' : '/'}>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11.5 7h-9M6.5 3l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {isDE ? 'Zur Startseite' : 'Back to home'}
      </a>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .cs {
    position: relative;
    overflow: hidden;
    min-height: 72vh;
    display: flex;
    align-items: center;
    padding: calc(var(--space-24) + 56px) 0 var(--space-24);
  }
  .cs__inner { position: relative; z-index: 1; max-width: 640px; }

  .cs__title {
    font-family: var(--font-family);
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }
  .cs__title em { font-family: var(--font-display); font-style: italic; font-weight: 400; }

  .cs__body {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: var(--space-8);
  }

  .cs__soon {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-size: var(--text-sm); font-weight: 600; color: var(--color-accent);
    margin-bottom: var(--space-8);
  }
  .cs__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-accent); animation: cs-pulse 1.8s ease-in-out infinite; }
  @keyframes cs-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .cs__back {
    display: inline-flex; align-items: center; gap: var(--space-2);
    height: 44px; padding: 0 var(--space-6);
    border: 1px solid var(--color-border); border-radius: var(--radius-ui);
    color: var(--color-text-secondary); font-size: var(--text-sm); font-weight: 500;
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }
  .cs__back:hover { color: var(--color-text-primary); border-color: var(--color-text-tertiary); }

  @media (prefers-reduced-motion: reduce) { .cs__dot { animation: none; } }
</style>

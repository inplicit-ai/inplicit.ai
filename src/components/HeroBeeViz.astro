---
// No props — self-contained illustration + animation
---

<div class="bviz" aria-hidden="true">

  <!-- Dashed trail SVG — same coordinate space as the offset-path -->
  <svg class="bviz__trail-svg" viewBox="0 0 420 480" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path id="bviz-trail"
          d="M 40,440 C -20,220 120,20 300,80"
          fill="none"
          stroke="var(--color-accent)"
          stroke-width="2.5"
          stroke-dasharray="8 7"
          stroke-linecap="round"
          opacity="0.55"/>
  </svg>

  <div class="bviz__flowers" id="bviz-flowers">
    <img src="/bee/flowers.svg" alt="" width="600" height="600" loading="eager" decoding="async" class="bviz__flowers-img"/>
  </div>

  <div class="bviz__bee" id="bviz-bee">
    <img src="/bee/bee.svg" alt="" width="110" height="110" loading="eager" decoding="async" class="bviz__bee-img"/>
  </div>
</div>

<script is:inline>
(function () {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var bee     = document.getElementById('bviz-bee');
  var flowers = document.getElementById('bviz-flowers');
  var trail   = document.getElementById('bviz-trail');
  if (!bee) return;

  if (reduced) {
    bee.style.opacity = '1';
    bee.style.offsetDistance = '100%';
    if (flowers) flowers.classList.add('bviz__flowers--sway');
    if (trail) trail.style.strokeDashoffset = '0';
    return;
  }

  // Hide trail until animation starts
  if (trail) {
    var len = Math.ceil(trail.getTotalLength());
    trail.style.strokeDasharray = len + ' ' + len;
    trail.style.strokeDashoffset = len;
  }

  var started = false;
  var io = new IntersectionObserver(function (entries) {
    if (started || !entries[0].isIntersecting) return;
    started = true;
    io.disconnect();

    if (flowers) flowers.classList.add('bviz__flowers--sway');

    bee.style.opacity = '1';
    bee.classList.add('bviz__bee--fly');

    // Trail draws slightly behind the bee
    if (trail) {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          trail.style.transition = 'stroke-dashoffset 3.2s cubic-bezier(.4,0,.6,1) 0.15s';
          trail.style.strokeDashoffset = '0';
        });
      });
    }

    setTimeout(function () {
      if (flowers) flowers.classList.add('bviz__flowers--land');
      bee.classList.add('bviz__bee--idle');
    }, 3600);

  }, { threshold: 0.15 });

  var root = document.querySelector('.bviz');
  if (root) io.observe(root);
})();
</script>

<style>
  .bviz {
    position: relative;
    width: 100%;
    min-height: 480px;
    overflow: visible;
  }

  /* ── Dashed trail SVG overlay ── */
  .bviz__trail-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  /* ── Flowers: large, stems rooted at section bottom edge ── */
  .bviz__flowers {
    position: absolute;
    bottom: 0;
    right: -80px;
    width: 600px;
    transform-origin: 50% 100%;
  }
  .bviz__flowers-img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply;
  }
  .bviz__flowers--sway {
    animation: bviz-sway 4.5s ease-in-out infinite;
  }
  .bviz__flowers--land {
    animation: bviz-wobble 0.9s cubic-bezier(.3,0,.7,1) forwards,
               bviz-sway 4.5s ease-in-out 0.9s infinite;
  }
  @keyframes bviz-sway {
    0%, 100% { transform: rotate(0deg); }
    50%      { transform: rotate(2deg); }
  }
  @keyframes bviz-wobble {
    0%   { transform: rotate(0deg); }
    18%  { transform: rotate(-10deg); }
    40%  { transform: rotate(6deg); }
    62%  { transform: rotate(-4deg); }
    80%  { transform: rotate(2deg); }
    100% { transform: rotate(0deg); }
  }

  /* ── Bee motion ── */
  .bviz__bee {
    position: absolute;
    top: 0; left: 0;
    width: 110px; height: 110px;
    opacity: 0;
    offset-anchor: 50% 50%;
    offset-path: path("M 40,440 C -20,220 120,20 300,80");
    offset-distance: 0%;
    offset-rotate: 0deg;
    z-index: 2;
  }
  .bviz__bee--fly {
    transition: opacity 0.3s ease;
    animation: bviz-bee-fly 3.4s cubic-bezier(.4,0,.2,1) forwards,
               bviz-bee-bob 0.45s ease-in-out infinite;
  }
  .bviz__bee--idle {
    animation: bviz-bee-hover 1.6s ease-in-out infinite;
    offset-distance: 100%;
  }
  @keyframes bviz-bee-fly {
    to { offset-distance: 100%; }
  }
  @keyframes bviz-bee-bob {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50%      { transform: translateY(-7px) rotate(5deg); }
  }
  @keyframes bviz-bee-hover {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-5px); }
  }

  /* ── Wing flap: strong squish mimicking real flap ── */
  .bviz__bee-img {
    width: 100%; height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
    animation: bviz-flap 0.09s ease-in-out infinite alternate;
    transform-origin: 50% 65%;
  }
  .bviz__bee--idle .bviz__bee-img {
    animation-duration: 0.42s;
  }
  @keyframes bviz-flap {
    0%   { transform: scaleX(1)    scaleY(1); }
    100% { transform: scaleX(1.08) scaleY(0.72); }
  }

  @media (prefers-reduced-motion: reduce) {
    .bviz__flowers, .bviz__bee-img { animation: none; }
    #bviz-trail { stroke-dashoffset: 0 !important; }
  }
</style>

---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

interface Principle { icon: string; title: string; body: string; }

const heroBadges = isDE ? [
  { label: 'DSGVO & AV-Vertrag',   sub: 'Art. 28 DSGVO, pro Unternehmen unterzeichnet' },
  { label: 'EU AI Act konform',     sub: 'Transparenz- und Kontrollpflichten erfüllt'   },
  { label: 'Betriebsrat-ready',     sub: 'Anforderungen vollständig erfüllt'            },
  { label: 'Zero Data Retention',   sub: 'Keine Mitarbeiterdaten im KI-Training'        },
] : [
  { label: 'GDPR & DPA',           sub: 'Art. 28 GDPR, signed per organisation'        },
  { label: 'EU AI Act compliant',   sub: 'Transparency and control obligations met'     },
  { label: 'Works-council ready',   sub: 'All requirements fully met'                  },
  { label: 'Zero Data Retention',   sub: 'No employee data in AI training'             },
];

const privacyPrinciples: Principle[] = isDE ? [
  { icon: 'shield',  title: 'AV-Vertrag nach Art. 28 DSGVO',   body: 'Schriftlich fixiert, pro Unternehmen unterzeichnet - vor dem ersten Interview.' },
  { icon: 'user',    title: 'Pseudonymisierung auf Wunsch',     body: 'Transkripte werden vor der Auswertung pseudonymisiert. Das Unternehmen definiert den Grad der Anonymisierung.' },
  { icon: 'bell',    title: '48-Stunden-Meldefrist',            body: 'Sicherheitsvorfälle werden innerhalb von 48 Stunden nach erster Kenntnis gemeldet.' },
  { icon: 'trash',   title: 'Datenlöschung auf Anfrage',        body: 'Alle Daten werden nach Vertragsende gelöscht oder zurückgegeben - auf Wunsch sofort.' },
  { icon: 'lock',    title: 'Privacy by Design',                body: 'Datenschutz ist von Anfang an eingebaut - nicht nachträglich angeheftet.' },
] : [
  { icon: 'shield',  title: 'DPA under Art. 28 GDPR',           body: 'Signed in writing, per organisation - before the first interview.' },
  { icon: 'user',    title: 'Pseudonymisation on request',       body: 'Transcripts are pseudonymised before analysis. The organisation defines the level of anonymisation.' },
  { icon: 'bell',    title: '48-hour incident reporting',        body: 'Security incidents are reported within 48 hours of first awareness.' },
  { icon: 'trash',   title: 'Data deletion on request',          body: 'All data is deleted or returned after contract end - immediately on request.' },
  { icon: 'lock',    title: 'Privacy by Design',                 body: 'Data protection is built in from day one - not bolted on after the fact.' },
];

const aiPrinciples: Principle[] = isDE ? [
  { icon: 'slash',   title: 'Kein Training auf Interview-Daten', body: 'Gespräche und Antworten Ihrer Mitarbeitenden fließen nicht in das Training von KI-Modellen. Vertraglich zugesichert.' },
  { icon: 'users',   title: 'Human-in-the-Loop',                 body: 'Kein Ergebnis wird automatisch versendet. Verantwortliche im Unternehmen entscheiden über die Weitergabe aller Erkenntnisse.' },
  { icon: 'check',   title: 'EU AI Act Konformität',             body: 'Transparenz- und Kontrollpflichten gemäß EU AI Act sind vollständig erfüllt.' },
] : [
  { icon: 'slash',   title: 'No training on interview data',     body: 'Conversations and employee responses do not flow into the training of AI models. Contractually guaranteed.' },
  { icon: 'users',   title: 'Human-in-the-Loop',                 body: 'No results are sent automatically. Responsible people within the organisation decide on the sharing of all insights.' },
  { icon: 'check',   title: 'EU AI Act compliance',              body: 'Transparency and control obligations under the EU AI Act are fully met.' },
];

const faqItems = isDE ? [
  { q: 'Werden Mitarbeiterdaten für KI-Training verwendet?',          a: 'Nein. inplicit nutzt ausschließlich Modelle mit vertraglich zugesichertem Zero Data Retention. Interview-Inhalte und Organisationsdaten werden nicht für das Training von Modellen verwendet.' },
  { q: 'Wer hat Zugriff auf Interview-Inhalte?',                      a: 'Ausschließlich autorisierte Personen im Unternehmen. Inhalte werden nicht an Dritte weitergegeben. inplicit-Mitarbeitende haben nur für technisch notwendige Tätigkeiten Zugriff.' },
  { q: 'Wie ist die Anonymisierung von Interview-Inhalten geregelt?',  a: 'Auf Wunsch erfolgt eine Pseudonymisierung der Transkripte vor der Auswertung. Das Unternehmen legt den gewünschten Grad der Anonymisierung fest.' },
  { q: 'Wie schnell werden Sicherheitsvorfälle gemeldet?',            a: 'Innerhalb von 48 Stunden nach erster Kenntnis - mit vollständiger Beschreibung des Vorfalls, betroffener Datenkategorien und ergriffener Maßnahmen.' },
  { q: 'Ist ein AV-Vertrag verfügbar?',                               a: 'Ja. Der Auftragsverarbeitungsvertrag wird pro Unternehmen beim Onboarding unterzeichnet. Auf Anfrage kann das Dokument vorab zugesendet werden.' },
] : [
  { q: 'Is employee data used for AI training?',                      a: 'No. inplicit uses only models with contractually guaranteed zero data retention. Interview content and organisation data are not used to train any models.' },
  { q: 'Who has access to interview content?',                        a: 'Only authorised people within your organisation. Content is not shared with third parties. inplicit staff access is limited to technically necessary activities.' },
  { q: 'How is anonymisation of interview content handled?',          a: 'On request, transcripts are pseudonymised before analysis. The organisation defines the level of anonymisation required.' },
  { q: 'How quickly are security incidents reported?',                a: 'Within 48 hours of first awareness - with a full description of the incident, affected data categories, and measures taken.' },
  { q: 'Is a data processing agreement available?',                   a: 'Yes. The DPA is signed per organisation at onboarding. It can be sent in advance upon request.' },
];
---

<!-- ─── HERO: two-column split ─── -->
<section class="tc-hero">
  <div class="container">
    <div class="tc-hero__split">

      <div class="tc-hero__left section-fade">
        <span class="tc-badge">Trust Center</span>
        <h1 class="tc-hero__heading">
          <span class="tc-hero__line1">{isDE ? 'Vertrauen' : 'Trust'}</span>
          <span class="tc-hero__line2">{isDE ? 'ist die Grundlage.' : 'is the foundation.'}</span>
        </h1>
      </div>

      <div class="tc-hero__right section-fade">
        <p class="tc-hero__sub">
          {isDE
            ? 'Wo Mitarbeiterdaten und Organisationswissen verarbeitet werden, muss alles nachvollziehbar sein. Hier steht, wie inplicit Datenschutz, Betriebsratsanforderungen und KI-Transparenz umsetzt.'
            : 'Where employee data and organisational knowledge are processed, everything must be transparent. Here is how inplicit implements data protection, works-council requirements, and AI transparency.'}
        </p>
        <!-- Add /public/av-vertrag.pdf once document is ready -->
        <a
          href="mailto:hello@inplicit.ai?subject=AV-Vertrag%20Anfrage"
          class="tc-av-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
          </svg>
          {isDE ? 'AV-Vertrag anfordern' : 'Request DPA'}
        </a>
      </div>

    </div>

    <!-- Compliance badge strip - Applications card style -->
    <div class="tc-hero__strip section-fade">
      {heroBadges.map((b) => (
        <div class="tc-hero__badge">
          <span class="tc-hero__badge-check" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          <div>
            <strong class="tc-hero__badge-label">{b.label}</strong>
            <span class="tc-hero__badge-sub">{b.sub}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── CONTENT: Dokumente → KI-Transparenz ─── -->
<section class="tc-content">
  <div class="container">

<!-- Pair 1: AV-Vertrag | Kontakt -->
<div class="tc-pair">
  <div class="tc-pair__cell section-fade">
    <p class="tc-cell__eyebrow">{isDE ? 'Dokumente' : 'Documents'}</p>
    <h2 class="tc-cell__heading">
      {isDE ? 'Der AV-Vertrag im Original' : 'The DPA in full'}
    </h2>
    <p class="tc-cell__text">
      {isDE
        ? 'Der vollständige Auftragsverarbeitungsvertrag nach Art. 28 DSGVO. Wird pro Unternehmen beim Onboarding unterzeichnet - vor dem ersten Interview.'
        : 'The full data processing agreement under Art. 28 GDPR. Signed per organisation at onboarding - before the first interview.'}
    </p>
    <a
      href="mailto:hello@inplicit.ai?subject=AV-Vertrag%20Anfrage"
      class="tc-doc-btn"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      {isDE ? 'AV-Vertrag anfordern' : 'Request DPA (PDF)'}
    </a>
  </div>

  <div class="tc-pair__cell section-fade">
    <p class="tc-cell__eyebrow">{isDE ? 'Kontakt' : 'Contact'}</p>
    <h2 class="tc-cell__heading">
      {isDE ? 'Fragen zu Datenschutz oder Compliance?' : 'Questions about privacy or compliance?'}
    </h2>
    <p class="tc-cell__text">
      {isDE
        ? 'Wir antworten persönlich. Für formale Anfragen, Audit-Wünsche oder Fragen zum AV-Vertrag:'
        : 'We respond personally. For formal requests, audit inquiries, or questions about the DPA:'}
    </p>
    <!-- Contact person card - Applications card style -->
    <div class="tc-contact">
      <div class="tc-contact__avatar" aria-hidden="true">MA</div>
      <div class="tc-contact__info">
        <p class="tc-contact__name">Martin Auer</p>
        <p class="tc-contact__role">{isDE ? 'Co-Founder, inplicit.ai' : 'Co-Founder, inplicit.ai'}</p>
        <a href="mailto:hello@inplicit.ai" class="tc-contact__email">hello@inplicit.ai</a>
      </div>
    </div>
  </div>
</div>

<!-- Pair 2: Datenschutz | KI-Transparenz -->
<div class="tc-pair tc-pair--sep">
  <div class="tc-pair__cell section-fade">
    <p class="tc-cell__eyebrow">{isDE ? 'Datenschutz' : 'Data Protection'}</p>
    <h2 class="tc-cell__heading">
      {isDE ? 'DSGVO, Betriebsrat und Betroffenenrechte' : 'GDPR, works council, and data subject rights'}
    </h2>
    <p class="tc-cell__text">
      {isDE
        ? 'Die Verarbeitung erfolgt ausschließlich im Auftrag und nach Weisung des jeweiligen Unternehmens. Betriebsräte erhalten vollständige Transparenz über Datenflüsse und Verarbeitungszwecke.'
        : 'Processing takes place exclusively on behalf of and according to the instructions of each organisation. Works councils receive full transparency on data flows and processing purposes.'}
    </p>
    <div class="tc-principles">
      {privacyPrinciples.map((p, i) => (
        <div class="tc-principle" style={`--delay: ${i * 50}ms`}>
          <div class="tc-principle__icon" aria-hidden="true">
            {p.icon === 'shield' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            {p.icon === 'user'  && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>}
            {p.icon === 'bell'  && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>}
            {p.icon === 'trash' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>}
            {p.icon === 'lock'  && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>}
          </div>
          <div class="tc-principle__body">
            <h3 class="tc-principle__title">{p.title}</h3>
            <p class="tc-principle__text">{p.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="tc-pair__cell section-fade">
    <p class="tc-cell__eyebrow">{isDE ? 'KI-Transparenz' : 'AI Transparency'}</p>
    <h2 class="tc-cell__heading">
      {isDE ? 'KI-Einsatz transparent und kontrolliert' : 'AI use - transparent and controlled'}
    </h2>
    <p class="tc-cell__text">
      {isDE
        ? 'inplicit setzt KI ein, um Interviews zu führen und Erkenntnisse zu synthetisieren. Die Nutzung ist vertraglich geregelt und ohne Datenrisiko für Mitarbeitende.'
        : 'inplicit uses AI to conduct interviews and synthesise insights. Usage is contractually regulated and risk-free for employees.'}
    </p>
    <div class="tc-principles">
      {aiPrinciples.map((p, i) => (
        <div class="tc-principle" style={`--delay: ${i * 50}ms`}>
          <div class="tc-principle__icon" aria-hidden="true">
            {p.icon === 'slash' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>}
            {p.icon === 'users' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
            {p.icon === 'check' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>}
          </div>
          <div class="tc-principle__body">
            <h3 class="tc-principle__title">{p.title}</h3>
            <p class="tc-principle__text">{p.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

  </div><!-- /container -->
</section><!-- /tc-content -->

<!-- ─── FAQ: two-column, 21.dev-inspired layout ─── -->
<section class="tc-faq-section">
  <div class="container">
    <div class="tc-faq__layout">

      <div class="tc-faq__intro section-fade">
        <p class="tc-cell__eyebrow">FAQ</p>
        <h2 class="tc-faq__heading">
          <span>{isDE ? 'Noch Fragen' : 'Still have'}</span>
          <span class="tc-heading__faded">{isDE ? 'zur Compliance?' : 'questions?'}</span>
        </h2>
        <p class="tc-faq__sub">
          {isDE
            ? 'Die häufigsten Fragen zu Datenschutz, KI-Einsatz und Compliance bei inplicit.'
            : 'The most common questions about data protection, AI usage, and compliance at inplicit.'}
        </p>
        <a href="mailto:hello@inplicit.ai" class="tc-faq__contact-link">
          {isDE ? 'Direkt fragen →' : 'Ask directly →'}
        </a>
      </div>

      <div class="tc-faq__items section-fade">
        {faqItems.map((item) => (
          <div class="tc-faq__item">
            <button class="tc-faq__q" aria-expanded="false" data-faq-trigger>
              <span class="tc-faq__q-text">{item.q}</span>
              <span class="tc-faq__icon" aria-hidden="true"></span>
            </button>
            <div class="tc-faq__answer-wrap">
              <p class="tc-faq__a">{item.a}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<!-- ─── CTA - same pattern as DemoCTA ─── -->
<section class="tc-cta section-fade">
  <div class="container">
    <div class="tc-cta__card">
      <p class="tc-cta__eyebrow">{isDE ? 'Jetzt starten' : 'Get started'}</p>
      <h2 class="tc-cta__heading">
        <span>{isDE ? 'Bereit, Ihrer Organisation' : 'Ready to give your'}</span>
        <span class="tc-heading__faded">{isDE ? 'eine Stimme zu geben?' : 'organisation a voice?'}</span>
      </h2>
      <p class="tc-cta__sub">
        {isDE
          ? 'Erste Erkenntnisse in 3–4 Tagen. Kein aufwendiges Onboarding. Kein Setup-Aufwand.'
          : 'First insights in 3–4 days. No lengthy onboarding. No setup effort.'}
      </p>
      <a href={isDE ? '/de/#request-pilot' : '/#request-pilot'} class="tc-cta__btn">
        <span class="tc-cta__btn-label">{isDE ? 'Zur Warteliste' : 'Join Waitlist'}</span>
        <i class="tc-cta__btn-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </i>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Shared utilities ── */
  .tc-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
    opacity: 0.85;
  }

  .tc-heading__faded { opacity: 0.3; }

  /* ── Hero ── */
  .tc-hero {
    padding: var(--space-section-lg) 0 var(--space-section);
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .tc-hero { padding: var(--space-24) 0; }
  }

  /* Two-column hero split */
  .tc-hero__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
    margin-bottom: var(--space-16);
  }

  @media (max-width: 767px) {
    .tc-hero__split { grid-template-columns: 1fr; gap: var(--space-10); margin-bottom: var(--space-12); }
  }

  .tc-hero__heading {
    font-size: clamp(var(--text-2xl), 7vw, var(--text-3xl));
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    display: flex;
    flex-direction: column;
    gap: 0.04em;
    color: var(--color-text-primary);
  }

  .tc-hero__line1 { color: var(--color-text-primary); }
  .tc-hero__line2 { color: var(--color-text-primary); opacity: 0.3; }

  .tc-hero__right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: var(--space-4);
  }

  .tc-hero__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  /* AV-Vertrag button - primary CTA style */
  .tc-av-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 44px;
    padding: 0 var(--space-6);
    background-color: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: var(--text-sm);
    font-weight: 700;
    border-radius: var(--radius-ui);
    transition: opacity 0.2s var(--ease-smooth);
  }

  .tc-av-btn:hover { opacity: 0.85; }

  /* Hero badge strip - Applications card style */
  .tc-hero__strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .tc-hero__strip { grid-template-columns: repeat(2, 1fr); }
  }

  .tc-hero__badge {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-6);
    background-color: var(--color-bg);
    border-right: 1px solid var(--color-border);
    transition: border-color 0.2s var(--ease-smooth);
  }

  .tc-hero__badge:last-child { border-right: none; }

  @media (max-width: 767px) {
    .tc-hero__badge:nth-child(2) { border-right: none; }
    .tc-hero__badge:nth-child(1),
    .tc-hero__badge:nth-child(2) { border-bottom: 1px solid var(--color-border); }
  }

  .tc-hero__badge:hover { background-color: var(--color-surface); }

  .tc-hero__badge-check {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .tc-hero__badge-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-bottom: 2px;
  }

  .tc-hero__badge-sub {
    display: block;
    font-size: 11px;
    color: var(--color-text-tertiary);
    line-height: 1.4;
  }

  /* ── Content section wrapper (normal container margins) ── */
  .tc-content {
    border-top: 1px solid var(--color-border);
    padding: var(--space-section) 0;
  }

  @media (max-width: 767px) {
    .tc-content { padding: var(--space-24) 0; }
  }

  /* Two-column pairs inside the container */
  .tc-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .tc-pair--sep {
    margin-top: var(--space-section);
    padding-top: var(--space-section);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .tc-pair { grid-template-columns: 1fr; }
    .tc-pair--sep { margin-top: var(--space-24); padding-top: var(--space-24); }
  }

  .tc-pair__cell {
    padding-right: var(--space-16);
  }

  .tc-pair__cell:last-child {
    padding-right: 0;
    padding-left: var(--space-16);
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {

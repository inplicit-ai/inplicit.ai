---
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const R = 22;

const nodes = [
  { cx: 165, cy: 148, role: 'CEO' },
  { cx: 82,  cy: 240, role: 'CTO' },
  { cx: 248, cy: 240, role: 'CPO' },
  { cx: 30,  cy: 340, role: '' },
  { cx: 118, cy: 340, role: '' },
  { cx: 212, cy: 340, role: '' },
  { cx: 300, cy: 340, role: '' },
  { cx: 165, cy: 422, role: '' },
];

const photos = [
  'photo-1560250097-0b93528c311a',
  'photo-1507003211169-0a1dd7228f2d',
  'photo-1494790108377-be9c29b29330',
  'photo-1500648767791-00dcc994a43e',
  'photo-1438761681033-6461ffad8d80',
  'photo-1472099645785-5658abf4ff4e',
  'photo-1573497019940-1c28c88b4f3e',
  'photo-1570295999919-56ceb5ecca61',
];

const edges: [number, number][] = [
  [0,1],[0,2],[1,3],[1,4],[2,5],[2,6],[4,7],[5,7],
];

const BADGE_ICONS = [
  // lightbulb
  `<circle cy="-1.5" r="3" fill="none" stroke="white" stroke-width="1.2"/>
   <path d="M-2,1.5 L2,1.5 M-1.4,3 L1.4,3" stroke="white" stroke-width="1.2" stroke-linecap="round"/>`,
  // gear
  `<circle r="2.2" fill="none" stroke="white" stroke-width="1.1"/>
   <circle r="0.9" fill="white"/>
   <path d="M0,-4 L0,-3 M0,3 L0,4 M-4,0 L-3,0 M3,0 L4,0 M-2.8,-2.8 L-2.1,-2.1 M2.1,-2.1 L2.8,-2.8 M-2.1,2.1 L-2.8,2.8 M2.8,2.8 L2.1,2.1" stroke="white" stroke-width="1.1" stroke-linecap="round"/>`,
  // lightning
  `<path d="M1.2,-4.5 L-1.2,0.2 L0.6,0.2 L-1.2,4.5 L2.2,-0.5 L0.4,-0.5 Z" fill="white"/>`,
  // chat bubble
  `<rect x="-3.8" y="-3.5" width="7.6" height="5" rx="1.5" fill="none" stroke="white" stroke-width="1.2"/>
   <path d="M-1.5,1.5 L-3,3.5 L1,1.5" fill="white"/>`,
  // bar chart
  `<rect x="-3.5" y="-1.5" width="1.7" height="5" fill="white"/>
   <rect x="-0.85" y="-3.5" width="1.7" height="7" fill="white"/>
   <rect x="1.8" y="0" width="1.7" height="3.5" fill="white"/>`,
];

const questions = isDE
  ? ['Wo verlieren wir im Betrieb Zeit?', 'Was sind die größten Schmerzpunkte?', 'Wo sehen Mitarbeitende ungenutzte Chancen?']
  : ['Where do we lose time in operations?', 'What are the most-named pain points?', 'Where do people see untapped opportunities?'];

const agentMsg = isDE
  ? 'Was möchtest du über deine Organisation verstehen?'
  : 'What do you want to understand about your organisation?';

const userMsg = isDE
  ? 'Wo verlieren wir Zeit und was sind unsere größten Engpässe?'
  : 'Where do we lose time and what are our biggest bottlenecks?';

const sendIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>`;

function personIcon(cx: number, cy: number) {
  return `<circle cx="${cx}" cy="${cy - 7}" r="6.5" fill="white" opacity="0.88"/>
<path d="M${cx-12},${cy+17} Q${cx-11},${cy+5} ${cx},${cy+5} Q${cx+11},${cy+5} ${cx+12},${cy+17}" fill="white" opacity="0.88"/>`;
}

// InplicitLoader path + initial circle positions (from InplicitLoader.tsx)
const SQUARE_PATH = "M925.999 829.575L251.424 926L155 251.424L829.575 155L925.999 829.575Z";
const LCw = { x: 501.10, y: 501.13 };
const LCo = { x: 578.80, y: 586.55 };
---

<div class="nviz" aria-hidden="true">

  <!-- ── Network SVG ── -->
  <svg class="nviz__svg" viewBox="0 0 330 460" xmlns="http://www.w3.org/2000/svg" role="presentation">
    <defs>
      {nodes.map((_, i) => (
        <clipPath id={`nclip-${i}`}>
          <circle cx={nodes[i].cx} cy={nodes[i].cy} r={R} />
        </clipPath>
      ))}
    </defs>

    <g class="nviz-gray">
      {edges.map(([a, b]) => (
        <line x1={nodes[a].cx} y1={nodes[a].cy} x2={nodes[b].cx} y2={nodes[b].cy}
          style="stroke: var(--color-border);" stroke-width="1.5"/>
      ))}
      {nodes.map((n, i) => (
        <g>
          <circle cx={n.cx} cy={n.cy} r={R}
            style="fill: var(--color-surface-elevated); stroke: var(--color-border);" stroke-width="1"/>
          <image
            href={`https://images.unsplash.com/${photos[i]}?w=88&h=88&fit=crop&crop=faces&auto=format&q=80`}
            x={n.cx - R} y={n.cy - R} width={R*2} height={R*2}
            clip-path={`url(#nclip-${i})`} preserveAspectRatio="xMidYMid slice"
            style="opacity: 0.55;"/>
          {n.role && (
            <text x={n.cx} y={n.cy + R + 11} text-anchor="middle"
              style="fill: var(--color-text-tertiary);" font-size="7.5" font-weight="700"
              font-family="Inter,sans-serif" letter-spacing="0.07em">{n.role}</text>
          )}
        </g>
      ))}
    </g>

    <g class="nviz-orange">
      {edges.map(([a, b], i) => (
        <line x1={nodes[a].cx} y1={nodes[a].cy} x2={nodes[b].cx} y2={nodes[b].cy}
          class="nviz-oline"
          style={`stroke: var(--color-accent); opacity: 0.5; animation-delay: ${(i*0.1+2.8).toFixed(2)}s`}
          stroke-width="1.5"/>
      ))}
      {nodes.map((n, i) => (
        <g class="nviz-onode" style={`animation-delay: ${(i*0.14+2.2).toFixed(2)}s`}>
          <circle cx={n.cx} cy={n.cy} r={R} style="fill: var(--color-accent);"/>
          <Fragment set:html={personIcon(n.cx, n.cy)}/>
          <circle cx={n.cx} cy={n.cy} r={R+3} fill="none"
            style="stroke: var(--color-accent);" stroke-width="2" opacity="0.5"/>
          <g class="nviz-badge" style={`animation-delay: ${(i*0.14+2.7).toFixed(2)}s`}>
            <circle cx={n.cx+19} cy={n.cy-19} r={8.5} style="fill: var(--color-text-primary);"/>
            <g transform={`translate(${n.cx+19},${n.cy-19})`}>
              <Fragment set:html={BADGE_ICONS[i % BADGE_ICONS.length]}/>
            </g>
          </g>
        </g>
      ))}
    </g>
  </svg>

  <!-- ── Popup scene (one scene, JS switches state inside) ── -->
  <div class="scene" id="nviz-scene">
    <div class="scene__head">
      <span class="scene__avatar" set:html={logoIconRaw}/>
      <div>
        <div class="scene__name">Inplicit</div>
        <div class="scene__sub">{isDE ? 'Autonomer Context-Gap-Agent' : 'Autonomous context-gap agent'}</div>
      </div>
      <span class="scene__live"></span>
    </div>

    <!-- State A: empty (InplicitLoader + hint text) -->
    <div class="scene__body" id="nviz-state-empty">
      <svg id="nviz-loader" width="52" height="52" viewBox="0 0 1080 1080"
           xmlns="http://www.w3.org/2000/svg" role="presentation">
        <path d={SQUARE_PATH} fill="#1a1714"/>
        <circle id="nviz-lw" cx={LCw.x} cy={LCw.y} r="128.405" fill="#faf8f4"/>
        <circle id="nviz-lo" cx={LCo.x} cy={LCo.y} r="128.405" fill="#F5A623"/>
      </svg>
      <p class="scene__hint">
        {isDE
          ? 'Frag alles. Jede Antwort zitiert eine anonyme Quelle.'
          : 'Ask anything. Every answer cites an anonymous source.'}
      </p>
    </div>

    <!-- State B: chat bubbles -->
    <div class="scene__chat-body" id="nviz-state-chat">
      <div class="chat__agent">
        <span class="chat__av" set:html={logoIconRaw}/>
        <div class="chat__agent-bubble">
          <span id="nviz-agent-text" data-text={agentMsg}></span><span class="chat__caret chat__caret--accent"></span>
        </div>
      </div>
      <div class="chat__user" id="nviz-user-row">
        <div class="chat__user-bubble">
          <span id="nviz-user-text" data-text={userMsg}></span><span class="chat__caret"></span>
        </div>
      </div>
    </div>

    <!-- Composer A: chips + rotator -->
    <div class="scene__composer" id="nviz-comp-empty">
      <div class="scene__chips">
        <span class="scene__chip">{isDE ? 'Prozesswissen' : 'Process knowledge'}</span>
        <span class="scene__chip">{isDE ? 'Operatives Know-how' : 'Operational know-how'}</span>
      </div>
      <div class="scene__input">
        <span class="scene__placeholder">
          <span id="nviz-rotator" data-qs={JSON.stringify(questions)}></span><span class="scene__caret"></span>
        </span>
        <span class="scene__send" set:html={sendIcon}/>
      </div>
    </div>

    <!-- Composer B: input where user message types before sending -->
    <div class="scene__composer nviz-hidden" id="nviz-comp-chat">
      <div class="scene__input">
        <span class="scene__placeholder">
          <span id="nviz-input-text"></span><span class="scene__caret" id="nviz-input-caret" style="display:none"></span>
        </span>
        <span class="scene__send" id="nviz-send-btn" set:html={sendIcon}/>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var scene    = document.getElementById('nviz-scene');
  var stEmpty  = document.getElementById('nviz-state-empty');
  var stChat   = document.getElementById('nviz-state-chat');
  var compE    = document.getElementById('nviz-comp-empty');
  var compC    = document.getElementById('nviz-comp-chat');
  var userRow  = document.getElementById('nviz-user-row');
  var lw       = document.getElementById('nviz-lw');
  var lo       = document.getElementById('nviz-lo');
  var rotEl    = document.getElementById('nviz-rotator');

  if (!scene) return;

  if (reduced) {
    // skip straight to chat state
    scene.style.cssText += 'opacity:1;transform:none;transition:none;';
    stEmpty.style.display  = 'none';
    compE.style.display    = 'none';
    stChat.style.display   = 'flex';
    compC.style.display    = 'flex';
    compC.classList.remove('nviz-hidden');
    if (userRow) userRow.style.opacity = '1';
    var at = document.getElementById('nviz-agent-text');
    var ut = document.getElementById('nviz-user-text');
    if (at) at.textContent = at.getAttribute('data-text') || '';
    if (ut) ut.textContent = ut.getAttribute('data-text') || '';
    return;
  }

  // ── InplicitLoader rAF ──
  var lraf = 0, ls = null;
  var LM = {x:539.95, y:543.84}, OFF = {x:38.85, y:42.71}, LR = 128.405, DEPTH = 0.13, DUR = 1400;
  function loaderTick(now) {
    if (ls === null) ls = now;
    var a = (((now - ls) % DUR) / DUR) * 2 * Math.PI;
    var c = Math.cos(a), s = Math.sin(a);
    lw.setAttribute('cx', (LM.x - OFF.x * c).toFixed(2));
    lw.setAttribute('cy', (LM.y - OFF.y * c).toFixed(2));
    lw.setAttribute('r',  (LR * (1 + DEPTH * s)).toFixed(2));
    lo.setAttribute('cx', (LM.x + OFF.x * c).toFixed(2));
    lo.setAttribute('cy', (LM.y + OFF.y * c).toFixed(2));
    lo.setAttribute('r',  (LR * (1 - DEPTH * s)).toFixed(2));
    var front = s >= 0 ? lw : lo;
    if (front.parentNode && front.parentNode.lastChild !== front) front.parentNode.appendChild(front);
    lraf = requestAnimationFrame(loaderTick);
  }

  // ── Placeholder rotator ──
  var rTimer = null;
  function startRotator() {
    if (!rotEl) return;
    var qs; try { qs = JSON.parse(rotEl.getAttribute('data-qs') || '[]'); } catch(e) { qs = []; }
    if (qs.length < 2) return;
    var qi = 0, ci = 0, del = false;
    function tick() {
      var q = qs[qi];
      if (!del) {
        rotEl.textContent = q.slice(0, ++ci);
        rTimer = ci >= q.length ? setTimeout(tick, 1900) : setTimeout(tick, 50 + Math.random()*35);
      } else {
        rotEl.textContent = q.slice(0, --ci);
        if (ci <= 0) { del = false; qi = (qi+1) % qs.length; rTimer = setTimeout(tick, 420); }
        else rTimer = setTimeout(tick, 28);
      }
      del = !del && ci >= qs[qi < qs.length ? qi : 0].length ? true : del;
    }
    // re-written without the bug:
    clearTimeout(rTimer);
    var qi2 = 0, ci2 = 0, deleting = false;
    function tick2() {
      var q = qs[qi2];
      if (!deleting) {
        rotEl.textContent = q.slice(0, ++ci2);
        if (ci2 >= q.length) { deleting = true; rTimer = setTimeout(tick2, 2000); }
        else rTimer = setTimeout(tick2, 50 + Math.random()*35);
      } else {
        rotEl.textContent = q.slice(0, --ci2);
        if (ci2 <= 0) { deleting = false; qi2 = (qi2+1) % qs.length; rTimer = setTimeout(tick2, 400); }
        else rTimer = setTimeout(tick2, 28);
      }
    }
    rTimer = setTimeout(tick2, 1200);
  }

  // ── Typing animation ──
  function typeIn(elId, caretId, delay) {
    setTimeout(function () {
      var el    = document.getElementById(elId);
      var caret = document.getElementById(caretId);
      if (!el) return;
      var text = el.getAttribute('data-text') || '';
      var i = 0;
      function go() {
        el.textContent = text.slice(0, i++);
        if (i <= text.length) setTimeout(go, 32 + Math.random()*28);
        else if (caret) { caret.style.animation = 'none'; caret.style.opacity = '0'; }
      }
      go();
    }, delay);
  }

  // ── Phase 1 → 2: show popup at 6 s ──
  setTimeout(function () {
    scene.style.opacity   = '1';
    scene.style.transform = 'translateY(0)';
    lraf = requestAnimationFrame(loaderTick);
    startRotator();
  }, 6000);

  // ── Phase 2 → 3: switch to chat at 12 s ──
  setTimeout(function () {
    stEmpty.style.display = 'none';
    compE.style.display   = 'none';
    clearTimeout(rTimer);
    cancelAnimationFrame(lraf);
    stChat.style.display = 'flex';
    compC.style.display  = 'flex';
    compC.classList.remove('nviz-hidden');

    // 1. Agent types in bubble
    typeIn('nviz-agent-text', 'nviz-agent-caret', 400);

    // 2. After agent done (~3.5 s), user types in the INPUT field
    setTimeout(function () {
      var inputEl  = document.getElementById('nviz-input-text');
      var inputCaret = document.getElementById('nviz-input-caret');
      var sendBtn  = document.getElementById('nviz-send-btn');
      var userTextEl = document.getElementById('nviz-user-text');
      var userCaretEl = document.getElementById('nviz-user-caret');
      if (!inputEl) return;
      var msg = (document.getElementById('nviz-user-text') || {}).getAttribute ?
                document.getElementById('nviz-user-text').getAttribute('data-text') || '' : '';
      // show caret in input
      if (inputCaret) inputCaret.style.display = 'inline-block';
      // type into input
      var i = 0;
      function typeInput() {
        inputEl.textContent = msg.slice(0, i++);
        if (i <= msg.length) {
          setTimeout(typeInput, 32 + Math.random() * 28);
        } else {
          // done typing — pause, flash send button, move to bubble
          setTimeout(function () {
            if (sendBtn) { sendBtn.style.transform = 'scale(0.88)'; sendBtn.style.transition = 'transform 0.12s'; }
            setTimeout(function () {
              if (sendBtn) sendBtn.style.transform = '';
              // clear input, hide caret
              inputEl.textContent = '';
              if (inputCaret) inputCaret.style.display = 'none';
              // show user bubble with text already there
              if (userTextEl) userTextEl.textContent = msg;
              if (userCaretEl) userCaretEl.style.display = 'none';
              if (userRow) userRow.style.opacity = '1';
            }, 160);
          }, 500);
        }
      }
      typeInput();
    }, 3800);
  }, 12000);
})();
</script>

<style>
  .nviz {
    position: relative;
    width: 100%;
  }
  .nviz__svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* Popup: absolute overlay exactly covering the SVG */
  .scene {
    position: absolute;
    inset: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    font-family: var(--font-family);
    /* initial invisible state — JS transitions in */
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.7s cubic-bezier(0.34, 1.1, 0.64, 1),
                transform 0.7s cubic-bezier(0.34, 1.1, 0.64, 1);
  }

  .nviz-hidden { display: none !important; }

  /* ── Network layer animations ── */
  .nviz-gray {
    opacity: 0;
    animation: nv-in 1.1s ease-out 0.5s forwards;
  }
  .nviz-orange {
    opacity: 0;
    animation: nv-lift 4.0s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.8s forwards;
  }
  @keyframes nv-in { to { opacity: 1; } }
  @keyframes nv-lift {
    0%   { opacity: 0; transform: translateY(0); }
    16%  { opacity: 1; transform: translateY(0); }
    52%  { opacity: 1; transform: translateY(-12px); }
    100% { opacity: 1; transform: translateY(-46px); }
  }
  .nviz-onode {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.3);
    animation: nv-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes nv-pop { to { opacity: 1; transform: scale(1); } }
  .nviz-oline {
    opacity: 0;
    animation: nv-in 0.5s ease-out forwards;
  }
  .nviz-badge {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0);
    animation: nv-pop 0.4s cubic-bezier(0.34, 1.8, 0.64, 1) forwards;
  }

  /* ── Scene head ── */
  .scene__head {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-elevated);
  }
  .scene__avatar {
    width: 26px; height: 26px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--color-accent-light);
    border: 1px solid var(--color-accent-muted);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .scene__avatar :global(svg)  { width: 16px; height: 16px; display: block; }
  .scene__avatar :global(path) { fill: var(--color-text-primary); }
  .scene__avatar :global(rect) { fill: var(--color-accent); }
  .scene__name { font-size: 11px; font-weight: 600; color: var(--color-text-primary); }
  .scene__sub  { font-size: 9.5px; color: var(--color-text-tertiary); }
  .scene__live {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-left: auto; flex-shrink: 0;
    animation: live-pulse 1.8s ease-in-out 7s infinite;
  }
  @keyframes live-pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

  /* ── Empty body ── */
  .scene__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
  }
  #nviz-loader {
    /* explicit pixel size so the SVG never expands */
    width: 52px !important;
    height: 52px !important;
    display: block;
    flex-shrink: 0;
  }
  .scene__hint {
    font-size: 11.5px; line-height: 1.55;
    color: var(--color-text-secondary);
    text-align: center; max-width: 22ch;
  }

  /* ── Chat body ── */
  .scene__chat-body {
    flex: 1;
    display: none; /* JS switches to flex */
    flex-direction: column;
    justify-content: flex-end;
    gap: 12px;
    padding: 14px 12px;
  }
  .chat__agent { display: flex; align-items: flex-start; gap: 8px; }
  .chat__av {
    width: 22px; height: 22px;
    border-radius: 50%; flex-shrink: 0; margin-top: 1px;
    background: var(--color-accent-light);
    border: 1px solid var(--color-accent-muted);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .chat__av :global(svg)  { width: 13px; height: 13px; display: block; }
  .chat__av :global(path) { fill: var(--color-text-primary); }
  .chat__av :global(rect) { fill: var(--color-accent); }
  .chat__agent-bubble {
    background: var(--color-text-primary);
    color: var(--color-bg);
    border-radius: 4px 14px 14px 14px;
    padding: 9px 12px; max-width: 85%;
    font-size: 11.5px; line-height: 1.55;
  }
  .chat__user {
    display: flex; justify-content: flex-end;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .chat__user-bubble {
    background: var(--color-accent);
    color: var(--color-text-primary);
    border-radius: 14px 4px 14px 14px;
    padding: 9px 12px; max-width: 85%;
    font-size: 11px; line-height: 1.5; font-weight: 500;
  }
  .chat__caret {
    display: inline-block;
    width: 1.5px; height: 1em;
    background: currentColor;
    margin-left: 1px; vertical-align: text-bottom;
    animation: caret-blink 0.9s step-end infinite;
  }
  /* agent caret: accent colour against dark bubble */
  .chat__caret--accent { background: var(--color-accent); }
  @keyframes caret-blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

  /* ── Composer ── */
  .scene__composer {
    flex-shrink: 0;
    display: flex; flex-direction: column; gap: 8px;
    padding: 10px 12px 13px;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .scene__chips { display: flex; flex-wrap: wrap; gap: 5px; }
  .scene__chip {
    font-size: 9.5px; color: var(--color-text-secondary);
    border: 1px solid var(--color-border); border-radius: 99px;

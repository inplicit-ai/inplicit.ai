---
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

// ── Large organisation as an organic cluster network ──
// Every circle is one employee (avatar). Grey photos first → the whole org
// turns orange (the digital twin). The leadership team sits at the centre and
// each exec heads a department cluster. Communication sparks flit along links.
function mulberry32(seed: number) {
  return function () {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rnd = mulberry32(20260706);
const rand = (a: number, b: number) => a + rnd() * (b - a);

const VW = 330, VH = 460, CX = 165, CY = 210;
const clampX = (v: number) => Math.max(18, Math.min(VW - 18, v));
const clampY = (v: number) => Math.max(18, Math.min(VH - 18, v));

const photos = [
  'photo-1560250097-0b93528c311a', 'photo-1507003211169-0a1dd7228f2d',
  'photo-1494790108377-be9c29b29330', 'photo-1500648767791-00dcc994a43e',
  'photo-1438761681033-6461ffad8d80', 'photo-1472099645785-5658abf4ff4e',
  'photo-1573497019940-1c28c88b4f3e', 'photo-1570295999919-56ceb5ecca61',
  'photo-1519345182560-3f2917c472ef', 'photo-1506794778202-cad84cf45f1d',
  'photo-1544005313-94ddf0286df2', 'photo-1524504388940-b1c1722653e1',
  'photo-1531123897727-8f129e1688ce', 'photo-1489424731084-a5d8b219a5bb',
];

// Leadership team at the centre — slots ordered [top, right, bottom, left]
// (long titles go top/bottom where there is vertical room for the label).
const execTitles = isDE
  ? ['Geschäftsführer', 'COO', 'Finanzvorstand', 'CTO']
  : ['CEO', 'COO', 'CFO', 'CTO'];

type Node = { x: number; y: number; r: number; role: string; photo: string; ang: number; exec: boolean };
const nodes: Node[] = [];

const edges: [number, number][] = [];
const seen = new Set<string>();
function addEdge(a: number, b: number) {
  if (a === b) return;
  const k = a < b ? `${a}-${b}` : `${b}-${a}`;
  if (seen.has(k)) return;
  seen.add(k);
  edges.push([a, b]);
}

// Executives — a tight, mutually connected core near the centre
const execIdx: number[] = [];
for (let i = 0; i < execTitles.length; i++) {
  const ang = -Math.PI / 2 + (i / execTitles.length) * Math.PI * 2;
  const x = clampX(CX + Math.cos(ang) * 48);
  const y = clampY(CY + Math.sin(ang) * 46);
  const idx = nodes.length;
  nodes.push({ x, y, r: 13, role: execTitles[i], photo: photos[idx % photos.length], ang, exec: true });
  execIdx.push(idx);
}
for (let i = 0; i < execIdx.length; i++)
  for (let j = i + 1; j < execIdx.length; j++) addEdge(execIdx[i], execIdx[j]);

// Each exec heads a department cluster fanning outward
execIdx.forEach((eIdx) => {
  const e = nodes[eIdx];
  const members: number[] = [];
  const k = Math.round(rand(8, 11));
  for (let m = 0; m < k; m++) {
    const a = e.ang + rand(-1.0, 1.0);
    const rad = rand(42, 94);
    const mx = clampX(e.x + Math.cos(a) * rad);
    const my = clampY(e.y + Math.sin(a) * rad);
    const mIdx = nodes.length;
    nodes.push({ x: mx, y: my, r: rand(6.5, 9), role: '', photo: photos[mIdx % photos.length], ang: a, exec: false });
    addEdge(eIdx, mIdx);
    members.push(mIdx);
  }
  // a few intra-cluster peer links
  members.forEach((mi) => {
    if (rnd() < 0.4) addEdge(mi, members[Math.floor(rnd() * members.length)]);
  });
});

// informal cross-cluster links (the messy web)
for (let k = 0; k < 12; k++) {
  addEdge(Math.floor(rnd() * nodes.length), Math.floor(rnd() * nodes.length));
}

// Label placement: push exec titles outward from the centre to avoid overlap
function labelPos(n: Node) {
  if (Math.abs(Math.sin(n.ang)) > 0.7) {
    return Math.sin(n.ang) < 0
      ? { x: n.x, y: n.y - n.r - 6, anchor: 'middle' }   // top
      : { x: n.x, y: n.y + n.r + 12, anchor: 'middle' };  // bottom
  }
  return Math.cos(n.ang) >= 0
    ? { x: n.x + n.r + 5, y: n.y + 3, anchor: 'start' }    // right
    : { x: n.x - n.r - 5, y: n.y + 3, anchor: 'end' };     // left
}

// Communication sparks — fast pulses; exec links always spark, plus a subset
type Spark = { d: string; dur: string; begin: string };
const execSet = new Set(execIdx);
const sparks: Spark[] = [];
edges.forEach(([a, b]) => {
  if (execSet.has(a) || execSet.has(b) || rnd() < 0.4) {
    const rev = rnd() < 0.5;
    const p1 = rev ? b : a, p2 = rev ? a : b;
    sparks.push({
      d: `M ${nodes[p1].x},${nodes[p1].y} L ${nodes[p2].x},${nodes[p2].y}`,
      dur: `${rand(0.32, 0.7).toFixed(2)}s`,
      begin: `${rand(0, 1.1).toFixed(2)}s`,
    });
  }
});

// Radial "interview" wave: nodes turn orange from the centre outward.
const maxDist = Math.max(...nodes.map((n) => Math.hypot(n.x - CX, n.y - CY)));
function twinDelay(n: Node) {
  return +((Math.hypot(n.x - CX, n.y - CY) / maxDist) * 1.5 + 1.8).toFixed(2);
}

// Person glyph (white) that replaces the photo in the digital twin, scaled to r
function personIcon(cx: number, cy: number, r: number) {
  const s = r / 22;
  return `<circle cx="${cx}" cy="${(cy - 7 * s).toFixed(1)}" r="${(6.5 * s).toFixed(1)}" fill="white"/>
<path d="M${(cx - 12 * s).toFixed(1)},${(cy + 17 * s).toFixed(1)} Q${(cx - 11 * s).toFixed(1)},${(cy + 5 * s).toFixed(1)} ${cx},${(cy + 5 * s).toFixed(1)} Q${(cx + 11 * s).toFixed(1)},${(cy + 5 * s).toFixed(1)} ${(cx + 12 * s).toFixed(1)},${(cy + 17 * s).toFixed(1)}" fill="white"/>`;
}

// Microphone glyph (white), drawn inside the black "interviewed" badge
function micIcon(s: number) {
  return `<g transform="scale(${s.toFixed(3)})" stroke="white" stroke-width="0.9" stroke-linecap="round" fill="none">
<rect x="-1.3" y="-3.4" width="2.6" height="4.6" rx="1.3" fill="white" stroke="none"/>
<path d="M-2.2,-0.3 A2.2,2.2 0 0 0 2.2,-0.3"/>
<line x1="0" y1="1.9" x2="0" y2="3.4"/>
<line x1="-1.4" y1="3.4" x2="1.4" y2="3.4"/>
</g>`;
}

// ── Scene copy (chat popup) ──
const questions = isDE
  ? ['Wo verlieren wir im Betrieb Zeit?', 'Was sind die größten Schmerzpunkte?', 'Wo sehen Mitarbeitende ungenutzte Chancen?']
  : ['Where do we lose time in operations?', 'What are the most-named pain points?', 'Where do people see untapped opportunities?'];

const agentMsg = isDE
  ? 'Was möchtest du über deine Organisation verstehen?'
  : 'What do you want to understand about your organisation?';

const userMsg = isDE
  ? 'Wo verlieren wir Zeit und was sind unsere größten Engpässe?'
  : 'Where do we lose time and what are our biggest bottlenecks?';

const sendIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>`;

// InplicitLoader path + initial circle positions (from InplicitLoader.tsx)
const SQUARE_PATH = "M925.999 829.575L251.424 926L155 251.424L829.575 155L925.999 829.575Z";
const LCw = { x: 501.10, y: 501.13 };
const LCo = { x: 578.80, y: 586.55 };
---

<div class="nviz" aria-hidden="true">

  <!-- ── Network SVG ── -->
  <svg class="nviz__svg" viewBox="0 0 330 460" xmlns="http://www.w3.org/2000/svg" role="presentation">
    <defs>
      {nodes.map((n, i) => (
        <clipPath id={`nclip-${i}`}>
          <circle cx={n.x} cy={n.y} r={n.r} />
        </clipPath>
      ))}
    </defs>

    <!-- Base layer: every employee as an avatar (real org — recedes as twin builds).
         Photos appear first, then the connecting lines draw in. -->
    <g class="nviz-base">
      <g class="nv-edges">
        {edges.map(([a, b]) => (
          <line x1={nodes[a].x} y1={nodes[a].y} x2={nodes[b].x} y2={nodes[b].y}
            style="stroke: var(--color-text-primary); opacity: 0.09;" stroke-width="1"/>
        ))}
      </g>
      <g class="nv-nodes">
        {nodes.map((n, i) => (
          <g>
            <circle cx={n.x} cy={n.y} r={n.r}
              style="fill: var(--color-surface-elevated); stroke: var(--color-border);" stroke-width="1"/>
            <image
              href={`https://images.unsplash.com/${n.photo}?w=88&h=88&fit=crop&crop=faces&auto=format&q=80`}
              x={n.x - n.r} y={n.y - n.r} width={n.r * 2} height={n.r * 2}
              clip-path={`url(#nclip-${i})`} preserveAspectRatio="xMidYMid slice"
              style="opacity: 0.92;"/>
          </g>
        ))}
      </g>
    </g>

    <!-- Digital twin: photos → person icons turning orange from the centre out,
         each node interviewed (mic badge). Orange lines appear AFTER the nodes and
         connect to the Inplicit logo. The whole twin (incl. logo) lifts / floats. -->
    <g class="nviz-orange">
      <!-- Orange links — fade in only after the nodes have turned orange -->
      <g class="nv-oedges">
        {execIdx.map((e) => (
          <line x1={CX} y1={CY} x2={nodes[e].x} y2={nodes[e].y}
            style="stroke: var(--color-accent); opacity: 0.6;" stroke-width="1.4"/>
        ))}
        {edges.map(([a, b]) => (
          <line x1={nodes[a].x} y1={nodes[a].y} x2={nodes[b].x} y2={nodes[b].y}
            style="stroke: var(--color-accent); opacity: 0.45;" stroke-width="1"/>
        ))}
      </g>

      {nodes.map((n) => {
        const bx = n.x + n.r * 0.72, by = n.y - n.r * 0.72;
        const badgeR = Math.max(5.5, n.r * 0.52);
        return (
          <g class="nv-onode" style={`animation-delay: ${twinDelay(n)}s`}>
            <circle cx={n.x} cy={n.y} r={n.r} style="fill: var(--color-accent);"/>
            <Fragment set:html={personIcon(n.x, n.y, n.r)}/>
            <g class="nv-badge" style={`animation-delay: ${(twinDelay(n) + 0.25).toFixed(2)}s`}>
              <circle cx={bx} cy={by} r={badgeR} style="fill: var(--color-text-primary);"/>
              <g transform={`translate(${bx.toFixed(1)},${by.toFixed(1)})`} set:html={micIcon(badgeR / 6.5)}/>
            </g>
          </g>
        );
      })}

      <!-- Inplicit at the very centre — the reason every node turns orange.
           Inside the twin group so it lifts / floats away with the rest. -->
      <g class="nv-inplicit">
        <circle cx={CX} cy={CY} r="16" style="fill: var(--color-bg); stroke: var(--color-border);" stroke-width="1"/>
        <g transform={`translate(${CX - 12}, ${CY - 12}) scale(0.24)`} set:html={logoIconRaw}/>
      </g>
    </g>

    <!-- Labels: leadership team (drawn on top so they stay legible) -->
    <g class="nviz-labels">
      {nodes.filter((n) => n.role).map((n) => {
        const p = labelPos(n);
        return (
          <text x={p.x} y={p.y} text-anchor={p.anchor}
            style="fill: var(--color-text-primary); paint-order: stroke; stroke: var(--color-bg); font-family: var(--font-family);"
            stroke-width="2.4" font-size="8" font-weight="700" letter-spacing="0.02em">{n.role}</text>
        );
      })}
    </g>

    <!-- Communication sparks flitting along the links (light grey, low saturation) -->
    <g class="nv-sparks">
      {sparks.map((sp) => (
        <circle r="1.9" style="fill: var(--color-text-tertiary);">
          <animateMotion path={sp.d} dur={sp.dur} begin={sp.begin} repeatCount="indefinite" calcMode="linear"/>
        </circle>
      ))}
    </g>
  </svg>

  <!-- ── Popup scene (one scene, JS switches state inside) ── -->
  <div class="scene" id="nviz-scene">
    <div class="scene__head">
      <span class="scene__avatar" set:html={logoIconRaw}/>
      <div>
        <div class="scene__name">Inplicit</div>
        <div class="scene__sub">{isDE ? 'Autonomer Context-Gap-Agent' : 'Autonomous context-gap agent'}</div>
      </div>
      <span class="scene__live"></span>
    </div>

    <!-- State A: empty (InplicitLoader + hint text) -->
    <div class="scene__body" id="nviz-state-empty">
      <svg id="nviz-loader" width="52" height="52" viewBox="0 0 1080 1080"
           xmlns="http://www.w3.org/2000/svg" role="presentation">
        <path d={SQUARE_PATH} fill="#1a1714"/>
        <circle id="nviz-lw" cx={LCw.x} cy={LCw.y} r="128.405" fill="#faf8f4"/>
        <circle id="nviz-lo" cx={LCo.x} cy={LCo.y} r="128.405" fill="#F5A623"/>
      </svg>
      <p class="scene__hint">
        {isDE
          ? 'Frag alles. Jede Antwort zitiert eine anonyme Quelle.'
          : 'Ask anything. Every answer cites an anonymous source.'}
      </p>
    </div>

    <!-- State B: chat bubbles -->
    <div class="scene__chat-body" id="nviz-state-chat">
      <div class="chat__agent">
        <span class="chat__av" set:html={logoIconRaw}/>
        <div class="chat__agent-bubble">
          <span id="nviz-agent-text" data-text={agentMsg}></span><span class="chat__caret chat__caret--accent"></span>
        </div>
      </div>
      <div class="chat__user" id="nviz-user-row">
        <div class="chat__user-bubble">
          <span id="nviz-user-text" data-text={userMsg}></span><span class="chat__caret"></span>
        </div>
      </div>
    </div>

    <!-- Composer A: chips + rotator -->
    <div class="scene__composer" id="nviz-comp-empty">
      <div class="scene__chips">
        <span class="scene__chip">{isDE ? 'Prozesswissen' : 'Process knowledge'}</span>
        <span class="scene__chip">{isDE ? 'Operatives Know-how' : 'Operational know-how'}</span>
      </div>
      <div class="scene__input">
        <span class="scene__placeholder">
          <span id="nviz-rotator" data-qs={JSON.stringify(questions)}></span><span class="scene__caret"></span>
        </span>
        <span class="scene__send" set:html={sendIcon}/>
      </div>
    </div>

    <!-- Composer B: input where user message types before sending -->
    <div class="scene__composer nviz-hidden" id="nviz-comp-chat">
      <div class="scene__input">
        <span class="scene__placeholder">
          <span id="nviz-input-text"></span><span class="scene__caret" id="nviz-input-caret" style="display:none"></span>
        </span>
        <span class="scene__send" id="nviz-send-btn" set:html={sendIcon}/>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var scene    = document.getElementById('nviz-scene');
  var stEmpty  = document.getElementById('nviz-state-empty');
  var stChat   = document.getElementById('nviz-state-chat');
  var compE    = document.getElementById('nviz-comp-empty');
  var compC    = document.getElementById('nviz-comp-chat');
  var userRow  = document.getElementById('nviz-user-row');
  var lw       = document.getElementById('nviz-lw');
  var lo       = document.getElementById('nviz-lo');
  var rotEl    = document.getElementById('nviz-rotator');

  if (!scene) return;

  if (reduced) {
    // skip straight to chat state
    var rsvg = document.querySelector('.nviz__svg');
    if (rsvg) rsvg.style.opacity = '0';
    scene.style.cssText += 'opacity:1;transform:none;transition:none;';
    stEmpty.style.display  = 'none';
    compE.style.display    = 'none';
    stChat.style.display   = 'flex';
    compC.style.display    = 'flex';
    compC.classList.remove('nviz-hidden');
    if (userRow) userRow.style.opacity = '1';
    var at = document.getElementById('nviz-agent-text');
    var ut = document.getElementById('nviz-user-text');
    if (at) at.textContent = at.getAttribute('data-text') || '';
    if (ut) ut.textContent = ut.getAttribute('data-text') || '';
    return;
  }

  // ── InplicitLoader rAF ──
  var lraf = 0, ls = null;
  var LM = {x:539.95, y:543.84}, OFF = {x:38.85, y:42.71}, LR = 128.405, DEPTH = 0.13, DUR = 1400;
  function loaderTick(now) {
    if (ls === null) ls = now;
    var a = (((now - ls) % DUR) / DUR) * 2 * Math.PI;
    var c = Math.cos(a), s = Math.sin(a);
    lw.setAttribute('cx', (LM.x - OFF.x * c).toFixed(2));
    lw.setAttribute('cy', (LM.y - OFF.y * c).toFixed(2));
    lw.setAttribute('r',  (LR * (1 + DEPTH * s)).toFixed(2));
    lo.setAttribute('cx', (LM.x + OFF.x * c).toFixed(2));
    lo.setAttribute('cy', (LM.y + OFF.y * c).toFixed(2));
    lo.setAttribute('r',  (LR * (1 - DEPTH * s)).toFixed(2));
    var front = s >= 0 ? lw : lo;
    if (front.parentNode && front.parentNode.lastChild !== front) front.parentNode.appendChild(front);
    lraf = requestAnimationFrame(loaderTick);
  }

  // ── Placeholder rotator ──
  var rTimer = null;
  function startRotator() {
    if (!rotEl) return;
    var qs; try { qs = JSON.parse(rotEl.getAttribute('data-qs') || '[]'); } catch(e) { qs = []; }
    if (qs.length < 2) return;
    clearTimeout(rTimer);
    var qi2 = 0, ci2 = 0, deleting = false;
    function tick2() {
      var q = qs[qi2];
      if (!deleting) {
        rotEl.textContent = q.slice(0, ++ci2);
        if (ci2 >= q.length) { deleting = true; rTimer = setTimeout(tick2, 2000); }
        else rTimer = setTimeout(tick2, 50 + Math.random()*35);
      } else {
        rotEl.textContent = q.slice(0, --ci2);
        if (ci2 <= 0) { deleting = false; qi2 = (qi2+1) % qs.length; rTimer = setTimeout(tick2, 400); }
        else rTimer = setTimeout(tick2, 28);
      }
    }
    rTimer = setTimeout(tick2, 1200);
  }

  // ── Phase 1 → 2: fade the network out, show the chat card at 6 s ──
  var netSvg = document.querySelector('.nviz__svg');
  setTimeout(function () {
    if (netSvg) netSvg.style.opacity = '0';
    scene.style.opacity   = '1';
    scene.style.transform = 'translateY(0)';
    lraf = requestAnimationFrame(loaderTick);
    startRotator();
  }, 6000);

  // ── Phase 2 → 3: switch to chat at 12 s ──
  setTimeout(function () {
    stEmpty.style.display = 'none';
    compE.style.display   = 'none';
    clearTimeout(rTimer);
    cancelAnimationFrame(lraf);
    stChat.style.display = 'flex';
    compC.style.display  = 'flex';
    compC.classList.remove('nviz-hidden');

    // 1. Agent message appears instantly (no typing effect)
    var agentEl = document.getElementById('nviz-agent-text');
    if (agentEl) agentEl.textContent = agentEl.getAttribute('data-text') || '';
    var agentCaret = document.querySelector('.chat__agent-bubble .chat__caret');
    if (agentCaret) agentCaret.style.display = 'none';

    // 2. After agent done (~3.5 s), user types in the INPUT field
    setTimeout(function () {
      var inputEl  = document.getElementById('nviz-input-text');
      var inputCaret = document.getElementById('nviz-input-caret');
      var sendBtn  = document.getElementById('nviz-send-btn');
      var userTextEl = document.getElementById('nviz-user-text');
      var userCaretEl = document.getElementById('nviz-user-caret');
      if (!inputEl) return;
      var msg = (document.getElementById('nviz-user-text') || {}).getAttribute ?
                document.getElementById('nviz-user-text').getAttribute('data-text') || '' : '';
      // show caret in input
      if (inputCaret) inputCaret.style.display = 'inline-block';
      // type into input
      var i = 0;
      function typeInput() {
        inputEl.textContent = msg.slice(0, i++);
        if (i <= msg.length) {
          setTimeout(typeInput, 32 + Math.random() * 28);
        } else {
          // done typing — pause, flash send button, move to bubble
          setTimeout(function () {
            if (sendBtn) { sendBtn.style.transform = 'scale(0.88)'; sendBtn.style.transition = 'transform 0.12s'; }
            setTimeout(function () {
              if (sendBtn) sendBtn.style.transform = '';
              // clear input, hide caret
              inputEl.textContent = '';
              if (inputCaret) inputCaret.style.display = 'none';
              // show user bubble with text already there
              if (userTextEl) userTextEl.textContent = msg;
              if (userCaretEl) userCaretEl.style.display = 'none';
              if (userRow) userRow.style.opacity = '1';
            }, 160);
          }, 500);
        }
      }
      typeInput();
    }, 3800);
  }, 12000);
})();
</script>

<style>
  .nviz {
    position: relative;
    width: 100%;
  }
  .nviz__svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
    transition: opacity 0.6s ease;
  }

  /* Popup: absolute overlay exactly covering the SVG */
  .scene {
    position: absolute;
    /* Centered card — stays a fixed size even when the network graphic grows */
    inset: 0;
    margin: auto;
    width: min(94%, 340px);
    height: min(88%, 476px);
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    font-family: var(--font-family);
    /* initial invisible state — JS transitions in */
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.7s cubic-bezier(0.34, 1.1, 0.64, 1),
                transform 0.7s cubic-bezier(0.34, 1.1, 0.64, 1);
  }

  .nviz-hidden { display: none !important; }

  /* ── Network layer animations ── */
  /* Real org: profile photos appear first, then the lines; recedes as twin builds */
  .nviz-base { animation: nv-recede 1.6s ease-out 2.6s forwards; }
  .nv-nodes  { opacity: 0; animation: nv-in 0.9s ease-out 0.3s forwards; }
  .nv-edges  { opacity: 0; animation: nv-in 1.0s ease-out 1.2s forwards; }
  /* Digital twin: whole layer (incl. Inplicit logo) lifts off and floats */
  .nviz-orange {
    animation: nv-lift 3.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.9s forwards,
               nv-float 4s ease-in-out 5.3s infinite;
    transform: translateY(0);
  }

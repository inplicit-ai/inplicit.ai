---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const badges = isDE ? [
  { label: 'BR-Freigabe', value: '✓ Erteilt' },
  { label: 'DSGVO-konform', value: '✓ Bestätigt' },
  { label: 'EU-Server', value: 'Frankfurt' },
  { label: 'AVV unterzeichnet', value: '✓ Aktiv' },
  { label: 'Anonymitätsschwelle', value: 'Min. 5 MA' },
  { label: 'Datenlöschung', value: '90 Tage' },
] : [
  { label: 'Works council approval', value: '✓ Enforced' },
  { label: 'GDPR compliant', value: '✓ Confirmed' },
  { label: 'EU servers', value: 'Frankfurt' },
  { label: 'DPA signed', value: '✓ Active' },
  { label: 'Anonymity threshold', value: 'Min. 5 employees' },
  { label: 'Data deletion', value: '90 days' },
];

const principles = isDE ? [
  {
    title: 'BR-Freigabe technisch erzwungen',
    body: 'Kampagne startet nicht ohne Genehmigung. Der Betriebsrat hat immer das letzte Wort.',
  },
  {
    title: 'EU-Server Frankfurt',
    body: 'Kein US-Tool, kein Datentransfer. Alle Daten verbleiben auf EU-Servern in Frankfurt.',
  },
  {
    title: 'UUID-Token statt Klarnamen',
    body: 'Keine Rückverfolgung auf Personen. Antworten sind strukturell nicht mit Namen verknüpfbar.',
  },
  {
    title: 'Automatische Datenlöschung',
    body: 'Nach 90 Tagen oder sofort auf Anfrage. Keine Datengräber, kein stilles Speichern.',
  },
  {
    title: 'Privacy by Design nach DSGVO Art. 25',
    body: 'Datenschutz von Anfang an eingebaut, nicht nachträglich angeheftet.',
  },
] : [
  {
    title: 'Works-council approval enforced at system level',
    body: 'A campaign cannot start without sign-off. The works council always has the final word.',
  },
  {
    title: 'EU servers in Frankfurt',
    body: 'No US tools, no data transfers. All data stays on EU infrastructure in Frankfurt.',
  },
  {
    title: 'UUID tokens instead of names',
    body: 'Responses cannot be traced back to individuals. Anonymity is structural, not a policy promise.',
  },
  {
    title: 'Automatic data deletion',
    body: 'After 90 days or immediately on request. No data graveyards, no silent retention.',
  },
  {
    title: 'Privacy by Design (GDPR Art. 25)',
    body: 'Data protection is built in from day one, not bolted on after the fact.',
  },
];
---

<section class="dp" id="data-privacy">
  <div class="container">

    <div class="dp__header section-fade">
      <span class="dp__badge">
        {isDE ? 'Datenschutz & Compliance' : 'Privacy & Compliance'}
      </span>
      <h2 class="dp__heading">
        <span class="dp__line1">
          {isDE ? 'Vertrauen durch' : 'Trust through'}
        </span>
        <span class="dp__line2">
          {isDE ? 'Transparenz.' : 'Transparency.'}
        </span>
      </h2>
      <p class="dp__sub">
        {isDE
          ? 'inplicit ist von Grund auf für den deutschen Unternehmenskontext gebaut: Betriebsrat, DSGVO und EU AI Act.'
          : 'inplicit is built from the ground up for regulated enterprise environments: works council, GDPR, and EU AI Act compliance included.'}
      </p>
    </div>

    <div class="dp__checklist section-fade">
      {badges.map((b) => (
        <div class="dp__badge-item">
          <span class="dp__badge-label">{b.label}</span>
          <span class="dp__badge-value">{b.value}</span>
        </div>
      ))}
    </div>

    <div class="dp__principles">
      {principles.map((p, i) => (
        <div class="dp__principle section-fade" style={`--delay: ${i * 60}ms`}>
          <div class="dp__principle-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="dp__principle-body">
            <h3 class="dp__principle-title">{p.title}</h3>
            <p class="dp__principle-text">{p.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .dp {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .dp { padding: var(--space-24) 0; }
  }

  .dp__header {
    margin-bottom: var(--space-12);
    max-width: 620px;
  }

  .dp__badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-6);
    opacity: 0.85;
  }

  .dp__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    margin-bottom: var(--space-4);
  }

  .dp__line1 { color: var(--color-text-primary); }
  .dp__line2 { color: var(--color-text-primary); opacity: 0.3; }

  .dp__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Compliance checklist grid */
  .dp__checklist {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    margin-bottom: var(--space-4);
  }

  @media (min-width: 640px) {
    .dp__checklist { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .dp__checklist { grid-template-columns: repeat(6, 1fr); }
  }

  .dp__badge-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-surface);
  }

  .dp__badge-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .dp__badge-value {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Principles grid */
  .dp__principles {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  @media (min-width: 640px) {
    .dp__principles { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .dp__principles { grid-template-columns: repeat(3, 1fr); }
  }

  .dp__principle {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background-color: var(--color-surface);
    transition: border-color 0.2s var(--ease-smooth);
  }

  .dp__principle:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
  }

  .dp__principle-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-ui);
    background-color: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .dp__principle-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .dp__principle-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .dp__principle-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>

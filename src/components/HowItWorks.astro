---
import slackUrl    from '../assets/integrations/Slack.svg?url';
import microsoftUrl from '../assets/integrations/Microsoft.svg?url';
import celonisUrl  from '../assets/integrations/Celonis.svg?url';
import googleUrl   from '../assets/integrations/Google.svg?url';
import logoIconRaw from '../assets/logo_icon.svg?raw';
import logoIconUrl from '../assets/logo_icon.svg?url';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const steps = isDE ? [
  {
    num: '01',
    title: 'Wissensquellen anbinden',
    body: 'Verbinden Sie Slack, Outlook, Celonis, SAP oder andere Systeme. So hat die Interview-KI bereits vor dem ersten Gespräch den nötigen Kontext.',
  },
  {
    num: '02',
    title: 'KI-Interviews',
    body: 'KI-Interviews mit den richtigen Personen. Nicht die ganze Belegschaft, sondern gezielt nach Kontext und Rolle.',
  },
  {
    num: '03',
    title: 'Mustererkennung',
    body: 'Unser KI-System extrahiert Erkenntnisse und clustert Muster automatisch in Echtzeit - ohne manuelle Analyse.',
  },
  {
    num: '04',
    title: 'Wissenslandkarte',
    body: 'Eine strukturierte Wissenslandkarte mit belegten Insights und Originalzitaten - bereit für Entscheidungen.',
  },
] : [
  {
    num: '01',
    title: 'Connect your knowledge',
    body: 'Connect Slack, Outlook, Celonis, SAP or anything else your organisation runs on. The interview agent has context before the first conversation begins.',
  },
  {
    num: '02',
    title: 'AI Interviews',
    body: 'AI interviews with the right people. Not the entire workforce - targeted by context and role.',
  },
  {
    num: '03',
    title: 'Pattern recognition',
    body: 'Our AI extracts insights and clusters patterns automatically in real time - no manual analysis needed.',
  },
  {
    num: '04',
    title: 'Knowledge map',
    body: 'A structured knowledge map with verified insights and original quotes - ready for decisions.',
  },
];
---

<section class="hiw" id="how-it-works">
  <div class="container">

    <div class="hiw__header section-fade">
      <p class="section-eyebrow">{isDE ? 'So funktioniert Inplicit' : 'How Inplicit works'}</p>
      <h2 class="hiw__heading">
        <span>{isDE ? 'Verborgenes Wissen,' : 'Hidden knowledge,'}</span>
        <span class="hiw__heading-ghost">{isDE ? 'sichtbar gemacht.' : 'made visible.'}</span>
      </h2>
    </div>

    <div class="hiw__inner">

      <!-- ── Left: accordion ──────────────────────────── -->
        <div class="hiw__accordion" id="hiw-accordion">
          {steps.map((s, i) => (
            <button class={`hiw__item${i === 0 ? ' hiw__item--active' : ''}`} data-step={i} type="button">
              <div class="hiw__progress" aria-hidden="true"></div>
              <div class="hiw__item-inner">
                <span class="hiw__num">{s.num}</span>
                <div class="hiw__item-text">
                  <p class="hiw__item-title">{s.title}</p>
                  <div class="hiw__item-body">
                    <p>{s.body}</p>
                  </div>
                </div>
              </div>
            </button>
          ))}
        </div>

      <!-- ── Right: panels ───────────────────────────── -->
      <div class="hiw__right">
        <div class="hiw__panels">

          <!-- Panel 0: Integrations -->
          <div class="hiw__panel hiw__panel--active" data-step="0">
            <div class="mock mock--integrations">
              <div class="mock__chrome">
                <div class="mock__dots">
                  <span class="mock__dot mock__dot--r"></span>
                  <span class="mock__dot mock__dot--y"></span>
                  <span class="mock__dot mock__dot--g"></span>
                </div>
                <span class="mock__title">{isDE ? 'Wissensquellen' : 'Knowledge Sources'}</span>
              </div>
              <div class="mock__body">
                <div class="mock__conn-row">
                  <div class="mock__conn-logo"><img src={slackUrl} width="28" height="28" alt="" /></div>
                  <div class="mock__wf-content">
                    <span class="mock__wf-title">Slack</span>
                    <span class="mock__wf-sub">{isDE ? 'Workspace-Nachrichten' : 'Workspace messages'}</span>
                  </div>
                  <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
                </div>
                <div class="mock__conn-row">
                  <div class="mock__conn-logo"><img src={microsoftUrl} width="28" height="28" alt="" /></div>
                  <div class="mock__wf-content">
                    <span class="mock__wf-title">Microsoft 365</span>
                    <span class="mock__wf-sub">Outlook & Teams</span>
                  </div>
                  <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
                </div>
                <div class="mock__conn-row">
                  <div class="mock__conn-logo mock__conn-logo--celonis"><img src={celonisUrl} width="20" height="20" alt="" /></div>
                  <div class="mock__wf-content">
                    <span class="mock__wf-title">Celonis</span>
                    <span class="mock__wf-sub">{isDE ? 'Prozessdaten' : 'Process data'}</span>
                  </div>
                  <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
                </div>
                <div class="mock__conn-row">
                  <div class="mock__conn-logo"><img src={googleUrl} width="28" height="28" alt="" /></div>
                  <div class="mock__wf-content">
                    <span class="mock__wf-title">Google Workspace</span>
                    <span class="mock__wf-sub">{isDE ? 'Drive & Kalender' : 'Drive & Calendar'}</span>
                  </div>
                  <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
                </div>
                <div class="mock__conn-agent">
                  <div class="mock__conn-agent-icon" set:html={logoIconRaw} />
                  <div class="mock__wf-content">
                    <span class="mock__wf-title">inplicit Agent</span>
                    <span class="mock__wf-sub">{isDE ? '4 Quellen verbunden' : '4 sources connected'}</span>
                  </div>
                  <span class="mock__status-dot"></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 1: Interviews network graph -->
          <div class="hiw__panel" data-step="1">
            <div class="mock mock--network">
              <div class="mock__chrome">
                <div class="mock__dots">
                  <span class="mock__dot mock__dot--r"></span>
                  <span class="mock__dot mock__dot--y"></span>
                  <span class="mock__dot mock__dot--g"></span>
                </div>
                <span class="mock__title">{isDE ? 'Gespräche laufen' : 'Conversations running'}</span>
                <span class="mock__status-dot" style="margin-left:auto"></span>
              </div>
              <div class="mock__network-wrap" aria-hidden="true">
                <svg class="mock__network-svg" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <!-- Inactive spokes -->
                  <line x1="200" y1="150" x2="305" y2="150" stroke="var(--color-border)" stroke-width="1.2"/>
                  <line x1="200" y1="150" x2="274" y2="224" stroke="var(--color-border)" stroke-width="1.2"/>
                  <line x1="200" y1="150" x2="200" y2="255" stroke="var(--color-border)" stroke-width="1.2"/>
                  <line x1="200" y1="150" x2="95" y2="150" stroke="var(--color-border)" stroke-width="1.2"/>
                  <line x1="200" y1="150" x2="126" y2="76" stroke="var(--color-border)" stroke-width="1.2"/>
                  <!-- Active animated spokes (amber dashed) -->
                  <line class="net-spoke net-spoke--a" x1="200" y1="150" x2="126" y2="224" stroke="var(--color-accent)" stroke-width="1.2" stroke-dasharray="4 4"/>
                  <line class="net-spoke net-spoke--b" x1="200" y1="150" x2="274" y2="76" stroke="var(--color-accent)" stroke-width="1.2" stroke-dasharray="4 4"/>
                  <line class="net-spoke net-spoke--c" x1="200" y1="150" x2="200" y2="45" stroke="var(--color-accent)" stroke-width="1.2" stroke-dasharray="4 4"/>
                  <!-- People nodes: inactive -->
                  <!-- Right -->
                  <circle cx="305" cy="150" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1.2"/>
                  <circle cx="305" cy="144" r="6" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <path d="M293 162 C293 156 317 156 317 162" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <!-- Lower-right -->
                  <circle cx="274" cy="224" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1.2"/>
                  <circle cx="274" cy="218" r="6" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <path d="M262 236 C262 230 286 230 286 236" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <!-- Bottom -->
                  <circle cx="200" cy="255" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1.2"/>
                  <circle cx="200" cy="249" r="6" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <path d="M188 267 C188 261 212 261 212 267" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <!-- Left -->
                  <circle cx="95" cy="150" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1.2"/>
                  <circle cx="95" cy="144" r="6" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <path d="M83 162 C83 156 107 156 107 162" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <!-- Upper-left -->
                  <circle cx="126" cy="76" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1.2"/>
                  <circle cx="126" cy="70" r="6" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <path d="M114 88 C114 82 138 82 138 88" fill="var(--color-text-tertiary)" opacity="0.5"/>
                  <!-- Active nodes (amber ring) -->
                  <!-- Lower-left -->
                  <circle cx="126" cy="224" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-accent-muted)" stroke-width="1.5"/>
                  <circle cx="126" cy="218" r="6" fill="var(--color-accent)" opacity="0.7"/>
                  <path d="M114 236 C114 230 138 230 138 236" fill="var(--color-accent)" opacity="0.7"/>
                  <!-- Upper-right -->
                  <circle cx="274" cy="76" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-accent-muted)" stroke-width="1.5"/>
                  <circle cx="274" cy="70" r="6" fill="var(--color-accent)" opacity="0.7"/>
                  <path d="M262 88 C262 82 286 82 286 88" fill="var(--color-accent)" opacity="0.7"/>
                  <!-- Top -->
                  <circle cx="200" cy="45" r="22" fill="var(--color-surface-elevated)" stroke="var(--color-accent-muted)" stroke-width="1.5"/>
                  <circle cx="200" cy="39" r="6" fill="var(--color-accent)" opacity="0.7"/>
                  <path d="M188 57 C188 51 212 51 212 57" fill="var(--color-accent)" opacity="0.7"/>
                  <!-- Center hub: inplicit logo (bg circle hides spoke ends) -->
                  <circle cx="200" cy="150" r="30" fill="var(--color-bg)"/>
                  <image href={logoIconUrl} x="172" y="122" width="56" height="56"/>
                </svg>
                <div class="mock__network-label">
                  <span class="mock__wf-status mock__wf-status--active">●</span>
                  <span style="font-size:11px;color:var(--color-text-secondary)">{isDE ? '3 aktive Gespräche' : '3 active conversations'}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 2: Synthesis -->
          <div class="hiw__panel" data-step="2">
            <div class="mock mock--synthesis">
              <div class="mock__chrome">
                <div class="mock__dots">
                  <span class="mock__dot mock__dot--r"></span>
                  <span class="mock__dot mock__dot--y"></span>
                  <span class="mock__dot mock__dot--g"></span>
                </div>
                <span class="mock__title">{isDE ? 'Synthese läuft' : 'Synthesis running'}</span>
              </div>
              <div class="mock__synth-body">
                <div class="mock__synth-graph" aria-hidden="true">
                  <svg class="mock__synth-svg" viewBox="0 0 360 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Source nodes -->
                    <rect x="8" y="30" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <rect x="8" y="93" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <rect x="8" y="156" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <!-- Source labels -->
                    <text x="56" y="52" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Gespräche' : 'Conversations'}</text>
                    <text x="56" y="115" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Dokumente' : 'Documents'}</text>
                    <text x="56" y="178" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Systeme' : 'Systems'}</text>
                    <!-- Paths: source → hub (hub center at 200,110) -->
                    <path class="mock__synth-path mock__synth-path--1" d="M104 47 C160 47 162 110 185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="mock__synth-path mock__synth-path--2" d="M104 110 L185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="mock__synth-path mock__synth-path--3" d="M104 173 C160 173 162 110 185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <!-- Hub → output path -->
                    <path class="mock__synth-path mock__synth-path--out" d="M215 110 L262 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <!-- Center hub: inplicit logo (centered in viewBox) -->
                    <image href={logoIconUrl} x="176" y="86" width="48" height="48"/>
                    <!-- Output node: big count + label -->
                    <rect x="262" y="80" width="74" height="60" rx="10" fill="var(--color-surface-elevated)" stroke="var(--color-accent-muted)" stroke-width="1.5"/>
                    <text x="299" y="114" text-anchor="middle" font-size="23" font-weight="800" fill="var(--color-accent)" font-family="Inter, sans-serif" letter-spacing="-0.04em">14</text>
                    <text x="299" y="129" text-anchor="middle" font-size="8" font-weight="700" fill="var(--color-text-secondary)" font-family="Inter, sans-serif" letter-spacing="0.1em">{isDE ? 'SIGNALE' : 'INSIGHTS'}</text>
                  </svg>
                </div>
                <div class="mock__body" style="padding-top:0">
                  <div class="mock__wf-item mock__wf-item--done">
                    <div class="mock__wf-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Gespräche geführt' : 'Conversations completed'}</span>
                      <span class="mock__wf-sub">{isDE ? '1.247 Stimmen erfasst' : '1,247 voices recorded'}</span>
                    </div>
                    <span class="mock__wf-status mock__wf-status--done">{isDE ? 'Fertig' : 'Done'}</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--active">
                    <div class="mock__wf-icon mock__wf-icon--spin"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Aussagen kreuzvalidieren' : 'Cross-validating statements'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Probleme über Interviews abgleichen' : 'Matching problems across interviews'}</span>
                    </div>
                    <span class="mock__wf-status mock__wf-status--active">{isDE ? 'Aktiv' : 'Active'}</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--pending">
                    <div class="mock__wf-icon mock__wf-icon--pending"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Cluster werden gebildet' : 'Clusters forming'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Signalquellen werden verbunden' : 'Connecting signal sources'}</span>
                    </div>
                    <span class="mock__wf-status">{isDE ? 'Ausstehend' : 'Pending'}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 3: Output -->
          <div class="hiw__panel" data-step="3">
            <div class="hiw__stack" id="hiw-stack">

              <div class="mock mock--opps hiw__stack-win hiw__stack-win--back" id="win-b">
                <div class="mock__chrome">
                  <div class="mock__dots">
                    <span class="mock__dot mock__dot--r"></span>
                    <span class="mock__dot mock__dot--y"></span>
                    <span class="mock__dot mock__dot--g"></span>
                  </div>
                  <span class="mock__title">{isDE ? 'Chancen' : 'Opportunities'}</span>
                  <span class="mock__opp-badge">8 {isDE ? 'identifiziert' : 'identified'}</span>
                </div>
                <div class="mock__body">
                  <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                    <div class="mock__wf-icon mock__wf-icon--accent"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">Predictive Maintenance Hub</span>
                      <span class="mock__wf-sub">{isDE ? '89 Stimmen · Operations' : '89 voices · Operations'}</span>
                    </div>
                    <span class="mock__opp-conf mock__opp-conf--high">{isDE ? 'Hoch' : 'High'}</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                    <div class="mock__wf-icon mock__wf-icon--accent"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Smart Dokumentations-Engine' : 'Smart Documentation Engine'}</span>
                      <span class="mock__wf-sub">{isDE ? '4 h/Tag · Logistik & Admin' : '4h/day · Logistics & Admin'}</span>
                    </div>
                    <span class="mock__opp-conf mock__opp-conf--high">{isDE ? 'Hoch' : 'High'}</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                    <div class="mock__wf-icon mock__wf-icon--accent"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Internes Expertennetzwerk' : 'Internal Expert Network'}</span>
                      <span class="mock__wf-sub">{isDE ? '140 Spezialisten · HR & F&E' : '140 specialists · HR & R&D'}</span>
                    </div>
                    <span class="mock__opp-conf mock__opp-conf--mid">{isDE ? 'Mittel' : 'Medium'}</span>
                  </div>
                </div>
              </div>

              <div class="mock mock--output hiw__stack-win hiw__stack-win--front" id="win-a">
                <div class="mock__chrome">
                  <div class="mock__dots">
                    <span class="mock__dot mock__dot--r"></span>
                    <span class="mock__dot mock__dot--y"></span>
                    <span class="mock__dot mock__dot--g"></span>
                  </div>
                  <span class="mock__title">{isDE ? 'Ergebnisübersicht' : 'Results overview'}</span>
                </div>
                <div class="mock__body">
                  <div class="mock__wf-item mock__wf-item--done">
                    <div class="mock__wf-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Schmerzpunkte' : 'Pain Points'}</span>
                      <span class="mock__wf-sub">{isDE ? 'In 5 Teams identifiziert' : 'Identified across 5 teams'}</span>
                    </div>
                    <span class="mock__out-count">14</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                    <div class="mock__wf-icon mock__wf-icon--accent"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Chancen' : 'Opportunities'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Handlungsfelder bereit' : 'Action areas ready'}</span>
                    </div>
                    <span class="mock__out-count mock__out-count--accent">8</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--done">
                    <div class="mock__wf-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Prozesslücken' : 'Process Gaps'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Priorisiert nach Impact' : 'Prioritised by impact'}</span>
                    </div>
                    <span class="mock__out-count">11</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--done">
                    <div class="mock__wf-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Wissenskarte' : 'Knowledge Map'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Cluster visualisiert' : 'Clusters visualised'}</span>
                    </div>
                    <span class="mock__out-count">3</span>
                  </div>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function () {
  var DURATION = 6000;
  var accordion = document.getElementById('hiw-accordion');
  if (!accordion) return;

  var items = accordion.querySelectorAll('.hiw__item');
  var panels = document.querySelectorAll('.hiw__panel');
  var active = 0;
  var timer = null;
  // Desktop cycles through one full-width preview (+ swaps the output windows);
  // mobile shows every graphic stacked & static.
  var isMobile = window.matchMedia('(max-width: 900px)').matches;

  function activate(idx, restart) {
    // Update accordion items
    items.forEach(function (item, i) {
      var progress = item.querySelector('.hiw__progress');
      if (i === idx) {
        item.classList.add('hiw__item--active');
        // Reset then animate progress bar
        progress.style.transition = 'none';
        progress.style.height = '0%';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            progress.style.transition = 'height ' + DURATION + 'ms linear';
            progress.style.height = '100%';
          });
        });
      } else {
        item.classList.remove('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
      }
    });

    // Update panels
    panels.forEach(function (panel, i) {
      if (i === idx) {
        panel.classList.add('hiw__panel--active');
      } else {
        panel.classList.remove('hiw__panel--active');
      }
    });

    active = idx;

    if (restart !== false && !isMobile) {
      clearTimeout(timer);
      timer = setTimeout(function () {
        activate((active + 1) % items.length);
      }, DURATION);
    }
  }

  items.forEach(function (item, i) {
    item.addEventListener('click', function () {
      activate(i);
    });
  });

  // Start
  activate(0);

  // Step 04 stacked windows
  var stack = document.getElementById('hiw-stack');
  if (stack && !isMobile) {
    var winA = document.getElementById('win-a');
    var winB = document.getElementById('win-b');
    var aFront = true;
    var swapTimer;

    function swap() {
      aFront = !aFront;
      var incoming = aFront ? winA : winB;
      incoming.style.zIndex = '3';
      setTimeout(function () { incoming.style.zIndex = ''; }, 300);
      winA.className = 'mock mock--output hiw__stack-win ' + (aFront ? 'hiw__stack-win--front' : 'hiw__stack-win--back');
      winB.className = 'mock mock--opps hiw__stack-win ' + (aFront ? 'hiw__stack-win--back' : 'hiw__stack-win--front');
    }

    stack.addEventListener('click', function (e) {
      if (e.target.closest('.hiw__stack-win--back')) {
        swap();
        clearInterval(swapTimer);
        swapTimer = setInterval(swap, 4800);
      }
    });

    swapTimer = setInterval(swap, 4800);
  }
})();
</script>

<style>
  .hiw {
    padding: var(--space-section) 0 var(--space-4);

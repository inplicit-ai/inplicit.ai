---
import logoIconRaw from '../assets/logo_icon.svg?raw';
import logoIconUrl from '../assets/logo_icon.svg?url';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const steps = isDE ? [
  { num: '01', title: 'Setup',
    body: 'Beschreibe, was du erfahren willst und wer befragt wird. Der Setup-Agent macht daraus in Minuten eine fertige Kampagne.' },
  { num: '02', title: 'Interviews',
    body: 'Deine Mitarbeitenden sprechen mit dem Agenten. Ein Sprachgespräch von etwa 20 Minuten, anonym, wann es ihnen passt. Sie wissen, dass sie mit einer KI sprechen.' },
  { num: '03', title: 'Synthese',
    body: 'Jedes Interview wird zu strukturierten Signalen. Das System liest die Transkripte und indexiert, was die Belegschaft weiß.' },
  { num: '04', title: 'Lösungsvorschläge',
    body: 'Sieh das Problem, den Vorschlag deiner Mitarbeitenden und die Chance dahinter. Jede Karte führt zum genauen Zitat.' },
  { num: '05', title: 'Wissens-Chat',
    body: 'Durchsuche das Wissen und den Kontext deiner Organisation in normaler Sprache. Antworten kommen mit Belegen zu einer anonymen Quelle zurück.' },
  { num: '06', title: 'Autonome Recherche', beta: true,
    body: 'Wenn die Daten die Antwort noch nicht hergeben, holt Inplicit sie. Es startet eine gezielte Interview-Runde und meldet sich per E-Mail, sobald die Ergebnisse da sind.' },
] : [
  { num: '01', title: 'Setup',
    body: 'Describe what you want to learn and who gets asked. The setup agent turns it into a ready campaign in minutes.' },
  { num: '02', title: 'Interviews',
    body: 'Your workforce talks to the agent. A voice conversation of about 20 minutes, anonymous, on their own schedule. They are told they speak with an AI.' },
  { num: '03', title: 'Synthesis',
    body: 'Every interview becomes structured signals. The system reads the transcripts and indexes what the workforce knows.' },
  { num: '04', title: 'Solution suggestions',
    body: 'See the problem, the solution your workforce suggests, and the opportunity behind it. Every card links to the exact quote.' },
  { num: '05', title: 'Knowledge chat',
    body: "Search your organisation's knowledge and context in plain language. Answers come back with citations to an anonymous source." },
  { num: '06', title: 'Autonomous research', beta: true,
    body: 'If the data does not hold the answer yet, Inplicit goes and finds it. It runs a focused round of interviews and emails you when the results are ready.' },
];

// Explicit width/height so icons never balloon if scoped CSS fails to load.
const sendIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>';
const userIcon = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
---

<section class="hiw" id="how-it-works">
  <div class="container">

    <div class="hiw__header section-fade">
      <p class="section-eyebrow">{isDE ? 'So funktioniert Inplicit' : 'How Inplicit works'}</p>
      <h2 class="hiw__heading">
        <span>{isDE ? 'Verborgenes Wissen,' : 'Hidden knowledge,'}</span>
        <span class="hiw__heading-ghost">{isDE ? 'sichtbar gemacht.' : 'made visible.'}</span>
      </h2>
    </div>

    <div class="hiw__inner">

      <!-- ── Left: step list ──────────────────────────── -->
      <div class="hiw__accordion" id="hiw-accordion">
        {steps.map((s, i) => (
          <button class={`hiw__item${i === 0 ? ' hiw__item--active' : ''}`} data-step={i} type="button">
            <div class="hiw__progress" aria-hidden="true"></div>
            <div class="hiw__item-inner">
              <span class="hiw__num">{s.num}</span>
              <div class="hiw__item-text">
                <p class="hiw__item-title">
                  {s.title}
                  {s.beta ? <span class="hiw__beta">Beta</span> : null}
                </p>
                <div class="hiw__item-body"><p>{s.body}</p></div>
              </div>
            </div>
          </button>
        ))}
      </div>

      <!-- ── Right: scene previews mirroring the dashboard ── -->
      <div class="hiw__right">
        <div class="hiw__panels">

          <!-- Scene 0: Setup — the setup agent chat -->
          <div class="hiw__panel hiw__panel--active" data-step="0">
            <div class="scene" aria-hidden="true">
              <div class="scene__head">
                <span class="scene__avatar" set:html={logoIconRaw} />
                <div>
                  <div class="scene__head-title">Inplicit Agent</div>
                  <div class="scene__head-sub">{isDE ? 'Kampagnen-Planer' : 'Campaign planner'}</div>
                </div>
                <span class="scene__dot" style="margin-left:auto"></span>
              </div>
              <div class="chat">
                <div class="chat__scroll">
                  <div class="msg msg--user">
                    <span class="msg__av msg__av--user" set:html={userIcon} />
                    <div class="msg__bubble msg__bubble--user">{isDE ? 'Warum verlieren wir im Tagesgeschäft so viel Zeit?' : 'Why do we lose so much time in daily operations?'}</div>
                  </div>
                  <div class="msg msg--agent">
                    <span class="msg__av msg__av--agent" set:html={logoIconRaw} />
                    <div class="msg__bubble msg__bubble--agent">{isDE ? 'Ich habe eine Interview-Kampagne mit 8 Fragen für Operations und Logistik entworfen. Möchtest du sie ansehen?' : 'I drafted an interview campaign of 8 questions for Operations and Logistics. Want to review it?'}</div>
                  </div>
                </div>
                <div class="composer">
                  <div class="composer__chips">
                    <span class="composer__chip">{isDE ? 'Fragen ansehen' : 'Review questions'}</span>
                    <span class="composer__chip">{isDE ? 'Finance ergänzen' : 'Add Finance'}</span>
                  </div>
                  <div class="composer__input">
                    <span class="composer__placeholder">{isDE ? 'Antworte oder bitte den Assistenten, die Interview-Kampagne anzupassen…' : 'Reply or ask the assistant to adjust the interview campaign…'}</span>
                    <span class="composer__send" set:html={sendIcon} />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 1: Conversations — the interviewee voice room -->
          <div class="hiw__panel" data-step="1">
            <div class="scene" aria-hidden="true">
              <div class="iv__top">
                <span class="scene__dot scene__dot--live"></span>
                <span class="iv__clock">12:30 / 25:00</span>
                <span class="iv__actions">
                  <span class="iv__btn"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>{isDE ? 'Pause' : 'Pause'}</span>
                  <span class="iv__btn iv__btn--end"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="5" width="14" height="14" rx="2"/></svg>{isDE ? 'Beenden' : 'End'}</span>
                </span>
              </div>
              <div class="iv__stage">
                <div class="iv-orb" id="hiw-orb" aria-hidden="true"></div>
                <div class="iv__hud">
                  <span class="iv__status"><span class="scene__dot scene__dot--live"></span>{isDE ? 'Hört zu' : 'Listening'}</span>
                  <span class="iv__phase">{isDE ? 'Phase 1 · Offen' : 'Phase 1 · Open'}</span>
                  <span class="iv__conn"><span class="iv__conn-dot"></span>{isDE ? 'Verbunden' : 'Connected'}</span>
                </div>
                <div class="iv__note">{isDE ? 'KI-Agent · anonym · kein Mensch' : 'AI agent · anonymous · not a human'}</div>
              </div>
              <div class="iv__bottom">
                <span class="iv__mute"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4"/></svg></span>
                <span class="iv__switch"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>{isDE ? 'Zu Chat wechseln' : 'Switch to chat'}</span>
              </div>
            </div>
          </div>

          <!-- Scene 2: Synthesis — the animated signal-flow graphic -->
          <div class="hiw__panel" data-step="2">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">{isDE ? 'Synthese läuft' : 'Synthesis running'}</div><span class="scene__dot scene__dot--live" style="margin-left:auto"></span></div>
              <div class="synth">
                <div class="synth__graph">
                  <svg class="synth__svg" viewBox="0 0 360 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="8" y="30" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <rect x="8" y="93" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <rect x="8" y="156" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <text x="56" y="52" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Interviews' : 'Interviews'}</text>
                    <text x="56" y="115" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Dokumente' : 'Documents'}</text>
                    <text x="56" y="178" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Systeme' : 'Systems'}</text>
                    <path class="synth__path synth__path--1" d="M104 47 C160 47 162 110 185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="synth__path synth__path--2" d="M104 110 L185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="synth__path synth__path--3" d="M104 173 C160 173 162 110 185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="synth__path synth__path--out" d="M215 110 L262 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <image href={logoIconUrl} x="176" y="86" width="48" height="48"/>
                    <rect x="262" y="80" width="74" height="60" rx="10" fill="var(--color-surface-elevated)" stroke="var(--color-accent-muted)" stroke-width="1.5"/>
                    <text x="299" y="114" text-anchor="middle" font-size="23" font-weight="800" fill="var(--color-accent)" font-family="Inter, sans-serif" letter-spacing="-0.04em">14</text>
                    <text x="299" y="129" text-anchor="middle" font-size="8" font-weight="700" fill="var(--color-text-secondary)" font-family="Inter, sans-serif" letter-spacing="0.1em">{isDE ? 'SIGNALE' : 'INSIGHTS'}</text>
                  </svg>
                </div>
                <div class="synth__list">
                  <div class="synth__step synth__step--done">
                    <span class="synth__ic"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></span>
                    <span class="synth__txt">{isDE ? 'Interviews gelesen' : 'Interviews read'}</span>
                    <span class="synth__tag synth__tag--done">{isDE ? 'Fertig' : 'Done'}</span>
                  </div>
                  <div class="synth__step synth__step--active">
                    <span class="synth__ic synth__ic--spin"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg></span>
                    <span class="synth__txt">{isDE ? 'Signale extrahiert' : 'Signals extracted'}</span>
                    <span class="synth__tag synth__tag--active">{isDE ? 'Aktiv' : 'Active'}</span>
                  </div>
                  <div class="synth__step">
                    <span class="synth__ic"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg></span>
                    <span class="synth__txt">{isDE ? 'Muster gruppiert' : 'Patterns grouped'}</span>
                    <span class="synth__tag">{isDE ? 'Ausstehend' : 'Pending'}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 3: Suggestions — the insights triad card -->
          <div class="hiw__panel" data-step="3">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">Insights</div></div>
              <div class="ins">
                <div class="ins__card">
                  <div class="ins__cardhead">
                    <div class="ins__badges"><span class="dept">Operations</span><span class="dept">{isDE ? 'Offene Phase' : 'Open phase'}</span></div>
                    <span class="ins__rank">#1</span>
                  </div>
                  <div class="ins__rows">
                    <div class="ins__row"><span class="tlabel tlabel--problem">Problem</span><span class="ttext">{isDE ? 'Auftragsexport braucht drei Tools und eine manuelle Prüfung.' : 'Order export needs three tools and a manual check.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--idea">{isDE ? 'Idee' : 'Idea'}</span><span class="ttext">{isDE ? 'Eine Export-Ansicht, die die drei Quellen zusammenführt.' : 'One export view that merges the three sources.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--opp">{isDE ? 'Chance' : 'Opportunity'}</span><span class="ttext">{isDE ? 'Etwa 4 Stunden pro Woche pro Mitarbeiter.' : 'About 4 hours a week per operator.'}</span></div>
                  </div>
                </div>
                <div class="ins__card">
                  <div class="ins__cardhead">
                    <div class="ins__badges"><span class="dept">HR</span><span class="dept">{isDE ? 'Offene Phase' : 'Open phase'}</span></div>
                    <span class="ins__rank">#2</span>
                  </div>
                  <div class="ins__rows">
                    <div class="ins__row"><span class="tlabel tlabel--problem">Problem</span><span class="ttext">{isDE ? 'Neue Mitarbeitende warten Tage auf Systemzugang.' : 'New hires wait days for system access.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--idea">{isDE ? 'Idee (AI)' : 'Idea (AI)'}</span><span class="ttext">{isDE ? 'Zugang aus dem unterschriebenen Vertrag auslösen.' : 'Trigger access from the signed contract.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--opp">{isDE ? 'Chance' : 'Opportunity'}</span><span class="ttext">{isDE ? 'Schnellere erste Woche, weniger Leerlauf.' : 'Faster first week, less idle time.'}</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 4: Knowledge chat — answer grounded in one exact quote -->
          <div class="hiw__panel" data-step="4">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">{isDE ? 'Wissens-Chat' : 'Knowledge chat'}</div><span class="scene__dot" style="margin-left:auto"></span></div>
              <div class="chat">
                <div class="chat__scroll">
                  <div class="msg msg--user">
                    <span class="msg__av msg__av--user" set:html={userIcon} />
                    <div class="msg__bubble msg__bubble--user">{isDE ? 'Hat jemand im Rechtsbereich Onboarding-Probleme erwähnt?' : 'Did anyone in Legal mention onboarding pain?'}</div>
                  </div>
                  <div class="msg msg--agent">
                    <span class="msg__av msg__av--agent" set:html={logoIconRaw} />
                    <div class="msg__bubble msg__bubble--agent">
                      {isDE ? 'Ja. Eine Person im Rechtsbereich beschreibt einen langsamen Zugangsprozess in ihrer ersten Woche:' : 'Yes. One person in Legal describes a slow access process in their first week:'}
                      <a class="msg-quote">
                        <span class="msg-quote__text">{isDE ? '„Es dauerte sechs Tage, bis ich eine einzige Akte öffnen konnte.“' : '“It took six days before I could open a single case file.”'}</span>
                        <span class="cite">ANON-3F2 · #14</span>
                      </a>
                      <div class="ai-note">{isDE ? 'KI-generiert aus anonymisierten Interviewdaten' : 'AI-generated from anonymized interview data'}</div>
                    </div>
                  </div>
                </div>
                <div class="composer">
                  <div class="composer__input">
                    <span class="composer__placeholder">{isDE ? 'Frag zu dieser Kampagne…' : 'Ask about this campaign…'}</span>
                    <span class="composer__send" set:html={sendIcon} />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 5: Autonomous research (Beta) — same chat, loop closes -->
          <div class="hiw__panel" data-step="5">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">{isDE ? 'Wissens-Chat' : 'Knowledge chat'}</div><span class="scene__beta" style="margin-left:auto">Beta</span></div>
              <div class="chat">
                <div class="chat__scroll">
                  <div class="msg msg--user">
                    <span class="msg__av msg__av--user" set:html={userIcon} />
                    <div class="msg__bubble msg__bubble--user">{isDE ? 'Wie regeln Nachtschichten die Übergabe?' : 'How do night shifts handle handover?'}</div>
                  </div>
                  <div class="msg msg--agent">
                    <span class="msg__av msg__av--agent" set:html={logoIconRaw} />
                    <div class="msg__bubble msg__bubble--agent">
                      {isDE ? 'Dazu habe ich noch keine Antwort in den Daten. Soll ich neue Interviews an Personen schicken, die das beantworten können?' : 'I have no answer in the data yet. Want me to send out new interviews to people who could answer?'}
                      <div class="choices">
                        <span class="choice choice--on">{isDE ? 'Ja, losschicken' : 'Yes, send them out'}</span>
                        <span class="choice">{isDE ? 'Später' : 'Not now'}</span>
                      </div>
                    </div>
                  </div>
                  <div class="msg msg--user">
                    <span class="msg__av msg__av--user" set:html={userIcon} />
                    <div class="msg__bubble msg__bubble--user">{isDE ? 'Ja, losschicken' : 'Yes, send them out'}</div>
                  </div>
                  <div class="msg msg--agent">
                    <span class="msg__av msg__av--agent" set:html={logoIconRaw} />
                    <div class="msg__bubble msg__bubble--agent">
                      {isDE ? 'Eine gezielte Runde mit 8 Personen in der Logistik läuft. Ich melde mich per E-Mail, sobald die Ergebnisse da sind.' : 'A focused round with 8 people in Logistics is running. I will email you when the results are ready.'}
                      <div class="lp-status"><span class="research__pulse"></span>{isDE ? '5 von 8 abgeschlossen' : '5 of 8 completed'}</div>
                    </div>
                  </div>
                </div>
                <div class="composer">
                  <div class="composer__input">
                    <span class="composer__placeholder">{isDE ? 'Frag zu dieser Kampagne…' : 'Ask about this campaign…'}</span>
                    <span class="composer__send" set:html={sendIcon} />
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function () {
  var DURATION = 6000;
  var accordion = document.getElementById('hiw-accordion');
  if (!accordion) return;

  var items = accordion.querySelectorAll('.hiw__item');
  var panels = document.querySelectorAll('.hiw__panel');
  var active = 0;
  var timer = null;
  var isMobile = window.matchMedia('(max-width: 1023px)').matches;

  function activate(idx, restart) {
    items.forEach(function (item, i) {
      var progress = item.querySelector('.hiw__progress');
      if (i === idx) {
        item.classList.add('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            progress.style.transition = 'height ' + DURATION + 'ms linear';
            progress.style.height = '100%';
          });
        });
      } else {
        item.classList.remove('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
      }
    });

    panels.forEach(function (panel, i) {
      panel.classList.toggle('hiw__panel--active', i === idx);
    });

    active = idx;

    if (restart !== false && !isMobile) {
      clearTimeout(timer);
      timer = setTimeout(function () {
        activate((active + 1) % items.length);
      }, DURATION);
    }
  }

  items.forEach(function (item, i) {
    item.addEventListener('click', function () { activate(i); });
  });

  var section = document.getElementById('how-it-works');
  requestAnimationFrame(function () {
    if (section) section.classList.add('is-ready');
    activate(0);
  });
})();
</script>

<script is:inline>
/* Interview-room orb — the dashboard AgentOrb (OGL) shader, ported to vanilla
   WebGL. Idle (audio level 0): the shader still animates via iTime (noise +
   orbiting light) with a slow base rotation. Falls back to the CSS orb when
   WebGL is unavailable or reduced-motion is set. */
(function () {
  var host = document.getElementById('hiw-orb');
  if (!host) return;
  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function fallback() {
    host.innerHTML = '<span class="iv-cssorb"><span class="iv-cssorb__core"></span><span class="iv-cssorb__ring"></span></span>';
  }
  var canvas = document.createElement('canvas');
  var gl = null;
  try {
    var opts = { alpha: true, premultipliedAlpha: false, antialias: true };
    gl = canvas.getContext('webgl', opts) || canvas.getContext('experimental-webgl', opts);
  } catch (e) { gl = null; }
  if (!gl || reduced) { fallback(); return; }

  var VERT = 'precision highp float;\n' +
    'attribute vec2 position;\n' +
    'attribute vec2 uv;\n' +
    'varying vec2 vUv;\n' +
    'void main(){ vUv = uv; gl_Position = vec4(position, 0.0, 1.0); }';

  var FRAG = `
  precision highp float;
  uniform float iTime;
  uniform vec3 iResolution;
  uniform float hue;
  uniform float hover;
  uniform float rot;
  uniform float hoverIntensity;
  varying vec2 vUv;
  vec3 rgb2yiq(vec3 c){ float y=dot(c,vec3(0.299,0.587,0.114)); float i=dot(c,vec3(0.596,-0.274,-0.322)); float q=dot(c,vec3(0.211,-0.523,0.312)); return vec3(y,i,q); }
  vec3 yiq2rgb(vec3 c){ float r=c.x+0.956*c.y+0.621*c.z; float g=c.x-0.272*c.y-0.647*c.z; float b=c.x-1.106*c.y+1.703*c.z; return vec3(r,g,b); }
  vec3 adjustHue(vec3 color, float hueDeg){ float hueRad=hueDeg*3.14159265/180.0; vec3 yiq=rgb2yiq(color); float cosA=cos(hueRad); float sinA=sin(hueRad); float i=yiq.y*cosA-yiq.z*sinA; float q=yiq.y*sinA+yiq.z*cosA; yiq.y=i; yiq.z=q; return yiq2rgb(yiq); }
  vec3 hash33(vec3 p3){ p3=fract(p3*vec3(0.1031,0.11369,0.13787)); p3+=dot(p3,p3.yxz+19.19); return -1.0+2.0*fract(vec3(p3.x+p3.y,p3.x+p3.z,p3.y+p3.z)*p3.zyx); }

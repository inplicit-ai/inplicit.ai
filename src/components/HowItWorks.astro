---
import slackUrl    from '../assets/integrations/Slack.svg?url';
import microsoftUrl from '../assets/integrations/Microsoft.svg?url';
import celonisUrl  from '../assets/integrations/Celonis.svg?url';
import googleUrl   from '../assets/integrations/Google.svg?url';
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';
---

<section class="hiw" id="how-it-works">
  <div class="container">

    <div class="hiw__header section-fade">
      <p class="hiw__eyebrow">{isDE ? 'Wie es funktioniert' : 'How it works'}</p>
      <h2 class="hiw__heading">
        <span class="hiw__line1">{isDE ? 'Vier Schritte.' : 'Four steps.'}</span>
        <span class="hiw__line2">{isDE ? 'Vom Start zur Klarheit.' : 'From setup to clarity.'}</span>
      </h2>
    </div>

    <!-- Step 01: Connect knowledge -->
    <div class="hiw__step hiw__step--odd section-fade">
      <div class="hiw__ghost" aria-hidden="true">01</div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 01' : 'Step 01'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Bestehende Wissensquellen anbinden' : 'Connect your existing knowledge'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Verbinden Sie Ihre vorhandenen Datenquellen: Slack, Outlook, Celonis, SAP oder jedes andere System, auf dem Ihre Organisation läuft. So weiß unsere Interview-KI bereits vor dem ersten Gespräch den nötigen Kontext.'
            : 'Start by connecting your explicit knowledge sources. Slack, Outlook, Celonis, SAP or anything else your organisation runs on. This gives the interview agent context before the first conversation begins.'}
        </p>
      </div>
      <div class="hiw__mockup">
        <div class="mock mock--integrations">
          <div class="mock__chrome">
            <div class="mock__dots">
              <span class="mock__dot mock__dot--r"></span>
              <span class="mock__dot mock__dot--y"></span>
              <span class="mock__dot mock__dot--g"></span>
            </div>
            <span class="mock__title">{isDE ? 'Wissensquellen' : 'Knowledge Sources'}</span>
          </div>
          <div class="mock__body">
            <div class="mock__conn-row">
              <div class="mock__conn-logo">
                <img src={slackUrl} width="28" height="28" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Slack</span>
                <span class="mock__wf-sub">{isDE ? 'Workspace-Nachrichten' : 'Workspace messages'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-row">
              <div class="mock__conn-logo">
                <img src={microsoftUrl} width="28" height="28" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Microsoft 365</span>
                <span class="mock__wf-sub">{isDE ? 'Outlook & Teams' : 'Outlook & Teams'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-row">
              <div class="mock__conn-logo mock__conn-logo--celonis">
                <img src={celonisUrl} width="20" height="20" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Celonis</span>
                <span class="mock__wf-sub">{isDE ? 'Prozessdaten' : 'Process data'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-row">
              <div class="mock__conn-logo">
                <img src={googleUrl} width="28" height="28" alt="" aria-hidden="true" />
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">Google Workspace</span>
                <span class="mock__wf-sub">{isDE ? 'Drive & Kalender' : 'Drive & Calendar'}</span>
              </div>
              <span class="mock__conn-pill">{isDE ? 'Verbunden' : 'Connected'}</span>
            </div>
            <div class="mock__conn-agent">
              <div class="mock__conn-agent-icon" set:html={logoIconRaw} />
              <div class="mock__wf-content">
                <span class="mock__wf-title">inplicit Agent</span>
                <span class="mock__wf-sub">{isDE ? '4 Quellen verbunden' : '4 sources connected'}</span>
              </div>
              <span class="mock__status-dot"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 02: Conversations -->
    <div class="hiw__step hiw__step--even section-fade">
      <div class="hiw__ghost" aria-hidden="true">02</div>
      <div class="hiw__mockup">
        <div class="hiw__gallery" id="hiw-gallery-02">

          <div class="hiw__gallery-tabs">
            <button class="hiw__gallery-tab hiw__gallery-tab--active" data-idx="0">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.37 2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.62a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
              {isDE ? 'Call' : 'Call'}
            </button>
            <button class="hiw__gallery-tab" data-idx="1">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Chat
            </button>
          </div>

          <!-- Panel: Video call -->
          <div class="mock mock--video hiw__gallery-panel hiw__gallery-panel--active">
            <div class="mock__video-grid">
              <div class="mock__video-tile">
                <div class="mock__video-avatar">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                  </svg>
                </div>
                <span class="mock__video-label">{isDE ? 'Mitarbeitende' : 'Employee'}</span>
              </div>
              <div class="mock__video-tile mock__video-tile--ai">
                <div class="mock__video-logo">
                  <span class="mock__agent-icon" set:html={logoIconRaw} />
                </div>
                <span class="mock__video-label">inplicit Agent</span>
              </div>
            </div>
            <div class="mock__video-bar">
              <span class="mock__video-time">5:54</span>
              <div class="mock__video-controls">
                <button class="mock__ctrl" aria-label="mute">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/>
                  </svg>
                </button>
                <button class="mock__ctrl mock__ctrl--end" aria-label="end call">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.37 2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.62a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Panel: Chat -->
          <div class="mock mock--chat hiw__gallery-panel">
            <div class="mock__chrome">
              <div class="mock__dots">
                <span class="mock__dot mock__dot--r"></span>
                <span class="mock__dot mock__dot--y"></span>
                <span class="mock__dot mock__dot--g"></span>
              </div>
              <span class="mock__title">inplicit Agent</span>
              <span class="mock__status-dot" style="margin-left:auto"></span>
            </div>
            <div class="mock__chat-body">
              <div class="mock__msg mock__msg--agent">
                <span class="mock__msg-icon" set:html={logoIconRaw} />
                <div class="mock__msg-bubble">
                  {isDE ? 'Welcher Prozess bremst Ihr Team am stärksten?' : 'Which process slows your team down the most?'}
                </div>
              </div>
              <div class="mock__msg mock__msg--user">
                <div class="mock__msg-bubble">
                  {isDE ? 'Abteilungsübergreifende Freigaben. Keine klare Verantwortung.' : 'Cross-team sign-offs. No single owner.'}
                </div>
                <div class="mock__msg-avatar">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                </div>
              </div>
              <div class="mock__msg mock__msg--agent">
                <span class="mock__msg-icon" set:html={logoIconRaw} />
                <div class="mock__msg-bubble">
                  {isDE ? 'Wie oft verzögert das einen Projektstart?' : 'How often does that delay a project launch?'}
                </div>
              </div>
              <div class="mock__msg mock__msg--user">
                <div class="mock__msg-bubble">
                  {isDE ? 'Fast immer. Wir planen mittlerweile 3 Wochen Puffer ein.' : 'Almost every time. We build in 3 weeks of buffer now.'}
                </div>
                <div class="mock__msg-avatar">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                </div>
              </div>
              <div class="mock__typing">
                <span class="mock__msg-icon" set:html={logoIconRaw} />
                <div class="mock__typing-dots"><span></span><span></span><span></span></div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 02' : 'Step 02'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'KI-Interviews mit der gesamten Belegschaft' : 'Conversations that actually listen'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Unsere KI spricht mit allen Mitarbeitenden. Dabei passt sie sich in Echtzeit dem Kontext und den Antworten der interviewten Person an. So kann sie auch gute Nachfragen stellen, um implizites Wissen herauszufinden.'
            : 'AI agents talk with everyone in the organisation, not just leadership. Every statement is cross-validated, not just recorded. The result is a picture that is honest.'}
        </p>
        <div class="hiw__stats">
          <div class="hiw__stat">
            <span class="hiw__stat-num">100+</span>
            <span class="hiw__stat-label">{isDE ? 'Gespräche in Stunden' : 'Conversations in hours'}</span>
          </div>
          <div class="hiw__stat">
            <span class="hiw__stat-num">100%</span>
            <span class="hiw__stat-label">{isDE ? 'der Belegschaft erreichbar' : 'Of workforce reached'}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 03: Synthesis -->
    <div class="hiw__step hiw__step--odd section-fade">
      <div class="hiw__ghost" aria-hidden="true">03</div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 03' : 'Step 03'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Muster werden sichtbar' : 'Results come together'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Unsere KI kann hunderte Gespräche gleichzeitig führen und verarbeiten. Die KI erkennt Muster, bildet Cluster und filtert die wichtigsten Signale heraus - ohne manuelle Auswertung, ohne Wartezeit.'
            : 'Hundreds of conversations happen at once. The AI spots patterns, forms clusters, and separates signal from noise. No manual analysis, no days of waiting.'}
        </p>
        <div class="hiw__stats">
          <div class="hiw__stat">
            <span class="hiw__stat-num">{isDE ? '3–4' : '4'}</span>
            <span class="hiw__stat-label">{isDE ? 'Tage bis zu ersten Erkenntnissen' : 'Hours to first insights'}</span>
          </div>
          <div class="hiw__stat">
            <span class="hiw__stat-num">0</span>
            <span class="hiw__stat-label">{isDE ? 'Keine manuelle Analyse' : 'Manual analysis needed'}</span>
          </div>
        </div>
      </div>
      <div class="hiw__mockup">
        <div class="mock mock--workflow">
          <div class="mock__chrome">
            <div class="mock__dots">
              <span class="mock__dot mock__dot--r"></span>
              <span class="mock__dot mock__dot--y"></span>
              <span class="mock__dot mock__dot--g"></span>
            </div>
            <span class="mock__title">{isDE ? 'Synthese läuft' : 'Synthesis running'}</span>
          </div>
          <div class="mock__body">
            <div class="mock__wf-item mock__wf-item--done">
              <div class="mock__wf-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Gespräche geführt' : 'Conversations completed'}</span>
                <span class="mock__wf-sub">{isDE ? '1.247 Stimmen erfasst' : '1,247 voices recorded'}</span>
              </div>
              <span class="mock__wf-status mock__wf-status--done">{isDE ? 'Fertig' : 'Done'}</span>
            </div>
            <div class="mock__wf-item mock__wf-item--active">
              <div class="mock__wf-icon mock__wf-icon--spin">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Aussagen kreuzvalidieren' : 'Cross-validating statements'}</span>
                <span class="mock__wf-sub">{isDE ? 'Probleme über Interviews abgleichen' : 'Matching problems across interviews'}</span>
              </div>
              <span class="mock__wf-status mock__wf-status--active">{isDE ? 'Aktiv' : 'Active'}</span>
            </div>
            <div class="mock__wf-item mock__wf-item--pending">
              <div class="mock__wf-icon mock__wf-icon--pending">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Cluster werden gebildet' : 'Clusters forming'}</span>
                <span class="mock__wf-sub">{isDE ? 'Signalquellen werden verbunden' : 'Connecting signal sources'}</span>
              </div>
              <span class="mock__wf-status">{isDE ? 'Ausstehend' : 'Pending'}</span>
            </div>
            <div class="mock__wf-item mock__wf-item--pending">
              <div class="mock__wf-icon mock__wf-icon--pending">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
              </div>
              <div class="mock__wf-content">
                <span class="mock__wf-title">{isDE ? 'Erkenntnisse generieren' : 'Generating insights'}</span>
                <span class="mock__wf-sub">{isDE ? 'Bereitet Ergebnisse vor' : 'Preparing your output'}</span>
              </div>
              <span class="mock__wf-status">{isDE ? 'Ausstehend' : 'Pending'}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 04: Output picture -->
    <div class="hiw__step hiw__step--even section-fade">
      <div class="hiw__ghost" aria-hidden="true">04</div>
      <div class="hiw__mockup hiw__mockup--stack">
        <div class="hiw__stack" id="hiw-stack-04">

          <!-- Window B: Opportunities (starts behind) -->
          <div class="mock mock--opps hiw__stack-win hiw__stack-win--back" id="win-b">
            <div class="mock__chrome">
              <div class="mock__dots">
                <span class="mock__dot mock__dot--r"></span>
                <span class="mock__dot mock__dot--y"></span>
                <span class="mock__dot mock__dot--g"></span>
              </div>
              <span class="mock__title">{isDE ? 'Chancen' : 'Opportunities'}</span>
              <span class="mock__opp-badge">8 {isDE ? 'identifiziert' : 'identified'}</span>
            </div>
            <div class="mock__body">
              <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                <div class="mock__wf-icon mock__wf-icon--accent">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Predictive Maintenance Hub' : 'Predictive Maintenance Hub'}</span>
                  <span class="mock__wf-sub">{isDE ? '89 Stimmen · Operations' : '89 voices · Operations'}</span>
                </div>
                <span class="mock__opp-conf mock__opp-conf--high">{isDE ? 'Hoch' : 'High'}</span>
              </div>
              <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                <div class="mock__wf-icon mock__wf-icon--accent">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Smart Dokumentations-Engine' : 'Smart Documentation Engine'}</span>
                  <span class="mock__wf-sub">{isDE ? '4 h/Tag · Logistik & Admin' : '4h/day · Logistics & Admin'}</span>
                </div>
                <span class="mock__opp-conf mock__opp-conf--high">{isDE ? 'Hoch' : 'High'}</span>
              </div>
              <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                <div class="mock__wf-icon mock__wf-icon--accent">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Internes Expertennetzwerk' : 'Internal Expert Network'}</span>
                  <span class="mock__wf-sub">{isDE ? '140 Spezialisten · HR & F&E' : '140 specialists · HR & R&D'}</span>
                </div>
                <span class="mock__opp-conf mock__opp-conf--mid">{isDE ? 'Mittel' : 'Medium'}</span>
              </div>
            </div>
          </div>

          <!-- Window A: Results overview (starts in front) -->
          <div class="mock mock--output hiw__stack-win hiw__stack-win--front" id="win-a">
            <div class="mock__chrome">
              <div class="mock__dots">
                <span class="mock__dot mock__dot--r"></span>
                <span class="mock__dot mock__dot--y"></span>
                <span class="mock__dot mock__dot--g"></span>
              </div>
              <span class="mock__title">{isDE ? 'Ergebnisübersicht' : 'Results overview'}</span>
            </div>
            <div class="mock__body">
              <div class="mock__wf-item mock__wf-item--done">
                <div class="mock__wf-icon">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Schmerzpunkte' : 'Pain Points'}</span>
                  <span class="mock__wf-sub">{isDE ? 'In 5 Teams identifiziert' : 'Identified across 5 teams'}</span>
                </div>
                <span class="mock__out-count">14</span>
              </div>
              <div class="mock__wf-item mock__wf-item--done mock__wf-item--accent">
                <div class="mock__wf-icon mock__wf-icon--accent">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Chancen' : 'Opportunities'}</span>
                  <span class="mock__wf-sub">{isDE ? 'Handlungsfelder bereit' : 'Action areas ready'}</span>
                </div>
                <span class="mock__out-count mock__out-count--accent">8</span>
              </div>
              <div class="mock__wf-item mock__wf-item--done">
                <div class="mock__wf-icon">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Prozesslücken' : 'Process Gaps'}</span>
                  <span class="mock__wf-sub">{isDE ? 'Priorisiert nach Impact' : 'Prioritised by impact'}</span>
                </div>
                <span class="mock__out-count">11</span>
              </div>
              <div class="mock__wf-item mock__wf-item--done">
                <div class="mock__wf-icon">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <div class="mock__wf-content">
                  <span class="mock__wf-title">{isDE ? 'Wissenskarte' : 'Knowledge Map'}</span>
                  <span class="mock__wf-sub">{isDE ? 'Cluster visualisiert' : 'Clusters visualised'}</span>
                </div>
                <span class="mock__out-count">3</span>
              </div>
            </div>
          </div>

        </div>
      </div>
      <div class="hiw__text">
        <p class="hiw__step-eyebrow">{isDE ? 'Schritt 04' : 'Step 04'}</p>
        <h3 class="hiw__step-heading">{isDE ? 'Sie sehen das vollständige Bild' : 'You see the full picture'}</h3>
        <p class="hiw__step-body">
          {isDE
            ? 'Sie erhalten alle Schwachstellen und Prozessineffizienzen, aber auch Innovationspotentiale und konkrete nächste Schritte in einem Maßnahmenplan - strukturiert, priorisiert und mit Einsparpotential.'
            : 'Pain points, opportunities, process gaps, and a knowledge map. Organised, prioritised, and ready for decisions. No 60-page report that nobody reads.'}
        </p>
      </div>
    </div>

  </div>
</section>

<script is:inline>
(function () {
  var g = document.getElementById('hiw-gallery-02');
  if (!g) return;
  var panels = g.querySelectorAll('.hiw__gallery-panel');
  var tabs = g.querySelectorAll('.hiw__gallery-tab');
  var idx = 0;
  var timer;

  function activate(i) {
    idx = i;
    panels.forEach(function (p, j) {
      p.classList.toggle('hiw__gallery-panel--active', j === i);
    });
    tabs.forEach(function (t, j) {
      t.classList.toggle('hiw__gallery-tab--active', j === i);
    });
  }

  tabs.forEach(function (t, i) {
    t.addEventListener('click', function () {
      clearInterval(timer);
      activate(i);
      timer = setInterval(function () { activate((idx + 1) % panels.length); }, 8000);
    });
  });

  timer = setInterval(function () { activate((idx + 1) % panels.length); }, 8000);
})();

/* ---- Step 04: stacked window z-swap ---- */
(function () {
  var stack = document.getElementById('hiw-stack-04');
  if (!stack) return;
  var winA = document.getElementById('win-a');
  var winB = document.getElementById('win-b');
  if (!winA || !winB) return;

  var aFront = true;
  var swapTimer;

  function swap() {
    aFront = !aFront;
    
    // Temporarily bump z-index to prevent clipping during animation
    var incoming = aFront ? winA : winB;
    incoming.style.zIndex = '3';
    setTimeout(function() { incoming.style.zIndex = ''; }, 300);

    // Swap the state classes
    winA.className = "mock mock--output hiw__stack-win " + (aFront ? "hiw__stack-win--front" : "hiw__stack-win--back");
    winB.className = "mock mock--opps hiw__stack-win " + (aFront ? "hiw__stack-win--back" : "hiw__stack-win--front");
  }

  function resetTimer() {
    clearInterval(swapTimer);
    swapTimer = setInterval(swap, 4800);
  }

  // Event delegation to catch clicks on whichever window is currently in the back
  stack.addEventListener('click', function (e) {
    if (e.target.closest('.hiw__stack-win--back')) {
      swap();
      resetTimer();
    }
  });

  swapTimer = setInterval(swap, 4800);
})();
</script>


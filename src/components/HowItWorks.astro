---
import logoIconRaw from '../assets/logo_icon.svg?raw';
import logoIconUrl from '../assets/logo_icon.svg?url';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const steps = isDE ? [
  { num: '01', title: 'Setup',
    body: 'Beschreibe, was du erfahren willst und wer befragt wird. Der Setup-Agent macht daraus in Minuten eine fertige Kampagne.' },
  { num: '02', title: 'Gespräche',
    body: 'Deine Leute sprechen mit dem Agenten. Ein Sprachgespräch von etwa 20 Minuten, anonym, wann es ihnen passt. Sie wissen, dass sie mit einer KI sprechen.' },
  { num: '03', title: 'Synthese',
    body: 'Jedes Gespräch wird zu strukturierten Signalen. Das System liest die Transkripte und indexiert, was die Belegschaft weiß.' },
  { num: '04', title: 'Vorschläge',
    body: 'Sieh das Problem, die Idee deiner Leute und die Geschäftschance dahinter. Jede Karte führt zum genauen Zitat.' },
  { num: '05', title: 'Wissens-Chat',
    body: 'Frag deine Belegschaftsdaten in normaler Sprache. Antworten kommen mit Belegen zu einer anonymen Quelle zurück.' },
  { num: '06', title: 'Autonome Recherche', beta: true,
    body: 'Wenn die Daten die Antwort noch nicht hergeben, holt Inplicit sie. Es startet eine gezielte Interview-Runde und bringt die Antwort zurück.' },
] : [
  { num: '01', title: 'Setup',
    body: 'Describe what you want to learn and who gets asked. The setup agent turns it into a ready campaign in minutes.' },
  { num: '02', title: 'Conversations',
    body: 'Your people talk to the agent. A voice conversation of about 20 minutes, anonymous, on their own schedule. They are told they speak with an AI.' },
  { num: '03', title: 'Synthesis',
    body: 'Every conversation becomes structured signals. The system reads the transcripts and indexes what the workforce knows.' },
  { num: '04', title: 'Suggestions',
    body: 'See the problem, the idea your people already have, and the business opportunity behind it. Every card links to the exact quote.' },
  { num: '05', title: 'Knowledge chat',
    body: 'Ask your workforce data in plain language. Answers come back with citations to an anonymous source.' },
  { num: '06', title: 'Autonomous research', beta: true,
    body: 'If the data does not hold the answer yet, Inplicit goes and finds it. It runs a focused round of interviews and brings the answer back.' },
];
---

<section class="hiw" id="how-it-works">
  <div class="container">

    <div class="hiw__header section-fade">
      <p class="section-eyebrow">{isDE ? 'So funktioniert Inplicit' : 'How Inplicit works'}</p>
      <h2 class="hiw__heading">
        <span>{isDE ? 'Verborgenes Wissen,' : 'Hidden knowledge,'}</span>
        <span class="hiw__heading-ghost">{isDE ? 'sichtbar gemacht.' : 'made visible.'}</span>
      </h2>
    </div>

    <div class="hiw__inner">

      <!-- ── Left: step list ──────────────────────────── -->
      <div class="hiw__accordion" id="hiw-accordion">
        {steps.map((s, i) => (
          <button class={`hiw__item${i === 0 ? ' hiw__item--active' : ''}`} data-step={i} type="button">
            <div class="hiw__progress" aria-hidden="true"></div>
            <div class="hiw__item-inner">
              <span class="hiw__num">{s.num}</span>
              <div class="hiw__item-text">
                <p class="hiw__item-title">
                  {s.title}
                  {s.beta ? <span class="hiw__beta">Beta</span> : null}
                </p>
                <div class="hiw__item-body"><p>{s.body}</p></div>
              </div>
            </div>
          </button>
        ))}
      </div>

      <!-- ── Right: scene previews ────────────────────── -->
      <div class="hiw__right">
        <div class="hiw__panels">

          <!-- Scene 0: Setup — setup-agent chat -->
          <div class="hiw__panel hiw__panel--active" data-step="0">
            <div class="mock">
              <div class="mock__chrome">
                <div class="mock__dots"><span class="mock__dot mock__dot--r"></span><span class="mock__dot mock__dot--y"></span><span class="mock__dot mock__dot--g"></span></div>
                <span class="mock__title">{isDE ? 'Setup' : 'Setup'}</span>
              </div>
              <div class="mock__chat-body">
                <div class="mock__msg mock__msg--agent">
                  <span class="mock__msg-icon" set:html={logoIconRaw} />
                  <div class="mock__msg-bubble">{isDE ? 'Was möchtest du von deinem Team erfahren?' : 'What do you want to learn from your team?'}</div>
                </div>
                <div class="mock__msg mock__msg--user">
                  <span class="mock__msg-avatar"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                  <div class="mock__msg-bubble">{isDE ? 'Wo wir im Betrieb Zeit verlieren.' : 'Where we lose time in operations.'}</div>
                </div>
                <div class="mock__msg mock__msg--agent">
                  <span class="mock__msg-icon" set:html={logoIconRaw} />
                  <div class="mock__msg-col">
                    <div class="mock__msg-bubble">{isDE ? '120 Personen eingeladen, je etwa 20 Minuten.' : '120 people invited, about 20 minutes each.'}</div>
                    <span class="mock__ready">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                      {isDE ? 'Kampagne bereit' : 'Campaign ready'}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 1: Conversations — interviewee view -->
          <div class="hiw__panel" data-step="1">
            <div class="mock">
              <div class="mock__chrome">
                <div class="mock__dots"><span class="mock__dot mock__dot--r"></span><span class="mock__dot mock__dot--y"></span><span class="mock__dot mock__dot--g"></span></div>
                <span class="mock__title">{isDE ? 'Interview' : 'Interview'}</span>
                <span class="mock__status-dot" style="margin-left:auto"></span>
              </div>
              <div class="mock__badges">
                <span class="mock__badge">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  {isDE ? 'Anonym' : 'Anonymous'}
                </span>
                <span class="mock__badge">{isDE ? 'KI-Agent' : 'AI agent'}</span>
              </div>
              <div class="mock__chat-body" style="padding-top:var(--space-3)">
                <div class="mock__msg mock__msg--agent">
                  <span class="mock__msg-icon" set:html={logoIconRaw} />
                  <div class="mock__msg-bubble">{isDE ? 'Erzähl von einem Moment diese Woche, der länger gedauert hat als nötig.' : 'Tell me about a moment this week that took longer than it should.'}</div>
                </div>
                <div class="mock__msg mock__msg--user">
                  <span class="mock__msg-avatar"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                  <div class="mock__msg-bubble">{isDE ? 'Jeder Auftragsexport braucht drei Tools und eine manuelle Prüfung.' : 'Every order export needs three tools and a manual check.'}</div>
                </div>
                <div class="mock__voice">
                  <span class="mock__voice-bars"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span>
                  <span class="mock__voice-label">{isDE ? 'Hört zu' : 'Listening'}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 2: Synthesis -->
          <div class="hiw__panel" data-step="2">
            <div class="mock mock--synthesis">
              <div class="mock__chrome">
                <div class="mock__dots"><span class="mock__dot mock__dot--r"></span><span class="mock__dot mock__dot--y"></span><span class="mock__dot mock__dot--g"></span></div>
                <span class="mock__title">{isDE ? 'Synthese läuft' : 'Synthesis running'}</span>
              </div>
              <div class="mock__synth-body">
                <div class="mock__synth-graph" aria-hidden="true">
                  <svg class="mock__synth-svg" viewBox="0 0 360 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="8" y="30" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <rect x="8" y="93" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <rect x="8" y="156" width="96" height="34" rx="8" fill="var(--color-surface-elevated)" stroke="var(--color-border)" stroke-width="1"/>
                    <text x="56" y="52" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Gespräche' : 'Conversations'}</text>
                    <text x="56" y="115" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Dokumente' : 'Documents'}</text>
                    <text x="56" y="178" text-anchor="middle" font-size="11" font-weight="500" fill="var(--color-text-secondary)" font-family="Inter, sans-serif">{isDE ? 'Systeme' : 'Systems'}</text>
                    <path class="mock__synth-path mock__synth-path--1" d="M104 47 C160 47 162 110 185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="mock__synth-path mock__synth-path--2" d="M104 110 L185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="mock__synth-path mock__synth-path--3" d="M104 173 C160 173 162 110 185 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <path class="mock__synth-path mock__synth-path--out" d="M215 110 L262 110" stroke="var(--color-accent)" stroke-width="0.8" stroke-dasharray="3 5"/>
                    <image href={logoIconUrl} x="176" y="86" width="48" height="48"/>
                    <rect x="262" y="80" width="74" height="60" rx="10" fill="var(--color-surface-elevated)" stroke="var(--color-accent-muted)" stroke-width="1.5"/>
                    <text x="299" y="114" text-anchor="middle" font-size="23" font-weight="800" fill="var(--color-accent)" font-family="Inter, sans-serif" letter-spacing="-0.04em">14</text>
                    <text x="299" y="129" text-anchor="middle" font-size="8" font-weight="700" fill="var(--color-text-secondary)" font-family="Inter, sans-serif" letter-spacing="0.1em">{isDE ? 'SIGNALE' : 'INSIGHTS'}</text>
                  </svg>
                </div>
                <div class="mock__body" style="padding-top:0">
                  <div class="mock__wf-item mock__wf-item--done">
                    <div class="mock__wf-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Gespräche gelesen' : 'Conversations read'}</span>
                      <span class="mock__wf-sub">{isDE ? '1.247 Stimmen' : '1,247 voices'}</span>
                    </div>
                    <span class="mock__wf-status mock__wf-status--done">{isDE ? 'Fertig' : 'Done'}</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--active">
                    <div class="mock__wf-icon mock__wf-icon--spin"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Signale extrahiert' : 'Signals extracted'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Probleme, Ideen, Chancen' : 'Problems, ideas, opportunities'}</span>
                    </div>
                    <span class="mock__wf-status mock__wf-status--active">{isDE ? 'Aktiv' : 'Active'}</span>
                  </div>
                  <div class="mock__wf-item mock__wf-item--pending">
                    <div class="mock__wf-icon mock__wf-icon--pending"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg></div>
                    <div class="mock__wf-content">
                      <span class="mock__wf-title">{isDE ? 'Muster gruppiert' : 'Patterns grouped'}</span>
                      <span class="mock__wf-sub">{isDE ? 'Verwandte Signale verbinden' : 'Connecting related signals'}</span>
                    </div>
                    <span class="mock__wf-status">{isDE ? 'Ausstehend' : 'Pending'}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 3: Suggestions — triad cards -->
          <div class="hiw__panel" data-step="3">
            <div class="mock mock--triads">
              <div class="mock__chrome">
                <div class="mock__dots"><span class="mock__dot mock__dot--r"></span><span class="mock__dot mock__dot--y"></span><span class="mock__dot mock__dot--g"></span></div>
                <span class="mock__title">{isDE ? 'Vorschläge' : 'Suggestions'}</span>
              </div>
              <div class="mock__body">

                <div class="triad">
                  <div class="triad__row triad__row--problem">
                    <span class="triad__label">{isDE ? 'Problem' : 'Problem'}</span>
                    <span class="triad__text">{isDE ? 'Auftragsexport braucht drei Tools und eine manuelle Prüfung.' : 'Order export needs three tools and a manual check.'}</span>
                  </div>
                  <div class="triad__row triad__row--idea">
                    <span class="triad__label">{isDE ? 'Idee' : 'Idea'}<span class="triad__origin">{isDE ? 'Vom Team' : 'From the team'}</span></span>
                    <span class="triad__text">{isDE ? 'Eine Export-Ansicht, die die drei Quellen zusammenführt.' : 'One export view that merges the three sources.'}</span>
                  </div>
                  <div class="triad__row triad__row--opp">
                    <span class="triad__label">{isDE ? 'Chance' : 'Opportunity'}</span>
                    <span class="triad__text">{isDE ? 'Etwa 4 Stunden pro Woche pro Mitarbeiter.' : 'About 4 hours a week per operator.'}</span>
                  </div>
                  <div class="triad__foot">
                    <span class="conf conf--high">{isDE ? 'Hoch' : 'High'}</span>
                    <span class="triad__quote">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      {isDE ? 'Zitat ansehen' : 'View quote'}
                    </span>
                  </div>
                </div>

                <div class="triad">
                  <div class="triad__row triad__row--problem">
                    <span class="triad__label">{isDE ? 'Problem' : 'Problem'}</span>
                    <span class="triad__text">{isDE ? 'Neue Mitarbeitende warten Tage auf Systemzugang.' : 'New hires wait days for system access.'}</span>
                  </div>
                  <div class="triad__row triad__row--idea">
                    <span class="triad__label">{isDE ? 'Idee' : 'Idea'}<span class="triad__origin">Inplicit</span></span>
                    <span class="triad__text">{isDE ? 'Zugang aus dem unterschriebenen Vertrag auslösen.' : 'Trigger access from the signed contract.'}</span>
                  </div>
                  <div class="triad__row triad__row--opp">
                    <span class="triad__label">{isDE ? 'Chance' : 'Opportunity'}</span>
                    <span class="triad__text">{isDE ? 'Schnellere erste Woche, weniger Leerlauf.' : 'Faster first week, less idle time.'}</span>
                  </div>
                  <div class="triad__foot">
                    <span class="conf conf--mid">{isDE ? 'Mittel' : 'Medium'}</span>
                    <span class="triad__quote">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      {isDE ? 'Zitat ansehen' : 'View quote'}
                    </span>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- Scene 4: Knowledge chat -->
          <div class="hiw__panel" data-step="4">
            <div class="mock">
              <div class="mock__chrome">
                <div class="mock__dots"><span class="mock__dot mock__dot--r"></span><span class="mock__dot mock__dot--y"></span><span class="mock__dot mock__dot--g"></span></div>
                <span class="mock__title">{isDE ? 'Wissens-Chat' : 'Knowledge chat'}</span>
              </div>
              <div class="mock__chat-body">
                <div class="mock__msg mock__msg--user">
                  <span class="mock__msg-avatar"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                  <div class="mock__msg-bubble">{isDE ? 'Hat jemand in Legal Onboarding-Probleme erwähnt?' : 'Did anyone in legal mention onboarding pain?'}</div>
                </div>
                <div class="mock__msg mock__msg--agent">
                  <span class="mock__msg-icon" set:html={logoIconRaw} />
                  <div class="mock__msg-col">
                    <div class="mock__msg-bubble">{isDE ? 'Ja. Zwei Personen in Legal beschreiben einen langsamen Zugangsprozess in ihrer ersten Woche.' : 'Yes. Two people in Legal describe a slow access process in their first week.'}</div>
                    <span class="mock__cite">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      ANON-3F2 · Legal
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 5: Autonomous research (Beta) -->
          <div class="hiw__panel" data-step="5">
            <div class="mock">
              <div class="mock__chrome">
                <div class="mock__dots"><span class="mock__dot mock__dot--r"></span><span class="mock__dot mock__dot--y"></span><span class="mock__dot mock__dot--g"></span></div>
                <span class="mock__title">{isDE ? 'Wissens-Chat' : 'Knowledge chat'}</span>
                <span class="mock__beta">Beta</span>
              </div>
              <div class="mock__chat-body">
                <div class="mock__msg mock__msg--user">
                  <span class="mock__msg-avatar"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                  <div class="mock__msg-bubble">{isDE ? 'Wie regeln Nachtschichten die Übergabe?' : 'How do night shifts handle handover?'}</div>
                </div>
                <div class="mock__msg mock__msg--agent">
                  <span class="mock__msg-icon" set:html={logoIconRaw} />
                  <div class="mock__msg-bubble">{isDE ? 'Noch keine Antwort in den Daten. Ich starte eine gezielte Interview-Runde.' : 'No answer in the data yet. Starting a focused interview round.'}</div>
                </div>
                <div class="mock__research">
                  <span class="mock__research-pulse"></span>
                  <div class="mock__wf-content">
                    <span class="mock__research-text">{isDE ? 'Befrage 8 Personen in der Logistik' : 'Interviewing 8 people in Logistics'}</span>
                    <span class="mock__research-sub">{isDE ? '5 von 8 abgeschlossen' : '5 of 8 completed'}</span>
                  </div>
                </div>
                <div class="mock__msg mock__msg--agent">
                  <span class="mock__msg-icon" set:html={logoIconRaw} />
                  <div class="mock__msg-col">
                    <div class="mock__msg-bubble">{isDE ? 'Die Übergabe läuft über ein gemeinsames Heft. Zwei Schichten wünschen ein digitales Log.' : 'Handover runs over a shared notebook. Two shifts ask for a digital log.'}</div>
                    <span class="mock__cite">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      {isDE ? '8 Stimmen · Logistik' : '8 voices · Logistics'}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function () {
  var DURATION = 6000;
  var accordion = document.getElementById('hiw-accordion');
  if (!accordion) return;

  var items = accordion.querySelectorAll('.hiw__item');
  var panels = document.querySelectorAll('.hiw__panel');
  var active = 0;
  var timer = null;
  // Only desktop (>=1024px) cycles the preview; tablet (zig-zag) and mobile
  // (stacked) show every scene static.
  var isMobile = window.matchMedia('(max-width: 1023px)').matches;

  function activate(idx, restart) {
    items.forEach(function (item, i) {
      var progress = item.querySelector('.hiw__progress');
      if (i === idx) {
        item.classList.add('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            progress.style.transition = 'height ' + DURATION + 'ms linear';
            progress.style.height = '100%';
          });
        });
      } else {
        item.classList.remove('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
      }
    });

    panels.forEach(function (panel, i) {
      panel.classList.toggle('hiw__panel--active', i === idx);
    });

    active = idx;

    if (restart !== false && !isMobile) {
      clearTimeout(timer);
      timer = setTimeout(function () {
        activate((active + 1) % items.length);
      }, DURATION);
    }
  }

  items.forEach(function (item, i) {
    item.addEventListener('click', function () { activate(i); });
  });

  // Start after first paint so the initial styles don't transition/flash in.
  var section = document.getElementById('how-it-works');
  requestAnimationFrame(function () {
    if (section) section.classList.add('is-ready');
    activate(0);
  });
})();
</script>

<style>
  .hiw {
    padding: var(--space-section) 0 var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .hiw { padding: var(--space-24) 0 var(--space-32); }
  }

  /* Prevent a colour / progress-bar flash on load: hold the active styling
     until the script marks the section ready (one frame after first paint). */
  .hiw:not(.is-ready) .hiw__progress { display: none; }
  .hiw:not(.is-ready) .hiw__num,
  .hiw:not(.is-ready) .hiw__item-title { transition: none; }

  /* ── Desktop: step list | one cycling preview, with a clear gap ── */
  .hiw__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .hiw__header {
    margin-bottom: var(--space-12);
    max-width: 50%;
  }

  @media (max-width: 900px) {
    .hiw__header { max-width: 100%; }
  }

  .hiw__heading {
    font-size: clamp(var(--text-xl), 4vw, 2.75rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.0;
    display: flex;
    flex-direction: column;
    gap: 0;
    color: var(--color-text-primary);
  }

  .hiw__heading-ghost { opacity: 0.25; }

  /* ── Step list ──────────────────────────────────────── */

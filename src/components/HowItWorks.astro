---
import logoIconRaw from '../assets/logo_icon.svg?raw';

export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

const steps = isDE ? [
  { num: '01', title: 'Setup',
    body: 'Beschreibe, was du erfahren willst und wer befragt wird. Der Setup-Agent macht daraus in Minuten eine fertige Kampagne.' },
  { num: '02', title: 'Gespräche',
    body: 'Deine Leute sprechen mit dem Agenten. Ein Sprachgespräch von etwa 20 Minuten, anonym, wann es ihnen passt. Sie wissen, dass sie mit einer KI sprechen.' },
  { num: '03', title: 'Synthese',
    body: 'Jedes Gespräch wird zu strukturierten Signalen. Das System liest die Transkripte und indexiert, was die Belegschaft weiß.' },
  { num: '04', title: 'Vorschläge',
    body: 'Sieh das Problem, die Idee deiner Leute und die Geschäftschance dahinter. Jede Karte führt zum genauen Zitat.' },
  { num: '05', title: 'Wissens-Chat',
    body: 'Frag deine Belegschaftsdaten in normaler Sprache. Antworten kommen mit Belegen zu einer anonymen Quelle zurück.' },
  { num: '06', title: 'Autonome Recherche', beta: true,
    body: 'Wenn die Daten die Antwort noch nicht hergeben, holt Inplicit sie. Es startet eine gezielte Interview-Runde und meldet sich per E-Mail, sobald die Ergebnisse da sind.' },
] : [
  { num: '01', title: 'Setup',
    body: 'Describe what you want to learn and who gets asked. The setup agent turns it into a ready campaign in minutes.' },
  { num: '02', title: 'Conversations',
    body: 'Your people talk to the agent. A voice conversation of about 20 minutes, anonymous, on their own schedule. They are told they speak with an AI.' },
  { num: '03', title: 'Synthesis',
    body: 'Every conversation becomes structured signals. The system reads the transcripts and indexes what the workforce knows.' },
  { num: '04', title: 'Suggestions',
    body: 'See the problem, the idea your people already have, and the business opportunity behind it. Every card links to the exact quote.' },
  { num: '05', title: 'Knowledge chat',
    body: 'Ask your workforce data in plain language. Answers come back with citations to an anonymous source.' },
  { num: '06', title: 'Autonomous research', beta: true,
    body: 'If the data does not hold the answer yet, Inplicit goes and finds it. It runs a focused round of interviews and emails you when the results are ready.' },
];

// Explicit width/height so the icon never balloons if scoped CSS fails to load.
const sendIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>';
---

<section class="hiw" id="how-it-works">
  <div class="container">

    <div class="hiw__header section-fade">
      <p class="section-eyebrow">{isDE ? 'So funktioniert Inplicit' : 'How Inplicit works'}</p>
      <h2 class="hiw__heading">
        <span>{isDE ? 'Verborgenes Wissen,' : 'Hidden knowledge,'}</span>
        <span class="hiw__heading-ghost">{isDE ? 'sichtbar gemacht.' : 'made visible.'}</span>
      </h2>
    </div>

    <div class="hiw__inner">

      <!-- ── Left: step list ──────────────────────────── -->
      <div class="hiw__accordion" id="hiw-accordion">
        {steps.map((s, i) => (
          <button class={`hiw__item${i === 0 ? ' hiw__item--active' : ''}`} data-step={i} type="button">
            <div class="hiw__progress" aria-hidden="true"></div>
            <div class="hiw__item-inner">
              <span class="hiw__num">{s.num}</span>
              <div class="hiw__item-text">
                <p class="hiw__item-title">
                  {s.title}
                  {s.beta ? <span class="hiw__beta">Beta</span> : null}
                </p>
                <div class="hiw__item-body"><p>{s.body}</p></div>
              </div>
            </div>
          </button>
        ))}
      </div>

      <!-- ── Right: scene previews (4:3 windows mirroring the dashboard) ── -->
      <div class="hiw__right">
        <div class="hiw__panels">

          <!-- Scene 0: Setup — the setup agent (edda) chat -->
          <div class="hiw__panel hiw__panel--active" data-step="0">
            <div class="scene" aria-hidden="true">
              <div class="scene__head">
                <span class="scene__avatar" set:html={logoIconRaw} />
                <div>
                  <div class="scene__head-title">edda</div>
                  <div class="scene__head-sub">{isDE ? 'Kampagnen-Planer' : 'Campaign planner'}</div>
                </div>
                <span class="scene__dot" style="margin-left:auto"></span>
              </div>
              <div class="chat">
                <div class="chat__scroll">
                  <div class="msg-user">{isDE ? 'Warum verlieren wir im Tagesgeschäft so viel Zeit?' : 'Why do we lose so much time in daily operations?'}</div>
                  <div class="msg-agent">{isDE ? 'Ich habe einen Katalog mit 8 Fragen für Operations und Logistik entworfen. Möchtest du ihn ansehen?' : 'I drafted a catalog of 8 questions for Operations and Logistics. Want to review it?'}</div>
                </div>
                <div class="composer">
                  <div class="composer__chips">
                    <span class="composer__chip">{isDE ? 'Fragen ansehen' : 'Review questions'}</span>
                    <span class="composer__chip">{isDE ? 'Finance ergänzen' : 'Add Finance'}</span>
                  </div>
                  <div class="composer__input">
                    <span class="composer__placeholder">{isDE ? 'Antworte oder bitte den Assistenten, den Katalog anzupassen…' : 'Reply or ask the assistant to adjust the catalog…'}</span>
                    <span class="composer__send" set:html={sendIcon} />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 1: Conversations — the interviewee voice room -->
          <div class="hiw__panel" data-step="1">
            <div class="scene" aria-hidden="true">
              <div class="iv__top">
                <span class="scene__dot scene__dot--live"></span>
                <span class="iv__clock">12:30 / 25:00</span>
                <span class="iv__ai">{isDE ? 'KI-Agent · kein Mensch' : 'AI agent · not a human'}</span>
                <span class="iv__end">{isDE ? 'Beenden' : 'End'}</span>
              </div>
              <div class="iv__stage">
                <div class="orb"><span class="orb__ring"></span><span class="orb__core"></span></div>
                <div class="iv__hud">
                  <span class="iv__status"><span class="scene__dot scene__dot--live"></span>{isDE ? 'Hört zu' : 'Listening'}</span>
                  <span class="iv__phase">{isDE ? 'Phase 1 · Offen' : 'Phase 1 · Open'}</span>
                  <span class="iv__conn"><span class="iv__conn-dot"></span>{isDE ? 'Verbunden' : 'Connected'}</span>
                </div>
              </div>
              <div class="iv__bottom">
                <span class="iv__mute"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4"/></svg></span>
                <span class="iv__switch"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>{isDE ? 'Zu Chat wechseln' : 'Switch to chat'}</span>
              </div>
            </div>
          </div>

          <!-- Scene 2: Synthesis — campaign overview metrics (no synthesis screen exists) -->
          <div class="hiw__panel" data-step="2">
            <div class="scene" aria-hidden="true">
              <div class="scene__head">
                <div class="scene__head-title">{isDE ? 'Kampagne · Operations' : 'Campaign · Operations'}</div>
                <span class="live-pill" style="margin-left:auto"><span class="scene__dot scene__dot--live"></span>Live</span>
              </div>
              <div class="ov__grid">
                <div class="metric"><span class="metric__label">{isDE ? 'Teilnehmer' : 'Participants'}</span><span class="metric__value">120</span></div>
                <div class="metric"><span class="metric__label">{isDE ? 'Abgeschlossen' : 'Completed'}</span><span class="metric__value">86</span></div>
                <div class="metric"><span class="metric__label">Insights</span><span class="metric__value metric__value--accent">14</span></div>
                <div class="metric"><span class="metric__label">{isDE ? 'Hypothesen' : 'Hypotheses'}</span><span class="metric__value">5</span></div>
              </div>
            </div>
          </div>

          <!-- Scene 3: Suggestions — the insights triad card -->
          <div class="hiw__panel" data-step="3">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">Insights</div></div>
              <div class="ins">
                <div class="ins__card">
                  <div class="ins__cardhead">
                    <div class="ins__badges"><span class="dept">Operations</span><span class="dept">{isDE ? 'Offene Phase' : 'Open phase'}</span></div>
                    <span class="ins__rank">#1</span>
                  </div>
                  <div class="ins__rows">
                    <div class="ins__row"><span class="tlabel tlabel--problem">Problem</span><span class="ttext">{isDE ? 'Auftragsexport braucht drei Tools und eine manuelle Prüfung.' : 'Order export needs three tools and a manual check.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--idea">{isDE ? 'Idee' : 'Idea'}</span><span class="ttext">{isDE ? 'Eine Export-Ansicht, die die drei Quellen zusammenführt.' : 'One export view that merges the three sources.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--opp">{isDE ? 'Chance' : 'Opportunity'}</span><span class="ttext">{isDE ? 'Etwa 4 Stunden pro Woche pro Mitarbeiter.' : 'About 4 hours a week per operator.'}</span></div>
                  </div>
                </div>
                <div class="ins__card">
                  <div class="ins__cardhead">
                    <div class="ins__badges"><span class="dept">HR</span><span class="dept">{isDE ? 'Offene Phase' : 'Open phase'}</span></div>
                    <span class="ins__rank">#2</span>
                  </div>
                  <div class="ins__rows">
                    <div class="ins__row"><span class="tlabel tlabel--problem">Problem</span><span class="ttext">{isDE ? 'Neue Mitarbeitende warten Tage auf Systemzugang.' : 'New hires wait days for system access.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--idea">{isDE ? 'Idee (AI)' : 'Idea (AI)'}</span><span class="ttext">{isDE ? 'Zugang aus dem unterschriebenen Vertrag auslösen.' : 'Trigger access from the signed contract.'}</span></div>
                    <div class="ins__row"><span class="tlabel tlabel--opp">{isDE ? 'Chance' : 'Opportunity'}</span><span class="ttext">{isDE ? 'Schnellere erste Woche, weniger Leerlauf.' : 'Faster first week, less idle time.'}</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 4: Knowledge chat — RAG with citations -->
          <div class="hiw__panel" data-step="4">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">{isDE ? 'Wissens-Chat' : 'Knowledge chat'}</div><span class="scene__dot" style="margin-left:auto"></span></div>
              <div class="chat">
                <div class="chat__scroll">
                  <div class="msg-user">{isDE ? 'Hat jemand im Rechtsbereich Onboarding-Probleme erwähnt?' : 'Did anyone in Legal mention onboarding pain?'}</div>
                  <div class="msg-agent">
                    {isDE ? 'Ja. Zwei Personen im Rechtsbereich beschreiben einen langsamen Zugangsprozess in ihrer ersten Woche.' : 'Yes. Two people in Legal describe a slow access process in their first week.'}
                    <div class="cites">
                      <span class="cites__label">{isDE ? 'Quellen' : 'Sources'}</span>
                      <span class="cite">ANON-3F2 · #14</span>
                      <span class="cite">ANON-9K1 · #7</span>
                    </div>
                    <div class="ai-note">{isDE ? 'KI-generiert aus anonymisierten Interviewdaten' : 'AI-generated from anonymized interview data'}</div>
                  </div>
                </div>
                <div class="composer">
                  <div class="composer__input">
                    <span class="composer__placeholder">{isDE ? 'Frag zu dieser Kampagne…' : 'Ask about this campaign…'}</span>
                    <span class="composer__send" set:html={sendIcon} />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scene 5: Autonomous research (Beta) — loop closes via a fresh round -->
          <div class="hiw__panel" data-step="5">
            <div class="scene" aria-hidden="true">
              <div class="scene__head"><div class="scene__head-title">{isDE ? 'Wissens-Chat' : 'Knowledge chat'}</div><span class="scene__beta" style="margin-left:auto">Beta</span></div>
              <div class="chat">
                <div class="chat__scroll">
                  <div class="msg-user">{isDE ? 'Wie regeln Nachtschichten die Übergabe?' : 'How do night shifts handle handover?'}</div>
                  <div class="msg-agent">{isDE ? 'Noch keine Antwort in den Daten. Ich starte eine gezielte Interview-Runde und melde mich per E-Mail, sobald die Ergebnisse da sind.' : 'No answer in the data yet. I will run a focused interview round and email you when the results are ready.'}</div>
                  <div class="research">
                    <span class="research__pulse"></span>
                    <div class="research__text">
                      <div class="research__title">{isDE ? 'Befrage 8 Personen in der Logistik' : 'Interviewing 8 people in Logistics'}</div>
                      <div class="research__sub">{isDE ? '5 von 8 abgeschlossen' : '5 of 8 completed'}</div>
                    </div>
                  </div>
                </div>
                <div class="composer">
                  <div class="composer__input">
                    <span class="composer__placeholder">{isDE ? 'Frag zu dieser Kampagne…' : 'Ask about this campaign…'}</span>
                    <span class="composer__send" set:html={sendIcon} />
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function () {
  var DURATION = 6000;
  var accordion = document.getElementById('hiw-accordion');
  if (!accordion) return;

  var items = accordion.querySelectorAll('.hiw__item');
  var panels = document.querySelectorAll('.hiw__panel');
  var active = 0;
  var timer = null;
  // Only desktop (>=1024px) cycles the preview; tablet and mobile show all scenes static.
  var isMobile = window.matchMedia('(max-width: 1023px)').matches;

  function activate(idx, restart) {
    items.forEach(function (item, i) {
      var progress = item.querySelector('.hiw__progress');
      if (i === idx) {
        item.classList.add('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            progress.style.transition = 'height ' + DURATION + 'ms linear';
            progress.style.height = '100%';
          });
        });
      } else {
        item.classList.remove('hiw__item--active');
        progress.style.transition = 'none';
        progress.style.height = '0%';
      }
    });

    panels.forEach(function (panel, i) {
      panel.classList.toggle('hiw__panel--active', i === idx);
    });

    active = idx;

    if (restart !== false && !isMobile) {
      clearTimeout(timer);
      timer = setTimeout(function () {
        activate((active + 1) % items.length);
      }, DURATION);
    }
  }

  items.forEach(function (item, i) {
    item.addEventListener('click', function () { activate(i); });
  });

  var section = document.getElementById('how-it-works');
  requestAnimationFrame(function () {
    if (section) section.classList.add('is-ready');
    activate(0);
  });
})();
</script>

<style>
  .hiw {
    padding: var(--space-section) 0 var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .hiw { padding: var(--space-24) 0 var(--space-32); }
  }

  /* Hold active styling until the script flags the section ready (no load flash). */
  .hiw:not(.is-ready) .hiw__progress { display: none; }
  .hiw:not(.is-ready) .hiw__num,
  .hiw:not(.is-ready) .hiw__item-title { transition: none; }

  /* ── Desktop: step list | one cycling preview ── */
  .hiw__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .hiw__header { margin-bottom: var(--space-12); max-width: 50%; }
  @media (max-width: 900px) { .hiw__header { max-width: 100%; } }

  .hiw__heading {
    font-size: clamp(var(--text-xl), 4vw, 2.75rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.0;
    display: flex;
    flex-direction: column;
    gap: 0;
    color: var(--color-text-primary);
  }

  .hiw__heading-ghost { opacity: 0.25; }

  /* ── Step list ──────────────────────────────────────── */
  .hiw__accordion { display: flex; flex-direction: column; }

  .hiw__item {
    position: relative;
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    border-top: 1px solid var(--color-border);
    padding: var(--space-6) 0 var(--space-6) var(--space-6);
    cursor: pointer;
    font-family: var(--font-family);
  }

  .hiw__item:last-child { border-bottom: 1px solid var(--color-border); }

  .hiw__progress {
    position: absolute;
    left: 0; top: 0;
    width: 2px; height: 0%;
    background: var(--color-accent);
    border-radius: 0 2px 2px 0;
  }

  .hiw__item-inner { display: flex; gap: var(--space-4); align-items: flex-start; }

  .hiw__num {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
    padding-top: 2px;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .hiw__item--active .hiw__num { color: var(--color-accent); }

  .hiw__item-text { flex: 1; }

  .hiw__item-title {
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--color-text-tertiary);
    transition: color 0.2s ease;
    margin: 0;
  }

  .hiw__item--active .hiw__item-title,
  .hiw__item:hover .hiw__item-title { color: var(--color-text-primary); }

  .hiw__beta {
    display: inline-block;
    margin-left: var(--space-2);
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-light);
    border: 1px solid var(--color-accent-muted);
    padding: 1px 6px;
    border-radius: var(--radius-full);
    vertical-align: middle;
  }

  .hiw__item-body {
    overflow: hidden; max-height: 0; opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease;
    margin-top: 0;
  }

  .hiw__item--active .hiw__item-body { max-height: 160px; opacity: 1; margin-top: var(--space-3); }

  .hiw__item-body p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: 1.75; }

  /* ── Right column: cycling preview ── */
  .hiw__right { position: sticky; top: 100px; }
  .hiw__panels { display: grid; }

  .hiw__panel { grid-area: 1 / 1; opacity: 0; pointer-events: none; transition: opacity 0.4s ease; }
  .hiw__panel--active { opacity: 1; pointer-events: auto; }

  /* Non-desktop: all scenes visible & static. */
  @media (max-width: 1023px) {
    .hiw__accordion,
    .hiw__right,
    .hiw__panels { display: contents; }
    .hiw__panel { position: static; display: block; opacity: 1; pointer-events: auto; transition: none; }
    .hiw__item { border-top: none; }
    .hiw__item:last-child { border-bottom: none; }
    .hiw__progress { display: none; }
    .hiw__num, .hiw__item-title { color: var(--color-text-primary); }
    .hiw__item-body,
    .hiw__item--active .hiw__item-body { max-height: none; opacity: 1; margin-top: var(--space-2); overflow: visible; }
  }

  /* iPad: zig-zag, each step a row, text and scene swap sides. */
  @media (min-width: 768px) and (max-width: 1023px) {
    .hiw__inner { display: grid; grid-template-columns: 1fr 1fr; column-gap: var(--space-8); row-gap: var(--space-12); align-items: center; }
    .hiw__item { padding: 0; }
    .hiw__item[data-step="0"]  { grid-column: 1; grid-row: 1; }
    .hiw__panel[data-step="0"] { grid-column: 2; grid-row: 1; }
    .hiw__panel[data-step="1"] { grid-column: 1; grid-row: 2; }
    .hiw__item[data-step="1"]  { grid-column: 2; grid-row: 2; }
    .hiw__item[data-step="2"]  { grid-column: 1; grid-row: 3; }
    .hiw__panel[data-step="2"] { grid-column: 2; grid-row: 3; }
    .hiw__panel[data-step="3"] { grid-column: 1; grid-row: 4; }
    .hiw__item[data-step="3"]  { grid-column: 2; grid-row: 4; }
    .hiw__item[data-step="4"]  { grid-column: 1; grid-row: 5; }
    .hiw__panel[data-step="4"] { grid-column: 2; grid-row: 5; }
    .hiw__panel[data-step="5"] { grid-column: 1; grid-row: 6; }
    .hiw__item[data-step="5"]  { grid-column: 2; grid-row: 6; }
  }

  /* Mobile: stacked, scenes full width. */
  @media (max-width: 767px) {
    .hiw__inner { display: flex; flex-direction: column; align-items: stretch; gap: var(--space-6); }
    .hiw__item { padding: var(--space-4) 0 0; }
    .hiw__panel[data-step="0"] { order: 0; } .hiw__item[data-step="0"] { order: 1; }
    .hiw__panel[data-step="1"] { order: 2; } .hiw__item[data-step="1"] { order: 3; }
    .hiw__panel[data-step="2"] { order: 4; } .hiw__item[data-step="2"] { order: 5; }
    .hiw__panel[data-step="3"] { order: 6; } .hiw__item[data-step="3"] { order: 7; }
    .hiw__panel[data-step="4"] { order: 8; } .hiw__item[data-step="4"] { order: 9; }
    .hiw__panel[data-step="5"] { order: 10; } .hiw__item[data-step="5"] { order: 11; }
  }

  /* ── Scene window: a 4:3 viewport into the real app ── */
  .scene {
    aspect-ratio: 4 / 3;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    font-family: var(--font-family);
  }

  .scene__head {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-elevated);
  }

  .scene__head-title { font-size: 12px; font-weight: 600; color: var(--color-text-primary); }
  .scene__head-sub { font-size: 10px; color: var(--color-text-tertiary); }

  .scene__avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--color-accent-light); border: 1px solid var(--color-accent-muted);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .scene__avatar :global(svg) { width: 17px; height: 17px; display: block; }
  .scene__avatar :global(path) { fill: #000000; }
  .scene__avatar :global(rect) { fill: var(--color-accent); }


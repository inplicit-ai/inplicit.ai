    grid-area: 1 / 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .hiw__panel--active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Steps: all descriptions stay visible (keeps the section height stable);
        the active step is highlighted as the preview cycles ── */
  .hiw__item-title { color: var(--color-text-primary); }
  .hiw__item--active .hiw__num { color: var(--color-accent); }

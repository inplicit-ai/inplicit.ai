<style>
  .hiw {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .hiw { padding: var(--space-24) 0; }
  }

  .hiw:not(.is-ready) .hiw__progress { display: none; }
  .hiw:not(.is-ready) .hiw__num,
  .hiw:not(.is-ready) .hiw__item-title { transition: none; }

  /* ── Desktop: step list | one cycling preview; both columns equal height ── */
  .hiw__inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: stretch; }

  .hiw__header { margin-bottom: var(--space-12); max-width: 50%; }
  @media (max-width: 900px) { .hiw__header { max-width: 100%; } }

  .hiw__heading {
    font-size: clamp(var(--text-xl), 4vw, 2.75rem);
    font-weight: 400; letter-spacing: -0.04em; line-height: 1.0;
    display: flex; flex-direction: column; gap: 0; color: var(--color-text-primary);
  }
  .hiw__heading-ghost { opacity: 0.25; }

  /* ── Step list ──────────────────────────────────────── */
  .hiw__accordion { display: flex; flex-direction: column; }

  .hiw__item {
    position: relative; display: block; width: 100%; text-align: left;
    background: none; border: none; border-top: 1px solid var(--color-border);
    padding: var(--space-6) 0 var(--space-6) var(--space-6); cursor: pointer; font-family: var(--font-family);
  }
  .hiw__item:last-child { border-bottom: 1px solid var(--color-border); }

  .hiw__progress { position: absolute; left: 0; top: 0; width: 2px; height: 0%; background: var(--color-accent); border-radius: 0 2px 2px 0; }

  .hiw__item-inner { display: flex; gap: var(--space-4); align-items: flex-start; }

  .hiw__num {
    font-size: var(--text-xs); font-weight: 700; color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums; letter-spacing: 0.05em; padding-top: 2px; flex-shrink: 0;
    transition: color 0.2s ease;
  }
  .hiw__item--active .hiw__num { color: var(--color-accent); }

  .hiw__item-text { flex: 1; }
  .hiw__item-title {
    font-size: var(--text-base); font-weight: 500; letter-spacing: -0.01em; line-height: 1.3;
    color: var(--color-text-tertiary); transition: color 0.2s ease; margin: 0;
  }
  .hiw__item--active .hiw__item-title, .hiw__item:hover .hiw__item-title { color: var(--color-text-primary); }

  .hiw__beta {
    display: inline-block; margin-left: var(--space-2);
    font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-accent); background: var(--color-accent-light); border: 1px solid var(--color-accent-muted);
    padding: 1px 6px; border-radius: var(--radius-full); vertical-align: middle;
  }

  /* Fixed expanded height keeps the accordion total height constant while cycling. */
  .hiw__item-body {
    overflow: hidden; height: 0; opacity: 0; margin-top: 0;
    transition: height 0.45s var(--ease-smooth), margin-top 0.45s var(--ease-smooth), opacity 0.3s ease;
  }
  .hiw__item--active .hiw__item-body { height: 5.5em; opacity: 1; margin-top: var(--space-3); }
  .hiw__item-body p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: 1.75; }

  /* ── Right column matches the step-list height ── */
  .hiw__right { height: 100%; }
  .hiw__panels { display: grid; height: 100%; }
  .hiw__panel { grid-area: 1 / 1; height: 100%; opacity: 0; pointer-events: none; transition: opacity 0.4s ease; }
  .hiw__panel--active { opacity: 1; pointer-events: auto; }

  @media (max-width: 1023px) {
    .hiw__accordion, .hiw__right, .hiw__panels { display: contents; }
    .hiw__panel { position: static; display: block; height: auto; opacity: 1; pointer-events: auto; transition: none; }
    .hiw__item { border-top: none; }
    .hiw__item:last-child { border-bottom: none; }
    .hiw__progress { display: none; }
    .hiw__num, .hiw__item-title { color: var(--color-text-primary); }
    .hiw__item-body, .hiw__item--active .hiw__item-body { height: auto; opacity: 1; margin-top: var(--space-2); overflow: visible; }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hiw__inner { display: grid; grid-template-columns: 1fr 1fr; column-gap: var(--space-8); row-gap: var(--space-16); align-items: center; }
    .hiw__item { padding: 0; }
    .hiw__item[data-step="0"]  { grid-column: 1; grid-row: 1; }
    .hiw__panel[data-step="0"] { grid-column: 2; grid-row: 1; }
    .hiw__panel[data-step="1"] { grid-column: 1; grid-row: 2; }
    .hiw__item[data-step="1"]  { grid-column: 2; grid-row: 2; }
    .hiw__item[data-step="2"]  { grid-column: 1; grid-row: 3; }
    .hiw__panel[data-step="2"] { grid-column: 2; grid-row: 3; }
    .hiw__panel[data-step="3"] { grid-column: 1; grid-row: 4; }
    .hiw__item[data-step="3"]  { grid-column: 2; grid-row: 4; }
    .hiw__item[data-step="4"]  { grid-column: 1; grid-row: 5; }
    .hiw__panel[data-step="4"] { grid-column: 2; grid-row: 5; }
    .hiw__panel[data-step="5"] { grid-column: 1; grid-row: 6; }
    .hiw__item[data-step="5"]  { grid-column: 2; grid-row: 6; }
  }

  @media (max-width: 767px) {
    .hiw__inner { display: flex; flex-direction: column; align-items: stretch; gap: 0; }
    /* Tight gap from each graphic to its own text; a larger gap and a divider
       below the text so each graphic + caption reads as one group. */
    .hiw__panel { margin-bottom: var(--space-3); }
    .hiw__item { padding: 0 0 var(--space-4); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-8); }
    .hiw__item:last-child { border-bottom: none; margin-bottom: 0; }
    .hiw__panel[data-step="0"] { order: 0; } .hiw__item[data-step="0"] { order: 1; }
    .hiw__panel[data-step="1"] { order: 2; } .hiw__item[data-step="1"] { order: 3; }
    .hiw__panel[data-step="2"] { order: 4; } .hiw__item[data-step="2"] { order: 5; }
    .hiw__panel[data-step="3"] { order: 6; } .hiw__item[data-step="3"] { order: 7; }
    .hiw__panel[data-step="4"] { order: 8; } .hiw__item[data-step="4"] { order: 9; }
    .hiw__panel[data-step="5"] { order: 10; } .hiw__item[data-step="5"] { order: 11; }
  }

  /* ── Scene window ── */
  .scene {
    height: 100%; display: flex; flex-direction: column; overflow: hidden;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-card); font-family: var(--font-family);
  }
  @media (max-width: 1023px) { .scene { height: auto; aspect-ratio: 3 / 4; } }

  .scene__head {
    flex-shrink: 0; display: flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); background: var(--color-surface-elevated);
  }
  .scene__head-title { font-size: 12px; font-weight: 600; color: var(--color-text-primary); }
  .scene__head-sub { font-size: 10px; color: var(--color-text-tertiary); }

  .scene__avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--color-accent-light); border: 1px solid var(--color-accent-muted);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .scene__avatar :global(svg) { width: 17px; height: 17px; display: block; }
  .scene__avatar :global(path) { fill: #000000; }
  .scene__avatar :global(rect) { fill: var(--color-accent); }

  .scene__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-text-tertiary); flex-shrink: 0; }
  .scene__dot--live { background: var(--color-accent); animation: pulse-dot 1.8s ease-in-out infinite; }

  .scene__beta {
    font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-accent); background: var(--color-accent-light); border: 1px solid var(--color-accent-muted);
    padding: 1px 6px; border-radius: var(--radius-full);
  }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  /* ── Chat ── */
  .chat { flex: 1; min-height: 0; display: flex; flex-direction: column; }
  .chat__scroll { flex: 1; min-height: 0; overflow: hidden; display: flex; flex-direction: column; justify-content: flex-end; gap: var(--space-3); padding: var(--space-4); }

  .msg { display: flex; align-items: flex-start; gap: 7px; max-width: 92%; }
  .msg--agent { align-self: flex-start; }
  .msg--user { align-self: flex-end; flex-direction: row-reverse; }

  .msg__av { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
  .msg__av--agent { background: var(--color-accent-light); border: 1px solid var(--color-accent-muted); }
  .msg__av--agent :global(svg) { width: 15px; height: 15px; display: block; }
  .msg__av--agent :global(path) { fill: #000000; }
  .msg__av--agent :global(rect) { fill: var(--color-accent); }
  .msg__av--user { background: var(--color-surface-elevated); border: 1px solid var(--color-border); color: var(--color-text-tertiary); }
  .msg__av--user :global(svg) { display: block; }

  .msg__bubble--agent { font-size: 11.5px; line-height: 1.6; color: var(--color-text-primary); padding-top: 2px; }
  .msg__bubble--user { background: var(--color-cta-bg); color: var(--color-cta-text); padding: 8px 11px; border-radius: 12px 12px 3px 12px; font-size: 11.5px; line-height: 1.5; }

  .msg-quote {
    display: block; margin-top: 8px; border-left: 2px solid var(--color-accent);
    background: var(--color-surface-elevated); border-radius: 0 var(--radius-ui) var(--radius-ui) 0;
    padding: 7px 10px; cursor: pointer; text-decoration: none;
  }
  .msg-quote__text { display: block; font-size: 11px; font-style: italic; color: var(--color-text-primary); line-height: 1.5; }
  .msg-quote .cite { display: inline-flex; margin-top: 5px; }

  .cite {
    font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 10px; font-weight: 500;
    color: var(--color-text-secondary); background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-full); padding: 1px 7px;
  }
  .ai-note { margin-top: 6px; font-size: 10px; color: var(--color-text-tertiary); }

  .choices { display: flex; gap: 6px; margin-top: 8px; }
  .choice { font-size: 10.5px; font-weight: 600; padding: 4px 10px; border-radius: var(--radius-full); border: 1px solid var(--color-border); color: var(--color-text-secondary); background: var(--color-surface); }
  .choice--on { background: var(--color-accent); color: #000000; border-color: var(--color-accent); }

  .lp-status { display: inline-flex; align-items: center; gap: 6px; margin-top: 8px; font-size: 10px; font-weight: 600; color: var(--color-text-secondary); }

  .composer { flex-shrink: 0; padding: var(--space-3) var(--space-4); border-top: 1px solid var(--color-border); background: var(--color-bg); }
  .composer__chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
  .composer__chip { font-size: 10px; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-full); padding: 3px 9px; background: var(--color-surface); white-space: nowrap; }
  .composer__input { display: flex; align-items: center; gap: var(--space-2); border: 1px solid var(--color-border); border-radius: var(--radius-ui); background: var(--color-surface); padding: 6px 6px 6px 11px; }
  .composer__placeholder { flex: 1; font-size: 11.5px; color: var(--color-text-tertiary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .composer__send { width: 26px; height: 26px; border-radius: 6px; flex-shrink: 0; background: var(--color-cta-bg); color: var(--color-cta-text); display: flex; align-items: center; justify-content: center; }
  .composer__send :global(svg) { width: 14px; height: 14px; display: block; }

  /* ── Interview voice room ── */
  .iv__top { flex-shrink: 0; display: flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); }
  .iv__clock { font-size: 11px; font-weight: 600; color: var(--color-text-secondary); font-variant-numeric: tabular-nums; }
  .iv__actions { margin-left: auto; display: flex; gap: 6px; }
  .iv__btn { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 600; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-ui); padding: 3px 8px; }

  .iv__stage { flex: 1; min-height: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-5); padding: var(--space-4); }

  /* Real interview-room orb: the dashboard's WebGL AgentOrb (iridescent shader)
     ported verbatim and run on a canvas. .iv-cssorb is the exact CSS fallback
     used when WebGL is unavailable or reduced-motion is set. */
  .iv-orb { width: 112px; height: 112px; display: grid; place-items: center; }
  .iv-orb canvas { display: block; }
  .iv-cssorb { position: relative; width: 112px; height: 112px; display: grid; place-items: center; }
  .iv-cssorb__core {
    width: 38%; height: 38%; border-radius: 50%; background: var(--color-accent);
    animation: cssorb-core 2.6s ease-in-out infinite;
  }
  .iv-cssorb__ring {
    position: absolute; inset: 0; border-radius: 50%; border: 1px solid var(--color-accent-muted);
    animation: cssorb-ring 2.6s ease-in-out infinite;
  }
  @keyframes cssorb-core {
    0%, 100% { transform: scale(1.01); opacity: 0.62; }
    50% { transform: scale(1.108); opacity: 0.84; }
  }
  @keyframes cssorb-ring {
    0%, 100% { transform: scale(0.734); opacity: 0.32; }
    50% { transform: scale(0.888); opacity: 0.51; }
  }

  .iv__hud { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; justify-content: center; }
  .iv__status { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; color: var(--color-accent); }
  .iv__phase { font-size: 10px; color: var(--color-text-secondary); background: var(--color-surface-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-full); padding: 1px 7px; }
  .iv__conn { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; color: var(--color-text-tertiary); }
  .iv__conn-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; }
  .iv__note { font-size: 10px; color: var(--color-text-tertiary); }

  .iv__bottom { flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: var(--space-3); padding: var(--space-3); border-top: 1px solid var(--color-border); }
  .iv__mute { width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--color-border); background: var(--color-surface); display: flex; align-items: center; justify-content: center; color: var(--color-text-secondary); }
  .iv__switch { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 600; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-ui); padding: 6px 10px; }

  /* ── Synthesis (animated signal flow) ── */
  .synth { flex: 1; min-height: 0; display: flex; flex-direction: column; justify-content: center; gap: var(--space-2); padding: var(--space-3) 0; }

---
/**
 * IcebergSection: "Explizit vs. Implizit" Eisberg.
 * Natives Astro-Component (scoped styles, kein Tailwind: der globale Reset der
 * Site würde Utility-Klassen überschreiben), Vanilla-JS für die Scroll-Effekte.
 *
 * Dramaturgie: Beim Scrollen schiebt sich der Eisberg von unten VOR den Text
 * (z-Ebene über dem Content), die Tool-Chips ziehen sich zur Mitte zusammen
 * und verschwinden hinter dem Berg. Unter der Wasserlinie nimmt der Scroll
 * den Blur vom Unterwasser-Teil und blendet Labels und das Intelligence-
 * Fenster ein.
 */

const HIDDEN = [
  { x: 322, y: 512, label: "Workarounds", side: "left" },
  { x: 472, y: 548, label: "Wissensinseln", side: "right" },
  { x: 292, y: 612, label: "informelle Entscheidungen", side: "left" },
  { x: 482, y: 648, label: "kulturelle Reibung", side: "right" },
  { x: 320, y: 722, label: "unausgesprochene Blocker", side: "left" },
  { x: 458, y: 742, label: "Hidden Expertise", side: "right" },
  { x: 372, y: 940, label: "Automatisierungspotenzial", side: "left" },
];
const LINKS = [[0, 2], [1, 3], [2, 4], [2, 6], [3, 5], [4, 6], [5, 6], [0, 1]];

/* Offizielle Logos liegen unter /public/logos (Wikimedia bzw. Simple Icons).
   Für Celonis gibt es kein offizielles SVG in freien Quellen, daher ein
   neutraler Buchstaben-Avatar statt eines erfundenen Logos. */
const TOOLS = [
  { n: "Celonis", file: "", style: "left:50%;top:6%;transform:translateX(-50%)" },
  { n: "Slack", file: "slack.svg", style: "left:11%;top:24%" },
  { n: "Teams", file: "teams.svg", style: "left:6%;top:50%" },
  { n: "Jira", file: "jira.svg", style: "right:9%;top:22%" },
  { n: "Confluence", file: "confluence.svg", style: "right:6%;top:49%" },
  { n: "Notion", file: "notion.svg", style: "left:18%;top:71%" },
  { n: "Drive", file: "drive.svg", style: "right:16%;top:71%" },
];

const INSIGHTS = [
  { c: "#d4452f", t: "87 % bestätigen kritische Wissensinseln", s: "Aus den Interviews: Schlüsselwissen hängt an einzelnen Personen." },
  { c: "#b07310", t: "5 wiederkehrende Prozessbrüche genannt", s: "In 31 Interviews benannt: Übergaben verlieren Kontext." },
  { c: "#f5a623", t: "Automatisierungspotenzial in Team Operations", s: "73 % nennen manuelle Routinen mit hohem Wiederholungsgrad." },
];

const px = (x: number) => (x / 760) * 100;
const py = (y: number) => (y / 1240) * 100;
const labelTransform = (side: string) =>
  side === "left" ? "translate(calc(-100% - 14px),-50%)" : "translate(14px,-50%)";
---

<div class="ipl" id="ipl">
  <!-- Ebene 0: Hintergründe -->
  <div class="ipl-bg" aria-hidden="true">
    <div class="sky"></div>
    <div class="deep"><div class="grid"></div></div>
    <div class="waterline"><div class="line"></div><div class="fade"></div></div>
  </div>

  <!-- Ebene 30: Eisberg (vor dem Hero-Text) -->
  <div class="berg" aria-hidden="true">
    <div class="berg-inner">
      <svg class="tip" viewBox="0 0 760 1240" preserveAspectRatio="xMidYMid meet">
        <defs>
          <filter id="tipshadow" x="-50%" y="-50%" width="200%" height="200%">
            <feDropShadow dx="0" dy="16" stdDeviation="22" flood-color="#2a5180" flood-opacity="0.24" />
          </filter>
        </defs>
        <g filter="url(#tipshadow)">
          <polygon points="372,44 262,190 158,430 372,430" fill="#d8e8f8" />
          <polygon points="372,44 372,430 478,175" fill="#f4f9ff" />
          <polygon points="478,175 372,430 586,430" fill="#bcd7f0" />
        </g>
        <polyline points="158,430 262,190 372,44 478,175 586,430" fill="none" stroke="#8fb7e0" stroke-width="1.8" opacity="0.85" />
      </svg>

      <svg class="implicit" id="implicitSvg" viewBox="0 0 760 1240" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="nodeglow" cx="50%" cy="50%" r="50%">
            <stop offset="0" stop-color="#f5a623" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#f5a623" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="beamgrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#f5a623" stop-opacity="0" />
            <stop offset="0.5" stop-color="#f5a623" stop-opacity="0.34" />
            <stop offset="1" stop-color="#f5a623" stop-opacity="0" />
          </linearGradient>
          <filter id="soft" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3.4" /></filter>
        </defs>
        <polygon points="158,430 112,580 372,600 372,430" fill="#3a7fbf" />
        <polygon points="372,430 372,600 632,580 586,430" fill="#2c6aa6" />
        <polygon points="112,580 286,830 372,1180 372,600" fill="#1d4f86" />
        <polygon points="372,600 372,1180 458,830 632,580" fill="#143a64" />
        <polygon points="158,430 586,430 632,580 112,580" fill="#f5a623" opacity="0.05" />
        <g class="beam">
          <rect x="120" y="414" width="500" height="34" fill="url(#beamgrad)" />
          <rect x="120" y="430" width="500" height="2.4" fill="#f5a623" opacity="0.9" />
          <rect x="120" y="430" width="500" height="7" fill="#f5a623" opacity="0.4" filter="url(#soft)" />
        </g>
        {LINKS.map(([a, b]) => (
          <line class="conn" x1={HIDDEN[a].x} y1={HIDDEN[a].y} x2={HIDDEN[b].x} y2={HIDDEN[b].y} />
        ))}
        {HIDDEN.map((n) => (
          <g class="node">
            <circle class="glow" cx={n.x} cy={n.y} r="16" fill="url(#nodeglow)" />
            <circle cx={n.x} cy={n.y} r="5" fill="#fff3df" />
            <circle cx={n.x} cy={n.y} r="5" fill="none" stroke="#f5a623" stroke-width="1.3" />
          </g>
        ))}
      </svg>

      {HIDDEN.map((n) => (
        <div class="lbl" style={`left:${px(n.x)}%;top:${py(n.y)}%;transform:${labelTransform(n.side)}`}>{n.label}</div>
      ))}
    </div>
  </div>

  <!-- Ebene 20: Hero-Content (der Berg schiebt sich davor) -->
  <div class="content">
    <section class="stage" id="stage">
      <div class="pin">
        <div class="logos" aria-hidden="true">
          {TOOLS.map((t) => (
            <div class="chip-pos" style={t.style}>
              <div class="chip">
                {t.file
                  ? <img src={`/logos/${t.file}`} width="20" height="20" alt="" />
                  : <span class="avatar">C</span>}
                <span>{t.n}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="hero" id="hero">
          <h1 class="blur-in">Das wertvollste Wissen Ihrer Organisation ist unsichtbar. Bis jetzt.</h1>
          <p class="blur-in d2">Wie bei einem Eisberg liegt der größte Teil des Organisationswissens unter der Oberfläche. Inplicit verbindet Tool-Daten mit gezielten KI-Interviews und macht den verborgenen menschlichen Kontext sichtbar.</p>
          <button class="cta blur-in d3" id="scrollCta" type="button">Verborgenen Organisationskontext erkennen
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v9M4 8l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
        </div>

        <div class="surface-badge">
          <span class="badge light"><span class="dot" style="background:#c2660c;box-shadow:0 0 10px #c2660c"></span>Explizit &amp; sichtbar</span>
        </div>
      </div>
    </section>
  </div>

  <!-- Ebene 40: Unterwasser-Content (über dem Berg) -->
  <div class="content-b">
    <section class="below" id="below">
      <div class="implizit-badge">
        <span class="badge dark"><span class="dot" style="background:#f5a623;box-shadow:0 0 10px #f5a623"></span>Implizit &amp; unsichtbar</span>
      </div>

      <!-- Management-Intelligence-Fenster im Inplicit-App-Look -->
      <div class="card" id="intelCard">
        <div class="win-bar">
          <span class="win-dots"><i></i><i></i><i></i></span>
          <span class="win-title">Inplicit · Management Intelligence</span>
          <span class="live"><span class="dot"></span>Live</span>
        </div>
        <div class="win-body">
          <p class="cap">Verdichtet aus Tool-Daten und 31 gezielten KI-Interviews</p>
          <ul class="ins">
            {INSIGHTS.map((ins) => (
              <li>
                <span class="sev" style={`background:${ins.c}`}></span>
                <span class="txt"><span class="h">{ins.t}</span><span class="s">{ins.s}</span></span>
              </li>
            ))}
          </ul>
        </div>
        <div class="win-foot">In Echtzeit aktualisiert</div>
      </div>
    </section>
  </div>
</div>

<script>
  document.getElementById("scrollCta")?.addEventListener("click", () =>
    document.getElementById("below")?.scrollIntoView({ behavior: "smooth", block: "start" })
  );

  /* Scroll-Dramaturgie (inline styles per Repo-Gotcha #2):
     1) Pin-Phase: Chips ziehen sich zur Pin-Mitte zusammen, schrumpfen und
        blenden am Ende aus (sie verschwinden hinter dem aufsteigenden Berg,
        der auf einer höheren z-Ebene liegt). Der Hero-Text tritt zurück.
     2) Unter der Wasserlinie: Scroll-Fortschritt nimmt den Blur vom
        Unterwasser-Teil, blendet die Labels und das Intelligence-Fenster ein. */
  const stage = document.getElementById("stage");
  const below = document.getElementById("below");
  const hero = document.getElementById("hero");
  const implicitSvg = document.getElementById("implicitSvg");
  const intelCard = document.getElementById("intelCard");
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (stage && !reduce) {
    const chips = [...document.querySelectorAll<HTMLElement>(".chip-pos")].map((el) => ({
      el,
      bt: el.style.transform ? el.style.transform + " " : "",
      tx: 0,
      ty: 0,
    }));
    const lbls = [...document.querySelectorAll<HTMLElement>(".lbl")];
    const pinEl = stage.querySelector(".pin");
    const clamp = (v: number) => Math.min(1, Math.max(0, v));
    const frame = () => {
      const r = stage.getBoundingClientRect();
      const total = r.height - innerHeight;
      const p = total > 0 ? clamp(-r.top / total) : 0;
      /* Bezugspunkt = Pin-Mitte (scrollt nach der Pin-Phase natürlich mit weg). */
      const pr = (pinEl ?? stage).getBoundingClientRect();
      const cx = pr.left + pr.width / 2;
      const cy = pr.top + pr.height * 0.6;
      const f = p * 0.9;
      const s = 1 - 0.45 * p;
      const chipO = 1 - clamp((p - 0.78) / 0.18);
      for (const c of chips) {
        const b = c.el.getBoundingClientRect();
        const baseX = b.left + b.width / 2 - c.tx;
        const baseY = b.top + b.height / 2 - c.ty;
        c.tx = (cx - baseX) * f;
        c.ty = (cy - baseY) * f;
        c.el.style.transform = `${c.bt}translate(${c.tx}px,${c.ty}px) scale(${s})`;
        c.el.style.opacity = String(chipO);
      }
      if (hero) {
        const ho = 1 - clamp((p - 0.6) / 0.32);
        hero.style.opacity = String(ho);
        hero.style.pointerEvents = ho < 0.15 ? "none" : "";
      }
      /* Unterwasser: q = Fortschritt, sobald die dunkle Zone in den Viewport kommt. */
      if (below) {
        const rb = below.getBoundingClientRect();
        const q = clamp((innerHeight * 0.85 - rb.top) / (innerHeight * 0.7));
        if (implicitSvg) implicitSvg.style.filter = q >= 1 ? "none" : `blur(${(1 - q) * 9}px)`;
        for (const l of lbls) {
          l.style.opacity = String(0.15 + 0.85 * q);
          l.style.filter = q >= 1 ? "none" : `blur(${(1 - q) * 6}px)`;
        }
        if (intelCard) {
          intelCard.style.opacity = String(q);
          intelCard.style.transform = `translateX(${(1 - q) * 28}px)`;
        }
      }
    };
    addEventListener("scroll", frame, { passive: true });
    addEventListener("resize", frame);
    frame();
  }
</script>

<style>
  /* overflow-x: clip (statt hidden): hidden würde einen Scroll-Container
     erzeugen und damit das position:sticky des Pins deaktivieren. */
  .ipl { position: relative; width: 100%; overflow-x: clip; background: #fff;
    --stage-h: 220vh; /* Pin-Intro: 100vh sichtbar + 120vh Scrollweg */
    font-family: var(--font-family, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif); -webkit-font-smoothing: antialiased; }
  .ipl svg { display: block; }

  /* Hintergründe */
  .ipl-bg { position: absolute; inset: 0; z-index: 0; }
  .sky { position: absolute; left: 0; top: 0; width: 100%; height: var(--stage-h);
    background:
      radial-gradient(80% 60% at 50% -10%, rgba(194,102,12,.14) 0%, rgba(194,102,12,0) 60%),
      radial-gradient(60% 50% at 85% 20%, rgba(245,166,35,.10) 0%, rgba(245,166,35,0) 55%),
      linear-gradient(180deg,#fff 0%,#fdfaf6 62%,#f4eee5 100%); }
  .deep { position: absolute; left: 0; top: var(--stage-h); bottom: 0; width: 100%; overflow: hidden;
    background:
      radial-gradient(90% 70% at 80% 12%, rgba(245,166,35,.10) 0%, rgba(8,12,22,0) 55%),
      linear-gradient(180deg,#0b1120 0%,#0a0f1c 55%,#070b15 100%); }
  .deep .grid { position: absolute; inset: 0;
    background-image: linear-gradient(rgba(150,180,220,.05) 1px,transparent 1px), linear-gradient(90deg,rgba(150,180,220,.05) 1px,transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(110% 80% at 45% 25%,#000 35%,transparent 100%);
            mask-image: radial-gradient(110% 80% at 45% 25%,#000 35%,transparent 100%); }
  .waterline { position: absolute; left: 0; top: var(--stage-h); width: 100%; }
  .waterline .line { height: 1px; width: 100%; background: linear-gradient(90deg,transparent,rgba(245,166,35,.55) 30%,rgba(255,255,255,.55) 50%,rgba(245,166,35,.55) 70%,transparent); }
  .waterline .fade { height: 112px; width: 100%; background: linear-gradient(180deg,rgba(245,166,35,.10),transparent); }

  /* Eisberg: z-30, schiebt sich beim Scrollen VOR den Hero-Text (z-20) */
  .berg { position: absolute; left: 40%; top: var(--stage-h); transform: translateX(-50%); z-index: 30; pointer-events: none; }
  .berg-inner { position: relative; width: min(840px,94vw); aspect-ratio: 760/1240; transform: translateY(-34.7%); }
  .berg-inner svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .node .glow { transform-box: fill-box; transform-origin: center; animation: pulse 3.2s ease-in-out infinite; }
  .conn { stroke: #f5a623; stroke-width: 1.1; opacity: .5; }
  /* Ambient-Scan in ruhiger Schleife */
  .beam { opacity: 0; animation: beam 7s ease-in-out 1.5s infinite; }

  .lbl { position: absolute; white-space: nowrap; font-size: 12.5px; font-weight: 500; letter-spacing: .02em;
    color: #f5a623; text-shadow: 0 0 14px rgba(194,102,12,.4); }

  /* Hero-Content */
  .content { position: relative; z-index: 20; }
  .stage { position: relative; height: var(--stage-h); }
  .pin { position: sticky; top: 0; display: flex; height: 100vh; flex-direction: column; }
  .logos { position: absolute; inset: 0; pointer-events: none; }
  .chip-pos { position: absolute; will-change: transform; }
  .chip { display: inline-flex; align-items: center; gap: 8px; background: #fff;
    border: 1px solid rgba(0,0,0,.06); border-radius: 12px; padding: 8px 12px;
    box-shadow: 0 10px 26px -14px rgba(20,40,80,.35); animation: float 6s ease-in-out infinite; }
  .chip img { display: block; }
  .chip .avatar { display: grid; place-items: center; width: 20px; height: 20px; border-radius: 5px;
    background: #eceae7; font-size: 11px; font-weight: 600; color: #52525b; }
  .chip span:last-child { font-size: 13px; font-weight: 500; color: #262626; letter-spacing: 0; }
  .hero { position: relative; margin: 0 auto; display: flex; flex: 1; max-width: 1152px;
    flex-direction: column; align-items: center; justify-content: center; padding: 80px 24px 0; text-align: center; }
  .hero h1 { margin: 0; max-width: 820px; font-size: clamp(34px,5vw,54px); font-weight: 600;
    line-height: 1.08; letter-spacing: -.02em; color: #0a0a0a; text-wrap: balance; }
  .hero p { margin: 20px 0 0; max-width: 620px; font-size: clamp(16px,1.6vw,18px); line-height: 1.6; color: #525252; text-wrap: pretty; }
  .blur-in { animation: blurIn .9s cubic-bezier(.22,1,.36,1) .15s backwards; }
  .blur-in.d2 { animation-delay: .38s; }
  .blur-in.d3 { animation-delay: .6s; }
  .cta { margin-top: 32px; display: inline-flex; align-items: center; gap: 8px; background: #0a0a0a; color: #fff;
    border: none; border-radius: 12px; padding: 13px 22px; font-family: inherit; font-size: 14px; font-weight: 600; cursor: pointer;
    box-shadow: 0 16px 36px -12px rgba(0,0,0,.55); transition: transform .2s; }
  .cta:hover { transform: translateY(-2px); }
  .surface-badge { display: flex; justify-content: center; padding-bottom: 40px; }
  .badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 5px 12px;
    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .16em; backdrop-filter: blur(6px); }
  .badge.light { border: 1px solid rgba(0,0,0,.1); background: rgba(255,255,255,.7); color: #71717a; }
  .badge.dark { border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.04); color: rgba(255,255,255,.55); }
  .badge .dot { width: 6px; height: 6px; border-radius: 50%; animation: live 2.2s ease-in-out infinite; }

  /* Unterwasser-Content (z-40, über dem Berg) */
  .content-b { position: relative; z-index: 40; }
  /* Höhe folgt dem Kiel (Unterwasser-Anteil ca. Breite × 810/760) plus Luft,
     damit der Erklärtext direkt nach dem Berg beginnt. */
  .below { position: relative; min-height: calc(min(840px, 94vw) * 1.12); width: 100%; }
  .implizit-badge { display: flex; justify-content: center; padding-top: 48px; }

  /* Intelligence-Fenster im Inplicit-App-Look: helles Fenster, ruhige Ränder */
  .card { position: absolute; right: 5%; top: 22%; width: 380px; max-width: calc(100vw - 48px);
    background: #fff; border: 1px solid rgba(0,0,0,.08); border-radius: var(--radius-card, 8px);
    box-shadow: 0 24px 60px -24px rgba(0,0,0,.55); overflow: hidden; }
  .win-bar { display: flex; align-items: center; gap: 10px; padding: 10px 14px;
    border-bottom: 1px solid rgba(0,0,0,.06); background: #fafafa; }
  .win-dots { display: inline-flex; gap: 5px; }
  .win-dots i { width: 8px; height: 8px; border-radius: 50%; background: #e3e0dc; }
  .win-title { flex: 1; font-size: 12px; font-weight: 500; color: rgba(0,0,0,.55);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .live { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .08em; color: rgba(0,0,0,.45); }
  .live .dot { width: 6px; height: 6px; border-radius: 50%; background: #f5a623; animation: live 2.2s ease-in-out infinite; }
  .win-body { padding: 14px; }
  .win-body .cap { margin: 0 0 12px; font-size: 11px; line-height: 1.4; color: rgba(0,0,0,.45); }
  .ins { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .ins li { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px;
    border: 1px solid rgba(0,0,0,.06); border-radius: var(--radius-ui, 6px); background: #fafafa; }
  .ins .sev { flex: 0 0 auto; width: 7px; height: 7px; border-radius: 50%; margin-top: 5px; }
  .ins .h { display: block; font-size: 13.5px; font-weight: 550; line-height: 1.35; color: #0a0a0a; }
  .ins .s { display: block; margin-top: 2px; font-size: 12px; line-height: 1.4; color: rgba(0,0,0,.55); }
  .win-foot { padding: 9px 14px; border-top: 1px solid rgba(0,0,0,.06); font-size: 10px; font-weight: 500;
    text-transform: uppercase; letter-spacing: .08em; color: rgba(0,0,0,.4); }

  @keyframes blurIn { from { opacity: 0; filter: blur(14px); transform: translateY(14px); } to { opacity: 1; filter: blur(0); transform: translateY(0); } }
  @keyframes pulse { 0%,100% { opacity: .4; transform: scale(1); } 50% { opacity: .75; transform: scale(1.2); } }
  @keyframes live { 0%,100% { opacity: .4; } 50% { opacity: 1; } }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
  @keyframes beam { 0% { opacity: 0; transform: translateY(0); } 8% { opacity: .9; } 55% { opacity: .9; } 68% { opacity: 0; transform: translateY(770px); } 100% { opacity: 0; transform: translateY(770px); } }

  @media (max-width: 768px) {
    .logos { display: none; }
  }
  @media (max-width: 640px) {
    .lbl { display: none; }
    .card { position: static; width: auto; margin: 480px auto 0; transform: none !important; }
  }
  @media (prefers-reduced-motion: reduce) {
    .node .glow, .badge .dot, .live .dot, .chip, .beam { animation: none !important; }
    .blur-in { animation: none !important; }
  }
</style>

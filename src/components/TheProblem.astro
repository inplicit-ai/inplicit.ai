---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const cards = lang === 'de' ? [
  {
    tag: 'Verborgenes Prozesswissen',
    title: 'Organisationswissen steckt in Köpfen',
    body: 'Viele Abläufe und Entscheidungen sind nicht sauber dokumentiert. Wenn Mitarbeitende gehen oder Teams wachsen, geht genau dieses Wissen leicht verloren.',
    cta: 'Inplicit macht verborgenes Wissen durch KI-Interviews sichtbar und strukturiert nutzbar.',
  },
  {
    tag: 'Fehlendes operatives Know-how',
    title: 'Entscheidungen brauchen mehr internen Kontext',
    body: 'Oft fehlt Management der Blick auf das, was operativ wirklich passiert. Dadurch werden wichtige Entscheidungen mit zu wenig Nähe zur Praxis getroffen.',
    cta: 'Inplicit bringt die operative Realität strukturiert zur Entscheidungsebene.',
  },
  {
    tag: 'Fehlende Kontext-Ebene',
    title: 'KI braucht Unternehmensrealität',
    body: 'Damit KI im Unternehmen sinnvoll hilft, braucht sie mehr als Dokumente. Sie braucht Kontext aus Menschen, Prozessen und gelebter Erfahrung.',
    cta: 'Inplicit liefert die Kontext-Ebene und belastbares Organisationswissen, auf das KI-Systeme zugreifen können.',
  },
] : [
  {
    tag: 'Hidden process knowledge',
    title: 'Organisational knowledge lives in people\'s heads',
    body: 'Many processes and decisions are never documented properly. When employees leave or teams grow, exactly this knowledge is easily lost.',
    cta: 'inplicit makes hidden knowledge visible and structured through AI-led interviews.',
  },
  {
    tag: 'Missing operational context',
    title: 'Decisions need more internal context',
    body: 'Management often lacks visibility into what is actually happening operationally. This leads to important decisions being made without sufficient proximity to practice.',
    cta: 'inplicit brings operational reality to the decision-making level in structured form.',
  },
  {
    tag: 'Missing context layer',
    title: 'AI needs organisational reality',
    body: 'For AI to be genuinely useful in organisations, it needs more than documents. It needs context from people, processes, and lived experience.',
    cta: 'inplicit delivers the context layer and reliable organisational knowledge that AI systems can draw on.',
  },
]
---

<section class="problem" id="the-problem">
  <div class="container">
    <p class="problem__eyebrow section-fade">
      {lang === 'de' ? 'Probleme & Usecases' : 'Problems & use cases'}
    </p>

    <div class="problem__cols">
      {cards.map((card, i) => (
        <div class="problem__card section-fade" style={`--delay: ${i * 80}ms`}>
          <div class="problem__card-tag">{card.tag}</div>
          <h3 class="problem__card-title">{card.title}</h3>
          <p class="problem__card-body">{card.body}</p>
          <div class="problem__card-rule" aria-hidden="true"></div>
          <p class="problem__card-cta">
            <span class="problem__card-arrow" aria-hidden="true">→</span>
            {card.cta}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problem {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .problem { padding: var(--space-24) 0; }
  }

  .problem__eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-10);
  }

  /* 3-column grid */
  .problem__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  @media (max-width: 900px) {
    .problem__cols { grid-template-columns: 1fr 1fr; gap: var(--space-6); }
  }

  @media (max-width: 600px) {
    .problem__cols { grid-template-columns: 1fr; gap: var(--space-6); }
  }

  /* Card */
  .problem__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Black pill tag */
  .problem__card-tag {
    display: inline-flex;
    align-self: flex-start;
    padding: 5px 10px;
    background: var(--color-text-primary);
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    border-radius: var(--radius-ui);
    line-height: 1;
  }

  .problem__card-title {
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin: 0;
  }

  .problem__card-body {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.75;
    flex: 1;
  }

  /* Amber separator line */
  .problem__card-rule {
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Amber arrow CTA text */
  .problem__card-cta {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1.65;
  }

  .problem__card-arrow {
    margin-right: var(--space-1);
  }
</style>

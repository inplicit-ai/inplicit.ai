---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const cards = lang === 'de' ? [
  {
    tag: 'Verborgenes Prozesswissen',
    title: 'Organisationswissen steckt in Köpfen',
    body: 'Viele Abläufe und Entscheidungen sind nicht sauber dokumentiert. Wenn Mitarbeitende gehen oder Teams wachsen, geht genau dieses Wissen leicht verloren.',
    cta: 'Inplicit macht verborgenes Wissen durch KI-Interviews sichtbar und strukturiert nutzbar.',
    grad: 'linear-gradient(135deg, #7a3e00 0%, #c47208 55%, #f5a623 100%)',
  },
  {
    tag: 'Fehlendes operatives Know-how',
    title: 'Entscheidungen brauchen mehr internen Kontext',
    body: 'Oft fehlt Management der Blick auf das, was operativ wirklich passiert. Dadurch werden wichtige Entscheidungen mit zu wenig Nähe zur Praxis getroffen.',
    cta: 'Inplicit bringt die operative Realität strukturiert zur Entscheidungsebene.',
    grad: 'linear-gradient(150deg, #7a3e00 0%, #bf6e0a 50%, #e8830f 100%)',
  },
  {
    tag: 'Fehlende Kontext-Ebene',
    title: 'KI braucht Unternehmensrealität',
    body: 'Damit KI im Unternehmen sinnvoll hilft, braucht sie mehr als Dokumente. Sie braucht Kontext aus Menschen, Prozessen und gelebter Erfahrung.',
    cta: 'Inplicit liefert die Kontext-Ebene und belastbares Organisationswissen, auf das KI-Systeme zugreifen können.',
    grad: 'linear-gradient(120deg, #7a3e00 0%, #c47208 50%, #f5a623 100%)',
  },
] : [
  {
    tag: 'Hidden process knowledge',
    title: 'Organisational knowledge lives in people\'s heads',
    body: 'Many processes and decisions are never properly documented. When employees leave or teams grow, exactly this knowledge is easily lost.',
    cta: 'inplicit makes hidden knowledge visible and structured through AI-led interviews.',
    grad: 'linear-gradient(135deg, #7a3e00 0%, #c47208 55%, #f5a623 100%)',
  },
  {
    tag: 'Missing operational context',
    title: 'Decisions need more internal context',
    body: 'Management often lacks visibility into what is actually happening operationally. Important decisions get made without sufficient proximity to practice.',
    cta: 'inplicit brings operational reality to the decision-making level in structured form.',
    grad: 'linear-gradient(150deg, #7a3e00 0%, #bf6e0a 50%, #e8830f 100%)',
  },
  {
    tag: 'Missing context layer',
    title: 'AI needs organisational reality',
    body: 'For AI to be genuinely useful, it needs more than documents. It needs context from people, processes, and lived organisational experience.',
    cta: 'inplicit delivers the context layer and reliable organisational knowledge that AI systems can draw on.',
    grad: 'linear-gradient(120deg, #7a3e00 0%, #c47208 50%, #f5a623 100%)',
  },
]
---

<section class="problem" id="the-problem">
  <div class="container">
    <p class="section-eyebrow section-fade">
      {lang === 'de' ? 'Probleme & Usecases' : 'Problems & use cases'}
    </p>

    <div class="problem__cols">
      {cards.map((card, i) => (
        <article class="problem__card section-fade" style={`--delay: ${i * 80}ms`}>
          <div class="problem__card-image" style={`background: ${card.grad}`} aria-hidden="true"></div>
          <div class="problem__card-body-wrap">
            <div class="problem__card-tag">{card.tag}</div>
            <h3 class="problem__card-title">{card.title}</h3>
            <p class="problem__card-body">{card.body}</p>
            <div class="problem__card-footer">
              <div class="problem__card-rule" aria-hidden="true"></div>
              <p class="problem__card-cta">
                <span aria-hidden="true">→ </span>{card.cta}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .problem {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .problem { padding: var(--space-24) 0; }
  }

  .problem__eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-10);
  }

  .problem__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  @media (max-width: 860px) {
    .problem__cols { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .problem__cols { grid-template-columns: 1fr; }
  }

  /* Card shell */
  .problem__card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 18px;
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(0.22,1,0.36,1),
                box-shadow 0.28s cubic-bezier(0.22,1,0.36,1),
                border-color 0.28s ease;
  }

  .problem__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 48px -20px rgba(15,23,42,0.18), 0 0 0 1px rgba(15,23,42,0.05);
    border-color: rgba(0,0,0,0.11);
  }

  /* Gradient image area */
  .problem__card-image {
    width: 100%;
    height: 160px;
    flex-shrink: 0;
  }

  /* Content area */
  .problem__card-body-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    flex: 1;
  }

  /* Black pill tag */
  .problem__card-tag {
    display: inline-flex;
    align-self: flex-start;
    padding: 4px 10px;
    background: #111111;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    border-radius: 6px;
    line-height: 1.4;
  }

  .problem__card-title {
    font-size: var(--text-lg);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0;
  }

  .problem__card-body {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  /* Footer: amber rule + CTA */
  .problem__card-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .problem__card-rule {
    width: 28px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .problem__card-cta {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1.65;
  }

  @media (prefers-reduced-motion: reduce) {
    .problem__card { transition: none; }
    .problem__card:hover { transform: none; }
  }
</style>

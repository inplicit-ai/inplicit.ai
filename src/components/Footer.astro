---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const year = new Date().getFullYear();

const mainLinks = lang === 'de'
  ? [
      { href: '/de/#how-it-works', label: 'Wie es funktioniert' },
      { href: '/de/#request-pilot', label: 'Jetzt starten' },
    ]
  : [
      { href: '/#how-it-works', label: 'How it works' },
      { href: '/#request-pilot', label: 'Join Waitlist' },
    ];

const legalLinks = lang === 'de'
  ? [
      { href: '/imprint', label: 'Impressum' },
      { href: '/privacy', label: 'Datenschutz' },
      { href: '/terms', label: 'AGB' },
    ]
  : [
      { href: '/imprint', label: 'Imprint' },
      { href: '/privacy', label: 'Privacy' },
      { href: '/terms', label: 'Terms' },
    ];
---

<footer class="footer">
  <div class="footer__inner container">

    <div class="footer__top">
     <a href={lang === 'de' ? '/de/' : '/'} class="nav__logo" aria-label="inplicit.ai home">
      <img class="footer__logo-img" src="/logo-inverted.png" alt="inplicit.ai" width="794" height="232" />
    </a>

      <!-- <ul class="footer__social" role="list">
        <li>
          <a
            href="https://linkedin.com/company/inplicit-ai"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-btn"
            aria-label="LinkedIn"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </li>
      </ul> -->
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">© {year} inplicit.ai</p>

      <nav class="footer__nav" aria-label={lang === 'de' ? 'Hauptnavigation' : 'Main navigation'}>
        {mainLinks.map((link) => (
          <a href={link.href} class="footer__nav-link">{link.label}</a>
        ))}
      </nav>

      <nav class="footer__legal" aria-label={lang === 'de' ? 'Rechtliches' : 'Legal'}>
        {legalLinks.map((link) => (
          <a href={link.href} class="footer__legal-link">{link.label}</a>
        ))}
      </nav>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: #0a0a0a;
    border-top: none;
    padding: var(--space-12) 0 var(--space-8);
    color: #ffffff;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

    .nav__logo {
    display: flex;
    align-items: center;
    transition: opacity 0.15s var(--ease-smooth);
  }

  .nav__logo:hover { opacity: 0.7; }

  .footer__logo-img {
    height: 20px;
    width: auto;
    display: block;
  }

  .footer__social {
    display: flex;
    list-style: none;
    gap: var(--space-2);
  }

  .footer__social-btn {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-tertiary);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }

  .footer__social-btn:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .footer__copy {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.35);
    margin-right: auto;
    font-variant-numeric: tabular-nums;
  }

  .footer__nav,
  .footer__legal {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.15s var(--ease-smooth);
  }

  .footer__nav-link:hover { color: #ffffff; }

  .footer__legal-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.15s var(--ease-smooth);
  }

  .footer__legal-link:hover { color: rgba(255, 255, 255, 0.6); }

  @media (max-width: 640px) {
    .footer__bottom { flex-direction: column; align-items: flex-start; }
    .footer__copy { margin-right: 0; }
  }
</style>

---
export interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;
const isDE = lang === 'de';

interface TrustItem {
  icon: string;
  title: string;
  body: string;
}

const items: TrustItem[] = isDE ? [
  {
    icon: 'shield',
    title: 'DSGVO & EU AI Act konform',
    body: 'Auftragsverarbeitungsvertrag, Betriebsrat-ready, klare Rechtsgrundlagen. Alles, was Ihr Unternehmen für einen rechtssicheren Einsatz braucht.',
  },
  {
    icon: 'server',
    title: 'Daten bleiben in der EU',
    body: 'Alle Gesprächsdaten verbleiben auf europäischer Infrastruktur. Kein Transfer in Drittstaaten für Kernprozesse.',
  },
  /* Temporarily disabled — "no training on interview data" claim
  {
    icon: 'lock',
    title: 'Kein Training auf Interviews',
    body: 'Gespräche und Antworten Ihrer Mitarbeitenden fließen nicht in Modelltraining. Null. Vertraglich zugesichert.',
  },
  */
  {
    icon: 'user',
    title: 'Freiwillig & anonym',
    body: 'Mitarbeitende entscheiden selbst, was sie teilen. inplicit wertet nur aus, was freiwillig gegeben und vollständig anonymisiert wurde.',
  },
] : [
  {
    icon: 'shield',
    title: 'GDPR & EU AI Act compliant',
    body: 'Data processing agreement, works-council ready, clear legal framework. Everything your organisation needs for compliant deployment.',
  },
  {
    icon: 'server',
    title: 'Data stays in the EU',
    body: 'All conversation data stays on European infrastructure. No transfer to third countries for core processes.',
  },
  /* Temporarily disabled — "no training on interview data" claim
  {
    icon: 'lock',
    title: 'No training on interviews',
    body: 'Conversations and employee responses do not flow into model training. Zero. Contractually guaranteed.',
  },
  */
  {
    icon: 'user',
    title: 'Voluntary & anonymous',
    body: 'Employees decide what they share. inplicit only analyses what is given voluntarily and fully anonymised.',
  },
];
---

<section class="trust" id="trust-security">
  <div class="container">

    <div class="trust__header section-fade">
      <span class="section-eyebrow">
        {isDE ? 'Vertrauen & Sicherheit' : 'Trust & Security'}
      </span>
      <h2 class="trust__heading">
        <span class="trust__line1">
          {isDE ? 'Vertrauen ist' : 'Security as'}
        </span>
        <span class="trust__line2">
          {isDE ? 'das Produkt' : 'main product.'}
        </span>
      </h2>
      <p class="trust__sub">
        {isDE
          ? 'Organisationen arbeiten mit sensiblen Daten. Deshalb ist Vertrauen für uns kein Feature, sondern das Fundament.'
          : 'Organisations work with sensitive data. That is why trust is not a feature for us. It is the foundation.'}
      </p>
    </div>

    <div class="trust__grid">
      {items.map((item, i) => (
        <div class="trust__card section-fade" style={`--delay: ${i * 80}ms`}>
          <div class="trust__card-icon" aria-hidden="true">
            {item.icon === 'shield' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            )}
            {item.icon === 'server' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="8" rx="2"/>
                <rect x="2" y="14" width="20" height="8" rx="2"/>
                <line x1="6" y1="6" x2="6.01" y2="6"/>
                <line x1="6" y1="18" x2="6.01" y2="18"/>
              </svg>
            )}
            {item.icon === 'lock' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            )}
            {item.icon === 'user' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            )}
          </div>
          <h3 class="trust__card-title">{item.title}</h3>
          <p class="trust__card-body">{item.body}</p>
        </div>
      ))}
    </div>

    <div class="trust__cta-wrap section-fade">
      <button class="trust__cta-link trust__cta-link--soon" type="button" disabled aria-disabled="true">
        {isDE ? 'Trust Center' : 'Trust Center'}
        <span class="trust__cta-soon">{isDE ? 'Bald verfügbar' : 'Coming soon'}</span>
      </button>
    </div>

  </div>
</section>

<style>
  .trust {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .trust { padding: var(--space-24) 0; }
  }

  .trust__header {
    margin-bottom: var(--space-16);
    max-width: 620px;
  }

  @media (max-width: 767px) {
    .trust__header { margin-bottom: var(--space-12); }
  }

  .trust__heading {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    margin-bottom: var(--space-4);
  }

  .trust__line1 { color: var(--color-text-primary); }
  .trust__line2 { color: var(--color-text-primary); opacity: 0.3; }

  .trust__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Grid - matches Applications */
  .trust__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
  }

  /* 3 items → one clean row on desktop (a 2-col grid would orphan the 3rd) */
  @media (min-width: 768px) {
    .trust__grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Card - matches Applications exactly */
  .trust__card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color 0.2s var(--ease-smooth);
  }

  .trust__card:hover { border-color: var(--color-text-tertiary); }

  .trust__card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-ui);
    color: var(--color-text-secondary);
    flex-shrink: 0;
    transition: color 0.2s var(--ease-smooth), border-color 0.2s var(--ease-smooth), background 0.2s var(--ease-smooth);
  }

  .trust__card:hover .trust__card-icon {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .trust__card-title {
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .trust__card-body {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  @media (max-width: 767px) {
    .trust__card { padding: var(--space-6); }
  }

  /* CTA link - matches hero secondary CTA */
  .trust__cta-wrap {
    display: flex;
  }

  .trust__cta-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    height: 48px;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    font-weight: 500;
    border-radius: var(--radius-ui);
    border: 1px solid var(--color-border);
    transition: color 0.15s var(--ease-smooth), border-color 0.15s var(--ease-smooth);
  }

  .trust__cta-link:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-tertiary);
  }

  /* Coming-soon state — non-interactive */
  .trust__cta-link--soon {
    font-family: var(--font-family);
    color: var(--color-text-tertiary);
    cursor: not-allowed;
  }

  .trust__cta-link--soon:hover {
    color: var(--color-text-tertiary);
    border-color: var(--color-border);
  }

  .trust__cta-soon {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-light);
    border: 1px solid var(--color-accent-muted);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }
</style>

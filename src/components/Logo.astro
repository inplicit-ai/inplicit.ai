---
// Animated inplicit logo: the loader mark (rotating square + orbiting
// orange/white circles) reveals first, then the "Inplicit" wordmark wipes in.
import wordmarkRaw from '../assets/wordmark.svg?raw';

// Scaled SQUARE path for InplicitLoader (44-unit space, matches UspViz loader)
const SQ = 'M37.71 33.80 L10.24 37.71 L6.31 10.24 L33.80 6.31 Z';
---

<span class="ilogo" aria-hidden="true">
  <svg class="ilogo__mark" viewBox="5 5 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d={SQ} class="ilogo__sq" />
    <circle class="ilogo__w" cx="20.41" cy="20.38" r="5.23" />
    <circle class="ilogo__o" cx="23.59" cy="23.90" r="5.23" />
  </svg>
  <span class="ilogo__word" set:html={wordmarkRaw}></span>
</span>

<style>
  .ilogo {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--color-text-primary);
  }

  .ilogo__mark {
    height: 24px;
    width: 24px;
    flex-shrink: 0;
    opacity: 0;
    transform: scale(0.4) rotate(-12deg);
    transform-origin: center;
    animation: ilogo-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s forwards;
  }
  .ilogo__sq { fill: var(--color-text-primary); }
  .ilogo__w  { fill: var(--logo-hole, #fff); }
  .ilogo__o  { fill: var(--color-accent); }

  .ilogo__word {
    display: inline-flex;
    /* revealed left → right after the mark pops in */
    clip-path: inset(0 100% 0 0);
    animation: ilogo-wipe 0.7s cubic-bezier(0.2, 0, 0, 1) 0.5s forwards;
  }
  .ilogo__word :global(svg) {
    height: 17px;
    width: auto;
    display: block;
  }
  .ilogo__word :global(path) { fill: var(--color-text-primary); }

  @keyframes ilogo-pop {
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  @keyframes ilogo-wipe {
    to { clip-path: inset(0 0 0 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ilogo__mark { opacity: 1; transform: none; animation: none; }
    .ilogo__word { clip-path: none; animation: none; }
  }
</style>

<script>
  // InplicitLoader — orbiting orange/white circles (vanilla-JS port, slow idle
  // speed for a nav mark). Skipped under reduced-motion.
  {
    const R = 128.405, Mx = 539.95, My = 543.84, Ox = 38.85, Oy = 42.71, DEPTH = 0.13, DUR = 2600, S = 44 / 1080;
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.ilogo__mark').forEach((svg) => {
        const w = svg.querySelector<SVGCircleElement>('.ilogo__w');
        const o = svg.querySelector<SVGCircleElement>('.ilogo__o');
        if (!w || !o) return;
        let t0: number | null = null;
        const set = (el: SVGCircleElement, cx: number, cy: number, r: number) => {
          el.setAttribute('cx', (cx * S).toFixed(2));
          el.setAttribute('cy', (cy * S).toFixed(2));
          el.setAttribute('r', (r * S).toFixed(2));
        };
        const tick = (now: number) => {
          if (t0 === null) t0 = now;
          const a = (((now - t0) % DUR) / DUR) * 2 * Math.PI;
          const cos = Math.cos(a), sin = Math.sin(a);
          set(w, Mx - Ox * cos, My - Oy * cos, R * (1 + DEPTH * sin));
          set(o, Mx + Ox * cos, My + Oy * cos, R * (1 - DEPTH * sin));
          const front = sin >= 0 ? w : o;
          if (front.parentNode && front.parentNode.lastChild !== front) front.parentNode.appendChild(front);
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }
  }
</script>

---
/**
 * ImplicitKnowledge: Erklärteil. Was ist implizites Wissen, warum ist es
 * wertvoll, was kostet seine Unsichtbarkeit. Nummerierte Fußnoten verweisen
 * auf die Quellenliste am Ende. Dunkle Fortsetzung der Unterwasser-Zone.
 */

const REASONS = [
  {
    t: "Rohstoff für Innovation",
    b: "Neues organisationales Wissen entsteht, wenn implizites Wissen ausgesprochen, geteilt und mit explizitem Wissen kombiniert wird. Das ist der Kern des SECI-Modells von Nonaka und Takeuchi. Wer nur auf Dokumentiertes schaut, recycelt Bestehendes.",
    refs: [2],
  },
  {
    t: "Wettbewerbsvorteil, der nicht kopierbar ist",
    b: "Die wissensbasierte Theorie der Firma zeigt: Nachhaltige Vorteile entstehen aus Wissen, das Wettbewerber nicht imitieren können. Explizites Wissen lässt sich kopieren, erfahrungsgebundenes implizites Wissen nicht.",
    refs: [3],
  },
  {
    t: "Produktivität, die nicht von allein skaliert",
    b: "Bewährte Praktiken verbreiten sich nicht von selbst: Ihr Transfer scheitert an interner „Stickiness“, vor allem weil das entscheidende Wissen implizit ist. Sichtbarmachung senkt genau diese Barriere.",
    refs: [4],
  },
  {
    t: "Risiken, die niemand ausspricht",
    b: "Organisationale Stille: Mitarbeitende halten Probleme, Bedenken und Ideen systematisch zurück, wenn Sprechen riskant wirkt. Mit jedem Abgang verlässt zudem kritisches Erfahrungswissen das Unternehmen, oft unwiederbringlich.",
    refs: [5, 6],
  },
];

const STATS = [
  { v: "42 %", l: "des Unternehmenswissens existiert nur in den Köpfen der Mitarbeitenden", r: 8 },
  { v: "5,3 Std.", l: "wartet ein Mitarbeitender pro Woche im Schnitt auf Wissen, das Kolleg:innen bereits haben", r: 7 },
  { v: "47 Mio. $", l: "verlieren große Unternehmen im Schnitt pro Jahr durch ineffizient geteiltes Wissen", r: 7 },
];

const SOURCES = [
  { t: "Polanyi, M. (1966): The Tacit Dimension. University of Chicago Press.", href: "https://scholar.google.com/scholar?q=Polanyi+%22The+Tacit+Dimension%22+1966" },
  { t: "Nonaka, I.; Takeuchi, H. (1995): The Knowledge-Creating Company. Oxford University Press.", href: "https://scholar.google.com/scholar?q=Nonaka+Takeuchi+%22The+Knowledge-Creating+Company%22+1995" },
  { t: "Grant, R. M. (1996): Toward a Knowledge-Based Theory of the Firm. Strategic Management Journal 17 (S2), 109–122.", href: "https://doi.org/10.1002/smj.4250171110" },
  { t: "Szulanski, G. (1996): Exploring Internal Stickiness: Impediments to the Transfer of Best Practice Within the Firm. Strategic Management Journal 17 (S2), 27–43.", href: "https://doi.org/10.1002/smj.4250171105" },
  { t: "Morrison, E. W.; Milliken, F. J. (2000): Organizational Silence: A Barrier to Change and Development in a Pluralistic World. Academy of Management Review 25 (4), 706–725.", href: "https://doi.org/10.5465/amr.2000.3707697" },
  { t: "DeLong, D. W. (2004): Lost Knowledge: Confronting the Threat of an Aging Workforce. Oxford University Press.", href: "https://scholar.google.com/scholar?q=DeLong+%22Lost+Knowledge%22+2004+aging+workforce" },
  { t: "Panopto (2018): Workplace Knowledge and Productivity Report.", href: "https://www.panopto.com/resource/valuing-workplace-knowledge/" },
  { t: "Delphi Group (2002): Taxonomy & Content Classification. Marktstudie.", href: "https://scholar.google.com/scholar?q=Delphi+Group+%22Taxonomy+%26+Content+Classification%22" },
];
---

<section class="ik" id="implizites-wissen">
  <div class="wrap">
    <span class="eyebrow">Implizites Wissen</span>
    <h2 class="fx">Die unsichtbaren 80 Prozent.</h2>
    <p class="lead fx">
      <strong>Implizites Wissen</strong> (englisch <em>tacit knowledge</em>) ist Wissen, das unser Handeln leitet,
      sich aber kaum vollständig artikulieren oder dokumentieren lässt: Erfahrung, eingespielte Routinen,
      Urteilsvermögen, informelle Netzwerke.<a class="ref" href="#ik-src-1"><sup>1</sup></a> Explizites Wissen
      dagegen steht in Tickets, Wikis und Dashboards. In der Wissensmanagement-Literatur wird dieses Verhältnis
      oft mit dem <strong>Eisbergmodell</strong> erklärt: Sichtbar ist nur die Spitze, der weitaus größere Teil
      liegt unter der Oberfläche.<a class="ref" href="#ik-src-2"><sup>2</sup></a>
    </p>

    <figure class="quote fx">
      <blockquote>„Wir wissen mehr, als wir zu sagen wissen.“</blockquote>
      <figcaption>Michael Polanyi, The Tacit Dimension (1966)<a class="ref" href="#ik-src-1"><sup>1</sup></a></figcaption>
    </figure>

    <div class="stats fx">
      {STATS.map((s) => (
        <div class="stat">
          <span class="v">{s.v}</span>
          <span class="l">{s.l}<a class="ref" href={`#ik-src-${s.r}`}><sup>{s.r}</sup></a></span>
        </div>
      ))}
    </div>

    <div class="example fx">
      <div class="ex-text">
        <h3>Ein Beispiel</h3>
        <p>
          Eine erfahrene Projektleiterin verlässt nach zwölf Jahren das Unternehmen. Im Wiki bleiben ihre
          Vorlagen, Prozessdiagramme und Übergabedokumente. Das ist der explizite Teil. Nicht dokumentiert ist,
          wen sie bei einer Eskalation zuerst anruft, welcher Zulieferer bei Engpässen wirklich reagiert und
          mit welchem Workaround sie jede Freigabe in zwei Tagen statt zwei Wochen bekommt.
          Dieses Wissen steht in keinem System und geht mit ihr.
        </p>
      </div>
      <figure class="ex-viz" aria-label="Verhältnis von explizitem zu implizitem Wissen: rund 20 zu 80 Prozent">
        <div class="bar">
          <div class="seg exp"><span class="pct">~20&nbsp;%</span><span class="what">explizit: dokumentiert in Systemen</span></div>
          <div class="wl"></div>
          <div class="seg imp"><span class="pct">~80&nbsp;%</span><span class="what">implizit: in Köpfen, Routinen, Beziehungen</span></div>
        </div>
        <figcaption>Gängige Faustregel der Wissensmanagement-Praxis; Studien wie die der Delphi Group stützen die Größenordnung.<a class="ref" href="#ik-src-8"><sup>8</sup></a></figcaption>
      </figure>
    </div>

    <h3 class="fx">Warum es sich lohnt, es sichtbar zu machen</h3>
    <div class="cards">
      {REASONS.map((c) => (
        <article class="card fx">
          <h4>{c.t}</h4>
          <p>{c.b}{c.refs.map((r) => <a class="ref" href={`#ik-src-${r}`}><sup>{r}</sup></a>)}</p>
        </article>
      ))}
    </div>

    <div class="closing fx">
      <p>
        Implizites Wissen lässt sich nicht per Formular abfragen. Es wird im Gespräch externalisiert.<a class="ref" href="#ik-src-2"><sup>2</sup></a>
        Genau dort setzt Inplicit an: KI-Interviews machen den impliziten Kontext Ihrer Organisation strukturiert
        sichtbar und verbinden ihn mit Ihren Tool-Daten.
      </p>
      <button class="ik-cta" id="ikCta" type="button">Zum Eisberg-Modell
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 13V4M4 8l4-4 4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </button>
    </div>

    <footer class="sources fx">
      <span class="src-head">Quellen</span>
      <ol>
        {SOURCES.map((s, i) => (
          <li id={`ik-src-${i + 1}`}><a href={s.href} target="_blank" rel="noopener noreferrer">{s.t}<span class="ext" aria-hidden="true">&#8599;</span></a></li>
        ))}
      </ol>
    </footer>
  </div>
</section>

<script>
  document.getElementById("ikCta")?.addEventListener("click", () => {
    document.getElementById("below")?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  /* Sanfte Reveals beim Scrollen. Default ist sichtbar (no-JS / reduced motion);
     JS setzt den Ausgangszustand inline und blendet per IO ein. */
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const els = [...document.querySelectorAll<HTMLElement>(".ik .fx")];
  if (!reduce && !document.hidden && "IntersectionObserver" in window) {
    els.forEach((el) => {
      el.style.opacity = "0";
      el.style.transform = "translateY(18px)";
      el.style.filter = "blur(6px)";
    });
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const el = e.target as HTMLElement;
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
          el.style.filter = "blur(0)";
          io.unobserve(el);
        });
      },
      { threshold: 0.15 }
    );
    els.forEach((el) => io.observe(el));
  }
</script>

<style>
  .ik { position: relative; background: linear-gradient(180deg, #070b15 0%, #0a0a0a 30%);
    color: #f5f5f5;
    font-family: var(--font-family, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif);
    padding: 120px 0 96px; }
  .wrap { max-width: var(--max-width, 1200px); margin: 0 auto; padding: 0 24px; }
  .fx { transition: opacity .8s cubic-bezier(.22,1,.36,1), transform .8s cubic-bezier(.22,1,.36,1), filter .8s ease; }

  .eyebrow { display: inline-block; margin-bottom: 20px; font-size: 12px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .18em; color: var(--color-accent, #f5a623); }
  h2 { margin: 0 0 24px; max-width: 720px; font-size: clamp(30px, 4vw, 48px); font-weight: 600;
    line-height: 1.1; letter-spacing: -.02em; color: #f5f5f5; text-wrap: balance; }
  .lead { margin: 0 0 64px; max-width: 660px; font-size: clamp(16px, 1.6vw, 18px); line-height: 1.65;
    color: rgba(255,255,255,.55); text-wrap: pretty; }

  .quote { margin: 0 0 64px; padding-left: 24px; border-left: 2px solid var(--color-accent, #f5a623); }
  .quote blockquote { margin: 0; font-size: clamp(22px, 2.6vw, 30px); font-weight: 300;
    line-height: 1.35; letter-spacing: -.01em; color: #f5f5f5; }
  .quote figcaption { margin-top: 12px; font-size: 13px; color: rgba(255,255,255,.55); }

  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 88px; }
  .stat { border: 1px solid rgba(255,255,255,.08); border-radius: 8px;
    background: rgba(255,255,255,.04); padding: 24px; display: flex; flex-direction: column; gap: 10px; }
  .stat .v { font-size: clamp(30px, 3.4vw, 42px); font-weight: 600; letter-spacing: -.02em;
    color: var(--color-accent, #f5a623); font-variant-numeric: tabular-nums; }
  .stat .l { font-size: 13.5px; line-height: 1.5; color: rgba(255,255,255,.55); }

  /* Beispiel + 80/20-Grafik: Bar in Markenfarben. Heller Block = explizit,
     dunkler Block = implizit, Amber-Linie als Wasserlinie dazwischen. */
  .example { display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: start; margin-bottom: 88px; }
  .ex-text p { margin: 0; font-size: clamp(15px, 1.5vw, 17px); line-height: 1.7; color: rgba(255,255,255,.6); }
  .ex-viz { margin: 0; }
  .bar { display: flex; flex-direction: column; height: 380px; border-radius: var(--radius-card, 8px);
    overflow: hidden; border: 1px solid rgba(255,255,255,.12); }
  .seg { display: flex; flex-direction: column; justify-content: center; gap: 3px; padding: 14px 20px; }
  .seg .pct { font-size: 22px; font-weight: 600; letter-spacing: -.02em; line-height: 1;
    font-variant-numeric: tabular-nums; }
  .seg .what { font-size: 12px; line-height: 1.4; }
  .seg.exp { flex: 0 0 20%; background: #ffffff; }
  .seg.exp .pct { color: #0a0a0a; }
  .seg.exp .what { color: rgba(0,0,0,.55); }
  .seg.imp { flex: 1; background: #141414; }
  .seg.imp .pct { color: var(--color-accent, #f5a623); }
  .seg.imp .what { color: rgba(255,255,255,.6); }
  .wl { flex: 0 0 2px; background: linear-gradient(90deg, rgba(245,166,35,.2), #f5a623, rgba(245,166,35,.2)); }
  .ex-viz figcaption { margin-top: 12px; font-size: 12px; line-height: 1.5; color: rgba(255,255,255,.4); }

  h3 { margin: 0 0 28px; font-size: clamp(20px, 2.2vw, 26px); font-weight: 600;
    letter-spacing: -.01em; color: #f5f5f5; }
  .ex-text h3 { margin-bottom: 14px; }
  .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 88px; }
  .card { border: 1px solid rgba(255,255,255,.08); border-radius: 8px;
    background: rgba(255,255,255,.04); padding: 28px; }
  .card h4 { margin: 0 0 10px; font-size: 16px; font-weight: 600; color: #f5f5f5; }
  .card p { margin: 0; font-size: 14px; line-height: 1.65; color: rgba(255,255,255,.55); }

  .closing { max-width: 660px; margin-bottom: 88px; }
  .closing p { margin: 0 0 28px; font-size: clamp(16px, 1.6vw, 18px); line-height: 1.65; color: #c9c9c9; }
  /* Ruhiger, heller Button auf dunklem Grund (statt grellem Verlauf) */
  .ik-cta { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(0,0,0,.08);
    border-radius: var(--radius-card, 8px); padding: 12px 22px; font-family: inherit; font-size: 14px;
    font-weight: 600; color: #0a0a0a; cursor: pointer; background: #ffffff;
    box-shadow: 0 12px 28px -14px rgba(0,0,0,.6); transition: transform .2s; }
  .ik-cta:hover { transform: translateY(-1px); }

  .ref { text-decoration: none; }
  .ref sup { font-size: 10px; font-weight: 600; color: var(--color-accent, #f5a623); margin-left: 2px; }
  .sources { border-top: 1px solid rgba(255,255,255,.08); padding-top: 28px; }
  .src-head { display: block; margin-bottom: 14px; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .16em; color: rgba(255,255,255,.55); }
  .sources ol { margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 6px; }
  .sources li { font-size: 12.5px; line-height: 1.55; color: #6a6a72; }
  .sources li:target { color: #c9c9c9; }
  .sources li a { color: inherit; text-decoration: none; border-bottom: 1px dotted rgba(255,255,255,.25);
    transition: color .15s ease, border-color .15s ease; }
  .sources li a:hover, .sources li a:focus-visible { color: #c9c9c9; border-bottom-color: var(--color-accent, #f5a623); }
  .sources .ext { margin-left: 4px; font-size: 10px; color: var(--color-accent, #f5a623); }

  @media (max-width: 860px) {
    .stats { grid-template-columns: 1fr; }
    .cards { grid-template-columns: 1fr; }
    .example { grid-template-columns: 1fr; gap: 28px; }
    .bar { height: 300px; }
    .ik { padding: 88px 0 72px; }
  }
</style>
